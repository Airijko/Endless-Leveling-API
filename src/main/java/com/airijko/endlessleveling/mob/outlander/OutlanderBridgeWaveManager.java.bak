package com.airijko.endlessleveling.mob.aram;

import com.google.gson.JsonArray;
import com.google.gson.JsonElement;
import com.google.gson.JsonObject;
import com.google.gson.JsonParser;
import com.hypixel.hytale.component.Ref;
import com.hypixel.hytale.component.Store;
import com.hypixel.hytale.logger.HytaleLogger;
import com.hypixel.hytale.math.vector.Vector3d;
import com.hypixel.hytale.math.vector.Vector3f;
import com.hypixel.hytale.server.core.HytaleServer;
import com.hypixel.hytale.server.core.Message;
import com.hypixel.hytale.server.core.modules.entity.component.TransformComponent;
import com.hypixel.hytale.server.core.modules.entity.damage.DeathComponent;
import com.hypixel.hytale.server.core.universe.PlayerRef;
import com.hypixel.hytale.server.core.universe.Universe;
import com.hypixel.hytale.server.core.universe.world.World;
import com.hypixel.hytale.server.core.universe.world.storage.EntityStore;
import com.hypixel.hytale.server.npc.NPCPlugin;
import com.hypixel.hytale.server.npc.entities.NPCEntity;

import javax.annotation.Nonnull;
import javax.annotation.Nullable;
import java.io.InputStream;
import java.io.InputStreamReader;
import java.nio.charset.StandardCharsets;
import java.util.ArrayList;
import java.util.Iterator;
import java.util.List;
import java.util.Locale;
import java.util.Objects;
import java.util.Random;
import java.util.UUID;
import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.CopyOnWriteArraySet;
import java.util.concurrent.ScheduledFuture;
import java.util.concurrent.TimeUnit;

public final class AramBridgeWaveManager {

    private static final HytaleLogger LOGGER = HytaleLogger.forEnclosingClassFull();
    private static final AramBridgeWaveManager INSTANCE = new AramBridgeWaveManager();

    public static final String WORLD_PREFIX = "instance-endless-";
    public static final String WORLD_BASE_NAME = "endless";
    public static final String WAVES_RESOURCE = "/waves/aram_bridge_waves.json";

    private static final Vector3d CENTER = new Vector3d(0.0, 80.0, 0.0);
    private static final Vector3d SPAWN_LEFT = new Vector3d(-92.0, 80.0, 0.0);
    private static final Vector3d SPAWN_RIGHT = new Vector3d(92.0, 80.0, 0.0);
    private static final double LEASH_RADIUS = 150.0;
    private static final double AGGRO_RADIUS = 200.0;
    private static final double AGGRO_RADIUS_SQ = AGGRO_RADIUS * AGGRO_RADIUS;
    private static final int COUNTDOWN_SECONDS = 30;
    private static final long INTER_WAVE_DELAY_SECONDS = 5L;
    private static final long TICK_PERIOD_SECONDS = 1L;

    private final ConcurrentHashMap<UUID, Session> sessions = new ConcurrentHashMap<>();
    private final List<WaveDef> waves = new ArrayList<>();
    private final Random random = new Random();
    private volatile ScheduledFuture<?> watchdogTask;

    private AramBridgeWaveManager() {}

    public static AramBridgeWaveManager get() { return INSTANCE; }

    public void load() {
        startWatchdog();
        waves.clear();
        try (InputStream in = AramBridgeWaveManager.class.getResourceAsStream(WAVES_RESOURCE)) {
            if (in == null) {
                LOGGER.atWarning().log("Aram Bridge waves resource missing: %s", WAVES_RESOURCE);
                return;
            }
            JsonElement root = JsonParser.parseReader(new InputStreamReader(in, StandardCharsets.UTF_8));
            JsonObject rootObj = root.getAsJsonObject();
            JsonArray wavesArr = rootObj.getAsJsonArray("waves");
            for (JsonElement we : wavesArr) {
                JsonObject wo = we.getAsJsonObject();
                int num = wo.has("wave") ? wo.get("wave").getAsInt() : (waves.size() + 1);
                WaveDef def = new WaveDef(num);
                if (wo.has("pools")) {
                    for (JsonElement pe : wo.getAsJsonArray("pools")) {
                        JsonObject po = pe.getAsJsonObject();
                        JsonArray batchArr = po.getAsJsonArray("mobs");
                        if (batchArr == null || batchArr.size() == 0) continue;
                        JsonObject batch = batchArr.get(random.nextInt(batchArr.size())).getAsJsonObject();
                        for (JsonElement me : batch.getAsJsonArray("mobs")) {
                            JsonObject mo = me.getAsJsonObject();
                            String id = mo.get("id").getAsString();
                            int count = mo.get("count").getAsInt();
                            for (int i = 0; i < count; i++) def.mobIds.add(id);
                        }
                    }
                }
                if (wo.has("bosses")) {
                    for (JsonElement be : wo.getAsJsonArray("bosses")) {
                        def.bossIds.add(be.getAsJsonObject().get("id").getAsString());
                    }
                }
                waves.add(def);
            }
            LOGGER.atInfo().log("Aram Bridge: loaded %d waves", waves.size());
        } catch (Exception ex) {
            LOGGER.atSevere().withCause(ex).log("Failed to load Aram Bridge wave config");
        }
    }

    private void startWatchdog() {
        if (watchdogTask != null && !watchdogTask.isDone()) return;
        watchdogTask = HytaleServer.SCHEDULED_EXECUTOR.scheduleAtFixedRate(() -> {
            try {
                for (PlayerRef pr : Universe.get().getPlayers()) {
                    if (pr == null || !pr.isValid()) continue;
                    Ref<EntityStore> pRef = pr.getReference();
                    if (pRef == null || !pRef.isValid()) continue;
                    Store<EntityStore> st = pRef.getStore();
                    if (st == null || st.getExternalData() == null) continue;
                    World w = st.getExternalData().getWorld();
                    if (w == null) continue;
                    if (isAramBridgeWorld(w)) onPlayerEntered(w);
                }
            } catch (Throwable t) {
                LOGGER.atWarning().withCause(t).log("Aram Bridge watchdog error");
            }
        }, 5L, 5L, TimeUnit.SECONDS);
    }

    public boolean isAramBridgeWorld(@Nullable World world) {
        if (world == null) return false;
        String n = world.getName();
        if (n == null) return false;
        String lower = n.toLowerCase(Locale.ROOT);
        return lower.startsWith(WORLD_PREFIX)
                || lower.equals(WORLD_BASE_NAME)
                || lower.startsWith(WORLD_BASE_NAME + "-");
    }

    public void onPlayerEntered(@Nonnull World world) {
        if (!isAramBridgeWorld(world)) return;
        if (waves.isEmpty()) {
            LOGGER.atWarning().log("Aram Bridge: player entered %s but wave config empty", world.getName());
            return;
        }
        UUID key = world.getWorldConfig().getUuid();
        LOGGER.atInfo().log("Aram Bridge: player entered world=%s uuid=%s", world.getName(), key);
        sessions.computeIfAbsent(key, k -> startCountdown(world));
    }

    public boolean forceStart(@Nonnull World world) {
        Session s = sessions.get(world.getWorldConfig().getUuid());
        if (s == null) {
            s = new Session(world);
            sessions.put(world.getWorldConfig().getUuid(), s);
        }
        if (s.started) return false;
        cancel(s.countdownTask);
        s.countdownTask = null;
        beginWave(s, 1);
        return true;
    }

    private Session startCountdown(@Nonnull World world) {
        Session s = new Session(world);
        broadcast(world, String.format(Locale.ROOT,
                "[Aram Bridge] Waves begin in %ds. Use /lvl start to begin now.", COUNTDOWN_SECONDS), "#f3c27a");
        s.countdownTask = HytaleServer.SCHEDULED_EXECUTOR.schedule(() -> {
            if (!s.started) beginWave(s, 1);
        }, COUNTDOWN_SECONDS, TimeUnit.SECONDS);
        return s;
    }

    private void beginWave(@Nonnull Session s, int waveNumber) {
        if (waveNumber > waves.size()) {
            broadcast(s.world, "[Aram Bridge] All waves cleared. Victory!", "#8effb6");
            cleanup(s);
            return;
        }
        s.started = true;
        s.currentWave = waveNumber;
        s.activeMobs.clear();

        WaveDef def = waves.get(waveNumber - 1);
        broadcast(s.world, String.format(Locale.ROOT,
                "[Aram Bridge] Wave %d/%d: %d mobs + %d boss(es)",
                waveNumber, waves.size(), def.mobIds.size(), def.bossIds.size()), "#f3b37a");

        NPCPlugin npc = NPCPlugin.get();
        if (npc == null) { LOGGER.atWarning().log("NPCPlugin null"); return; }
        World world = s.world;

        s.awaitingSpawn = true;
        world.execute(() -> {
            try {
                Store<EntityStore> store = world.getEntityStore().getStore();
                if (store == null) { LOGGER.atWarning().log("Aram Bridge: world store null"); return; }
                List<String> all = new ArrayList<>(def.mobIds);
                all.addAll(def.bossIds);
                int spawned = 0;
                for (int i = 0; i < all.size(); i++) {
                    String id = all.get(i);
                    Vector3d sp = (i % 2 == 0) ? SPAWN_LEFT : SPAWN_RIGHT;
                    float yaw = (float) Math.atan2(CENTER.x - sp.x, CENTER.z - sp.z);
                    Vector3f rot = new Vector3f(0f, yaw, 0f);
                    Object res = null;
                    try {
                        res = npc.spawnNPC(store, id, null, sp, rot);
                    } catch (Throwable t) {
                        LOGGER.atWarning().withCause(t).log("Aram Bridge: spawn failed id=%s", id);
                    }
                    Ref<EntityStore> ref = extractRef(res);
                    if (ref != null) {
                        s.activeMobs.add(ref);
                        lockTargetNearest(world, store, ref);
                        spawned++;
                    } else {
                        LOGGER.atWarning().log("Aram Bridge: null ref for spawn id=%s", id);
                    }
                }
                LOGGER.atInfo().log("Aram Bridge: wave %d spawned %d/%d mobs", s.currentWave, spawned, all.size());
            } finally {
                s.awaitingSpawn = false;
            }
        });

        if (s.tickTask == null || s.tickTask.isDone()) {
            s.tickTask = HytaleServer.SCHEDULED_EXECUTOR.scheduleAtFixedRate(
                    () -> tick(s), TICK_PERIOD_SECONDS, TICK_PERIOD_SECONDS, TimeUnit.SECONDS);
        }
    }

    private void tick(@Nonnull Session s) {
        try {
            if (!s.world.isAlive()) { cleanup(s); return; }
            Store<EntityStore> store = s.world.getEntityStore().getStore();
            if (store == null) return;
            Iterator<Ref<EntityStore>> it = s.activeMobs.iterator();
            while (it.hasNext()) {
                Ref<EntityStore> ref = it.next();
                if (ref == null || !ref.isValid()) { it.remove(); continue; }
                DeathComponent death = store.getComponent(ref, DeathComponent.getComponentType());
                if (death != null) { it.remove(); continue; }
                TransformComponent tr = store.getComponent(ref,
                        Objects.requireNonNull(TransformComponent.getComponentType()));
                if (tr == null) continue;
                Vector3d pos = tr.getPosition();
                if (pos == null) continue;
                double dx = pos.x - CENTER.x;
                double dz = pos.z - CENTER.z;
                double distSq = dx * dx + dz * dz;
                if (distSq > LEASH_RADIUS * LEASH_RADIUS) {
                    Vector3d back = (pos.x < 0) ? SPAWN_LEFT : SPAWN_RIGHT;
                    tr.teleportPosition(back);
                }
                // Re-lock aggro every tick so mobs track the nearest player within 200 blocks.
                lockTargetNearest(s.world, store, ref);
            }
            if (s.awaitingSpawn) return;
            if (s.activeMobs.isEmpty() && s.currentWave > 0 && !s.awaitingNextWave) {
                s.awaitingNextWave = true;
                int next = s.currentWave + 1;
                broadcast(s.world, String.format(Locale.ROOT,
                        "[Aram Bridge] Wave %d cleared. Next in %ds...", s.currentWave, INTER_WAVE_DELAY_SECONDS),
                        "#8effb6");
                HytaleServer.SCHEDULED_EXECUTOR.schedule(() -> {
                    s.awaitingNextWave = false;
                    beginWave(s, next);
                }, INTER_WAVE_DELAY_SECONDS, TimeUnit.SECONDS);
            }
        } catch (Throwable t) {
            LOGGER.atWarning().withCause(t).log("Aram Bridge tick error");
        }
    }

    private void lockTargetNearest(@Nonnull World world, @Nonnull Store<EntityStore> store,
                                   @Nonnull Ref<EntityStore> mobRef) {
        try {
            NPCEntity npc = store.getComponent(mobRef, NPCEntity.getComponentType());
            if (npc == null || npc.getRole() == null) return;
            TransformComponent mt = store.getComponent(mobRef,
                    Objects.requireNonNull(TransformComponent.getComponentType()));
            if (mt == null || mt.getPosition() == null) return;
            Vector3d mp = mt.getPosition();
            Ref<EntityStore> best = null;
            double bestSq = Double.MAX_VALUE;
            for (PlayerRef pr : Universe.get().getPlayers()) {
                if (pr == null || !pr.isValid()) continue;
                Ref<EntityStore> pRef = pr.getReference();
                if (pRef == null || !pRef.isValid()) continue;
                Store<EntityStore> pStore = pRef.getStore();
                if (pStore == null) continue;
                World pWorld = pStore.getExternalData() != null ? pStore.getExternalData().getWorld() : null;
                if (pWorld == null || !pWorld.equals(world)) continue;
                TransformComponent pt = pStore.getComponent(pRef,
                        Objects.requireNonNull(TransformComponent.getComponentType()));
                if (pt == null || pt.getPosition() == null) continue;
                Vector3d pp = pt.getPosition();
                double dx = pp.x - mp.x, dz = pp.z - mp.z;
                double sq = dx * dx + dz * dz;
                if (sq < bestSq && sq <= AGGRO_RADIUS_SQ) { bestSq = sq; best = pRef; }
            }
            if (best != null) npc.getRole().setMarkedTarget("LockedTarget", best);
        } catch (Throwable ignored) {}
    }

    @SuppressWarnings("unchecked")
    @Nullable
    private static Ref<EntityStore> extractRef(@Nullable Object res) {
        if (res == null) return null;
        if (res instanceof Ref<?> r) return (Ref<EntityStore>) r;
        for (String m : new String[]{"getLeft", "getFirst", "getKey"}) {
            try {
                Object v = res.getClass().getMethod(m).invoke(res);
                if (v instanceof Ref<?> r) return (Ref<EntityStore>) r;
            } catch (Exception ignored) {}
        }
        return null;
    }

    private static void cancel(@Nullable ScheduledFuture<?> f) {
        if (f != null) try { f.cancel(false); } catch (Exception ignored) {}
    }

    private void cleanup(@Nonnull Session s) {
        cancel(s.tickTask);
        cancel(s.countdownTask);
        sessions.remove(s.world.getWorldConfig().getUuid());
    }

    private static void broadcast(@Nonnull World world, @Nonnull String text, @Nonnull String color) {
        for (PlayerRef pr : Universe.get().getPlayers()) {
            if (pr == null || !pr.isValid()) continue;
            Ref<EntityStore> ref = pr.getReference();
            if (ref == null || !ref.isValid()) continue;
            Store<EntityStore> st = ref.getStore();
            if (st == null || st.getExternalData() == null) continue;
            World w = st.getExternalData().getWorld();
            if (w != null && w.equals(world)) pr.sendMessage(Message.raw(text).color(color));
        }
    }

    private static final class WaveDef {
        final int number;
        final List<String> mobIds = new ArrayList<>();
        final List<String> bossIds = new ArrayList<>();
        WaveDef(int n) { this.number = n; }
    }

    private static final class Session {
        final World world;
        int currentWave = 0;
        boolean started = false;
        boolean awaitingNextWave = false;
        volatile boolean awaitingSpawn = false;
        ScheduledFuture<?> countdownTask;
        ScheduledFuture<?> tickTask;
        final CopyOnWriteArraySet<Ref<EntityStore>> activeMobs = new CopyOnWriteArraySet<>();
        Session(World world) { this.world = world; }
    }
}
