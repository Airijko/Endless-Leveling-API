$C = "../Common.ui";
$Nav = "Nav/LeftNavPanel.ui";

@DungeonCard = Group {
    Anchor: (Width: 250, Height: 258);
    LayoutMode: Top;
    Background: #0b141f(0.92);
    Padding: (Full: 14);

    Group {
        Anchor: (Height: 94, Bottom: 14);
        Background: @BannerColor;
        Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);

        Label #DungeonCardBadge {
            Text: @BadgeText;
            Anchor: (Height: 16);
            Style: (FontSize: 10, TextColor: #d9e7f6, RenderBold: true, LetterSpacing: 1);
        }

        Label #DungeonCardBannerTitle {
            Text: @BannerTitle;
            Anchor: (Bottom: 4, Height: 32);
            Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Bottom, Wrap: true);
        }
    }

    Label #DungeonCardTitle {
        Text: @CardTitle;
        Anchor: (Height: 24, Bottom: 6);
        Style: (FontSize: 17, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
    }

    Label #DungeonCardMeta {
        Text: @MetaText;
        Anchor: (Height: 18, Bottom: 10);
        Style: (FontSize: 11, TextColor: #7fb7ff, RenderBold: true, VerticalAlignment: Center);
    }

    Label #DungeonCardDescription {
        Text: @DescriptionText;
        FlexWeight: 1;
        Style: (FontSize: 12, TextColor: #bdd0e8, Wrap: true);
    }
};

$C.@PageOverlay {
    $C.@DecoratedContainer {
        Anchor: (Width: 1000, Height: 700);
        #Title {
            Group {
                $C.@Title #DungeonsTitle {
                    @Text = "ENDLESS LEVELING";
                }
            }
        }

        #Content {
            LayoutMode: Left;
            Padding: (Full: 0);

            $Nav.@LeftNavPanel {}

            Group #RightPanel {
                FlexWeight: 1;
                LayoutMode: Top;
                Anchor: (Right: 7, Bottom: 7);

                Group #Header {
                    LayoutMode: Left;
                    Anchor: (Height: 60);
                    Padding: (Horizontal: 16, Vertical: 10);

                    Label #DungeonsTitleLabel {
                        Text: "Dungeons";
                        Anchor: (Height: 60);
                        Style: (FontSize: 22, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                    }

                    Group { FlexWeight: 1; }

                    Group {
                        LayoutMode: Left;
                        Background: #0f1c29(0.92);
                        Anchor: (Height: 40);
                        Padding: (Full: 8);

                        Label #DungeonsIntroText {
                            Text: "Integrated instance mods, grouped by source pack.";
                            Style: (TextColor: #aaccff, FontSize: 14, VerticalAlignment: Center);
                        }
                    }
                }

                Group {
                    Anchor: (Height: 1);
                    Background: #2b3542;
                }

                Group #Main {
                    LayoutMode: TopScrolling;
                    ScrollbarStyle: $C.@DefaultScrollbarStyle;
                    FlexWeight: 1;
                    Padding: (Full: 16);

                    Group #OverviewCard {
                        LayoutMode: Top;
                        Background: #0b141f(0.88);
                        Padding: (Full: 18);

                        Label {
                            Text: "Dungeon Library";
                            Anchor: (Height: 24);
                            Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true);
                        }

                        Group { Anchor: (Height: 6); }

                        Label {
                            Text: "This page tracks the dungeon content currently integrated into your Endless Leveling setup. Endgame content is shown first, followed by the Major Dungeons chain.";
                            Style: (FontSize: 13, TextColor: #bfd0e4, Wrap: true);
                        }
                    }

                    Group { Anchor: (Height: 18); }

                    Group #EndgameSection {
                        LayoutMode: Top;

                        Label {
                            Text: "ENDGAME";
                            Anchor: (Height: 24, Bottom: 10);
                            Style: (FontSize: 16, TextColor: #d2ecff, RenderBold: true, LetterSpacing: 1);
                        }

                        Group {
                            LayoutMode: Left;
                            Anchor: (Height: 258, Bottom: 12);

                            @DungeonCard {
                                @BannerColor = #113451;
                                @BadgeText = "ENDGAME & QOL";
                                @BannerTitle = "Frozen Dungeon";
                                @CardTitle = "Frozen Dungeon";
                                @MetaText = "Instance: endgame_frozen_dungeon";
                                @DescriptionText = "An instanced icy gauntlet from Endgame & QoL, integrated through the Endless Leveling dungeon gate addon.";
                            }

                            Group { Anchor: (Width: 12); }

                            @DungeonCard {
                                @BannerColor = #184637;
                                @BadgeText = "ENDGAME & QOL";
                                @BannerTitle = "Swamp Dungeon";
                                @CardTitle = "Swamp Dungeon";
                                @MetaText = "Instance: endgame_swamp_dungeon";
                                @DescriptionText = "A swamp-themed endgame instance with its own scaling profile and gate integration path.";
                            }

                            Group { Anchor: (Width: 12); }

                            @DungeonCard {
                                @BannerColor = #25193e;
                                @BadgeText = "ENDGAME & QOL";
                                @BannerTitle = "Void Golem Realm";
                                @CardTitle = "Void Golem Realm";
                                @MetaText = "Instance: endgame_golem_void";
                                @DescriptionText = "The void-tier endgame realm, surfaced here as a dedicated integrated instance dungeon card.";
                            }
                        }
                    }

                    Group { Anchor: (Height: 16); }

                    Group #MajorSection {
                        LayoutMode: Top;

                        Label {
                            Text: "MAJOR DUNGEONS";
                            Anchor: (Height: 24, Bottom: 10);
                            Style: (FontSize: 16, TextColor: #ffd58a, RenderBold: true, LetterSpacing: 1);
                        }

                        Group {
                            LayoutMode: Left;
                            Anchor: (Height: 258, Bottom: 12);

                            @DungeonCard {
                                @BannerColor = #4f231c;
                                @BadgeText = "D01";
                                @BannerTitle = "Azaroth";
                                @CardTitle = "Azaroth";
                                @MetaText = "Major Dungeons 0.4.5";
                                @DescriptionText = "The first Major Dungeons instance chain entry, exposed in Endless Leveling as the D01 gate route.";
                            }

                            Group { Anchor: (Width: 12); }

                            @DungeonCard {
                                @BannerColor = #3d1d33;
                                @BadgeText = "D02";
                                @BannerTitle = "Katherina";
                                @CardTitle = "Katherina";
                                @MetaText = "Major Dungeons 0.4.5";
                                @DescriptionText = "The second instanced dungeon in the Major Dungeons set, tied to the Katherina route and dungeon gate bridge.";
                            }

                            Group { Anchor: (Width: 12); }

                            @DungeonCard {
                                @BannerColor = #3c2b18;
                                @BadgeText = "D03";
                                @BannerTitle = "Baron";
                                @CardTitle = "Baron";
                                @MetaText = "Major Dungeons 0.4.5";
                                @DescriptionText = "The third Major Dungeons instance, available through the integrated D03 gate path in the addon stack.";
                            }
                        }
                    }
                }
            }
        }
    }
}

$C.@BackButton {}