$C = "../../Common.ui";
$Nav = "../Nav/LeftNavPanel.ui";

$C.@PageOverlay {
    $C.@DecoratedContainer {
        Anchor: (Width: 1000, Height: 700);
        #Title {
            Group {
                $C.@Title #DungeonsTitle {
                    @Text = "ENDLESS LEVELING";
                }
            }
        }

        #Content {
            LayoutMode: Left;
            Padding: (Full: 0);

            $Nav.@LeftNavPanel {}

            Group #RightPanel {
                FlexWeight: 1;
                LayoutMode: Top;
                Anchor: (Right: 7, Bottom: 7);

                Group #Header {
                    LayoutMode: Left;
                    Anchor: (Height: 60);
                    Padding: (Horizontal: 16, Vertical: 10);

                    Label #DungeonsTitleLabel {
                        Text: "Dungeons";
                        Anchor: (Height: 60);
                        Style: (FontSize: 22, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                    }

                    Group { FlexWeight: 1; }
                }

                Group {
                    Anchor: (Height: 1);
                    Background: #2b3542;
                }

                Group #Main {
                    LayoutMode: TopScrolling;
                    ScrollbarStyle: $C.@DefaultScrollbarStyle;
                    FlexWeight: 1;
                    Padding: (Full: 16);

                    Group #OverviewCard {
                        LayoutMode: Top;
                        Background: #0b141f(0.88);
                        Padding: (Full: 18);

                        Label {
                            Text: "Dungeon Library";
                            Anchor: (Height: 24);
                            Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true);
                        }

                        Group { Anchor: (Height: 6); }

                        Label #DungeonsOverviewText {
                            Text: "";
                            Style: (FontSize: 13, TextColor: #bfd0e4, Wrap: true);
                        }
                    }

                    Group { Anchor: (Height: 18); }

                    Group #EndgameSection {
                        LayoutMode: Top;

                        Label {
                            Text: "ENDGAME";
                            Anchor: (Height: 24, Bottom: 10);
                            Style: (FontSize: 16, TextColor: #d2ecff, RenderBold: true, LetterSpacing: 1);
                        }

                        Group #EndgameCards {
                            LayoutMode: Top;
                        }
                    }

                    Group { Anchor: (Height: 16); }

                    Group #MajorSection {
                        LayoutMode: Top;

                        Label {
                            Text: "MAJOR DUNGEONS";
                            Anchor: (Height: 24, Bottom: 10);
                            Style: (FontSize: 16, TextColor: #ffd58a, RenderBold: true, LetterSpacing: 1);
                        }

                        Group #MajorCards {
                            LayoutMode: Top;
                        }
                    }
                }
            }
        }
    }
}

$C.@BackButton {}