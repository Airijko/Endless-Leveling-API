$C = "../../Common.ui";
$Nav = "../Nav/LeftNavPanel.ui";

@DownloadButtonStyle = TextButtonStyle(
    Default:  (Background: $C.@DefaultSquareButtonDefaultBackground,  LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered:  (Background: $C.@DefaultSquareButtonHoveredBackground,  LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed:  (Background: $C.@DefaultSquareButtonPressedBackground,  LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

$C.@PageOverlay {
    $C.@DecoratedContainer {
        Anchor: (Width: 1000, Height: 700);
        #Title {
            Group {
                $C.@Title #DungeonsTitle {
                    @Text = "ENDLESS LEVELING";
                }
            }
        }

        #Content {
            LayoutMode: Left;
            Padding: (Full: 0);

            $Nav.@LeftNavPanel {}

            Group #RightPanel {
                FlexWeight: 1;
                LayoutMode: Top;
                Anchor: (Right: 7, Bottom: 7);

                Group #Main {
                    LayoutMode: TopScrolling;
                    ScrollbarStyle: $C.@DefaultScrollbarStyle;
                    FlexWeight: 1;
                    Padding: (Full: 16);

                    Group #OverviewCard {
                        LayoutMode: Top;
                        Background: #0b141f(0.88);
                        Padding: (Full: 18);

                        Label {
                            Text: "Dungeon Library";
                            Anchor: (Height: 24);
                            Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true);
                        }

                        Group { Anchor: (Height: 6); }

                        Label #DungeonsOverviewText {
                            Text: "";
                            Style: (FontSize: 13, TextColor: #bfd0e4, Wrap: true);
                        }
                    }

                    Group { Anchor: (Height: 18); }

                    Group #EndgameSection {
                        LayoutMode: Top;

                        Group {
                            LayoutMode: Left;
                            Anchor: (Height: 30, Bottom: 10);

                            Label {
                                Text: "ENDGAME";
                                Anchor: (Height: 24);
                                Style: (FontSize: 16, TextColor: #d2ecff, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center);
                            }

                            Group { FlexWeight: 1; }

                            Label #EndgameNotInstalledLabel {
                                Text: "Not Installed";
                                Anchor: (Height: 20, Right: 10);
                                Visible: false;
                                Style: (FontSize: 12, TextColor: #e07070, RenderBold: true, VerticalAlignment: Center);
                            }

                            $C.@TextButton #EndgameInstallButton {
                                Text: "Download";
                                Anchor: (Width: 100, Height: 28);
                                Padding: (Horizontal: 10);
                                Style: @DownloadButtonStyle;
                                Visible: false;
                            }
                        }

                        Group #EndgameCards {
                            LayoutMode: Top;
                        }

                        Group #EndgameDimOverlay {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: #000000(0.55);
                            Visible: false;
                        }
                    }

                    Group { Anchor: (Height: 16); }

                    Group #MajorSection {
                        LayoutMode: Top;

                        Group {
                            LayoutMode: Left;
                            Anchor: (Height: 30, Bottom: 10);

                            Label {
                                Text: "MAJOR DUNGEONS";
                                Anchor: (Height: 24);
                                Style: (FontSize: 16, TextColor: #ffd58a, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center);
                            }

                            Group { FlexWeight: 1; }

                            Label #MajorNotInstalledLabel {
                                Text: "Not Installed";
                                Anchor: (Height: 20, Right: 10);
                                Visible: false;
                                Style: (FontSize: 12, TextColor: #e07070, RenderBold: true, VerticalAlignment: Center);
                            }

                            $C.@TextButton #MajorInstallButton {
                                Text: "Download";
                                Anchor: (Width: 100, Height: 28);
                                Padding: (Horizontal: 10);
                                Style: @DownloadButtonStyle;
                                Visible: false;
                            }
                        }

                        Group #MajorCards {
                            LayoutMode: Top;
                        }

                        Group #MajorDimOverlay {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: #000000(0.55);
                            Visible: false;
                        }
                    }
                }
            }
        }
    }
}

$C.@BackButton {}