Button #CardWeeklyBosses {
    Anchor: (Width: 340, Height: 580, Right: 24, Top: 10, Bottom: 10);
    Padding: (Full: 0);
    Background: #0c121a(0);
    LayoutMode: Top;
    Style: (
        Hovered: (Background: #1c2b40(0.20)),
        Pressed: (Background: #263852(0.28))
    );

    Group { Anchor: (Height: 2); Background: #25384b; }

    Group {
        FlexWeight: 1;
        LayoutMode: Left;

        Group { Anchor: (Width: 2); Background: #25384b; }

        Group {
            FlexWeight: 1;

            Group { Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0); Background: #0e1826(0.94); }

            Group {
                Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                LayoutMode: Top;

                Group {
                    Anchor: (Height: 180);
                    Background: #2e1a3a;
                    Padding: (Full: 4);

                    Group #WeeklyBossesBannerImage {
                        Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                        Background: (TexturePath: "../Images/EndlessWeeklyBossPlaceholder.png");
                        Visible: false;

                        Group {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: #000000(0.3);
                        }
                    }

                    Group {
                        Anchor: (Top: 6, Left: 6, Height: 22, Width: 150);
                        Background: #0a121c(0.85);
                        LayoutMode: Middle;
                        Label {
                            Text: "ENDLESS LEVELING";
                            Style: (FontSize: 9, TextColor: #ff5555, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
                        }
                    }
                }

                Group {
                    LayoutMode: Top;
                    FlexWeight: 1;
                    Padding: (Left: 14, Right: 14, Top: 12, Bottom: 12);

                    Label {
                        Text: "Weekly Bosses";
                        Anchor: (Height: 24);
                        Style: (FontSize: 18, TextColor: #f2f7ff, RenderBold: true);
                    }

                    Group { Anchor: (Height: 2); }

                    Label {
                        Text: "By Airijko";
                        Anchor: (Height: 16);
                        Style: (FontSize: 11, TextColor: #7fb7ff, RenderBold: true);
                    }

                    Group { Anchor: (Height: 8); }

                    Label #WeeklyBossesStatus {
                        Text: "Patreon Exclusive";
                        Anchor: (Height: 16);
                        Style: (FontSize: 11, TextColor: #ff5555, RenderBold: true, LetterSpacing: 1);
                    }

                    Group { Anchor: (Height: 8); }

                    Group { Anchor: (Height: 1); Background: #ffffff(0.08); }

                    Group { Anchor: (Height: 8); }

                    Label {
                        Text: "High-stakes weekly raid bosses with prestige rewards and leaderboard glory. Patreon-exclusive content.";
                        Style: (FontSize: 11, TextColor: #bdd0e8, Wrap: true);
                        FlexWeight: 1;
                    }

                    Label #WeeklyBossesPatreonHint {
                        Text: "Click for Patreon";
                        Anchor: (Height: 14);
                        Style: (FontSize: 10, TextColor: #ff5555, HorizontalAlignment: Center, VerticalAlignment: End, LetterSpacing: 1);
                    }
                }
            }
        }

        Group { Anchor: (Width: 2); Background: #25384b; }
    }

    Group { Anchor: (Height: 2); Background: #25384b; }

    Group {
        Anchor: (Top: 0, Left: 0, Right: 0, Height: 3);
        Background: #ff5555;
    }
}
