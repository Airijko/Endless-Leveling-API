$C = "../../../../Common.ui";

@CardButtonLabelStyle = LabelStyle(
    FontSize: 11,
    TextColor: #e8f1ff,
    RenderBold: true,
    RenderUppercase: true,
    LetterSpacing: 1,
    HorizontalAlignment: Center,
    VerticalAlignment: Center,
);

@CardButtonStyle = TextButtonStyle(
    Default:  (Background: $C.@DefaultSquareButtonDefaultBackground,  LabelStyle: @CardButtonLabelStyle),
    Hovered:  (Background: $C.@DefaultSquareButtonHoveredBackground,  LabelStyle: @CardButtonLabelStyle),
    Pressed:  (Background: $C.@DefaultSquareButtonPressedBackground,  LabelStyle: @CardButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

Group {
    Anchor: (Width: 340, Height: 580, Right: 24, Top: 10, Bottom: 10);
    LayoutMode: Top;

    Group { Anchor: (Height: 2); Background: #25384b; }

    Group {
        FlexWeight: 1;
        LayoutMode: Left;

        Group { Anchor: (Width: 2); Background: #25384b; }

        Group {
            FlexWeight: 1;

            Group { Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0); Background: #0e1826(0.94); }

            Group #KatherinaCardFront {
                Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                LayoutMode: Top;
                Visible: true;

                Group {
                    Anchor: (Height: 200);
                    Background: #2a2245;
                    Padding: (Full: 4);

                    Group #KatherinaBannerImage {
                        Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                        Background: (TexturePath: "../Images/MajorKatherinaPlaceholder.png");
                        Visible: false;
                        Group {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: #000000(0.3);
                        }
                    }

                    Group {
                        Anchor: (Top: 6, Left: 6, Height: 22, Width: 150);
                        Background: #0a121c(0.85);
                        LayoutMode: Middle;
                        Label {
                            Text: "MAJOR DUNGEONS";
                            Style: (FontSize: 9, TextColor: #ffd58a, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
                        }
                    }
                }

                Group {
                    LayoutMode: Top;
                    FlexWeight: 1;
                    Padding: (Left: 14, Right: 14, Top: 12, Bottom: 12);

                    Label {
                        Text: "Katherina";
                        Anchor: (Height: 24);
                        Style: (FontSize: 18, TextColor: #f2f7ff, RenderBold: true);
                    }

                    Group { Anchor: (Height: 2); }

                    Label {
                        Text: "By MAJOR76";
                        Anchor: (Height: 16);
                        Style: (FontSize: 11, TextColor: #7fb7ff, RenderBold: true);
                    }

                    Group { Anchor: (Height: 8); }

                    Label {
                        Text: "Mechanics / Control";
                        Anchor: (Height: 16);
                        Style: (FontSize: 11, TextColor: #ffd58a, RenderBold: true, LetterSpacing: 1);
                    }

                    Group { Anchor: (Height: 8); }

                    Group { Anchor: (Height: 1); Background: #ffffff(0.08); }

                    Group { Anchor: (Height: 8); }

                    Label {
                        Text: "A mid-chain dungeon focused on sustained mechanics, control checks, and layered encounter phases.";
                        Style: (FontSize: 11, TextColor: #bdd0e8, Wrap: true);
                        FlexWeight: 1;
                    }

                    Group { Anchor: (Height: 8); }

                    $C.@TextButton #KatherinaDetailsButton {
                        Text: "DETAILS";
                        Anchor: (Height: 36);
                        Padding: (Horizontal: 8);
                        Style: @CardButtonStyle;
                    }
                }
            }

            Group #KatherinaCardBack {
                Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                LayoutMode: Top;
                Visible: false;
                Padding: (Left: 14, Right: 14, Top: 14, Bottom: 12);

                Label {
                    Text: "ADVANCED DETAILS";
                    Anchor: (Height: 14);
                    Style: (FontSize: 10, TextColor: #ffd58a, RenderBold: true, LetterSpacing: 2);
                }

                Group { Anchor: (Height: 4); }

                Label {
                    Text: "Katherina";
                    Anchor: (Height: 24);
                    Style: (FontSize: 18, TextColor: #f0c040, RenderBold: true);
                }

                Group { Anchor: (Height: 8); }

                Group { Anchor: (Height: 1); Background: #ffffff(0.08); }

                Group { Anchor: (Height: 8); }

                Label {
                    Text: "MECHANICS";
                    Anchor: (Height: 14);
                    Style: (FontSize: 10, TextColor: #9fb6d3, RenderBold: true, LetterSpacing: 1);
                }

                Group { Anchor: (Height: 4); }

                Label {
                    Text: "- Sustained mechanic checks throughout.";
                    Anchor: (Height: 28);
                    Style: (FontSize: 10, TextColor: #bdd0e8, Wrap: true);
                }
                Label {
                    Text: "- Layered encounter phases require coordination.";
                    Anchor: (Height: 28);
                    Style: (FontSize: 10, TextColor: #bdd0e8, Wrap: true);
                }
                Label {
                    Text: "- Mid-chain entry in the Major Dungeons line.";
                    Anchor: (Height: 28);
                    Style: (FontSize: 10, TextColor: #bdd0e8, Wrap: true);
                }

                Group { Anchor: (Height: 8); }

                Label {
                    Text: "PORTAL ACCESS";
                    Anchor: (Height: 14);
                    Style: (FontSize: 10, TextColor: #9fb6d3, RenderBold: true, LetterSpacing: 1);
                }

                Group { Anchor: (Height: 4); }

                Label {
                    Text: "Requires the Major Dungeons mod. Find the dungeon's portal key in-world to enter.";
                    Anchor: (Height: 44);
                    Style: (FontSize: 10, TextColor: #ffc98b, Wrap: true);
                }

                Group { FlexWeight: 1; }

                $C.@TextButton #KatherinaBackButton {
                    Text: "< BACK";
                    Anchor: (Height: 36);
                    Padding: (Horizontal: 8);
                    Style: @CardButtonStyle;
                }
            }
        }

        Group { Anchor: (Width: 2); Background: #25384b; }
    }

    Group { Anchor: (Height: 2); Background: #25384b; }

    Group {
        Anchor: (Top: 0, Left: 0, Right: 0, Height: 3);
        Background: #ffd58a;
    }
}
