$C = "../../Common.ui";
$Nav = "../Nav/TopNavBar.ui";

@CustomStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

@FilterCompactLabelStyle = LabelStyle(
    FontSize: 14,
    TextColor: #bfcdd5,
    RenderBold: true,
    RenderUppercase: true,
    HorizontalAlignment: Center,
    VerticalAlignment: Center
);

@FilterCompactStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @FilterCompactLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: @FilterCompactLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @FilterCompactLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: @FilterCompactLabelStyle),
    Sounds: $C.@ButtonSounds,
);

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;
        Padding: (Vertical: 12);

        // ====================== TOP NAVBAR ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Height: 92);
                $Nav.@TopNavBar {}
            }
        }

        Group { Anchor: (Height: 14); }

        // ====================== MAIN CONTENT ======================
        Group {
            LayoutMode: Middle;

    $Nav.@ObjectiveContainer {
        Anchor: (Width: 1400, Height: 700);
        #Title {
            Label #LeaderboardsTitle {
                Text: "ENDLESS LEVELING";
                Style: $Nav.@PanelTitleStyle;
            }
        }

        #Content {
            LayoutMode: Top;
            Padding: (Full: 0);

            // ================= HEADER =================
            Group #Header {
                LayoutMode: Top;
                Padding: (Horizontal: 16, Top: 10, Bottom: 6);

                Group {
                    LayoutMode: Left;

                    Label #LeaderboardsTitleLabel {
                        Text: "Leaderboards";
                        Style: (FontSize: 22, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                        Anchor: (Height: 40);
                    }

                    Group { FlexWeight: 1; }

                    Group #LeaderboardsIntro {
                        LayoutMode: Left;
                        Background: (TexturePath: "../../Hud/ObjectivePanelContainer.png", Border: 15);
                        Anchor: (Height: 36);
                        Padding: (Horizontal: 14, Vertical: 6);

                        Label #LeaderboardsIntroText {
                            Style: (TextColor: #f0c040, FontSize: 12, RenderBold: true, VerticalAlignment: Center);
                            Text: "Top players ranked by level and experience.";
                        }
                    }
                }
            }

            // ================= CONTROLS =================
            Group #ControlSection {
                LayoutMode: Top;
                Padding: (Horizontal: 16, Vertical: 6);

                Group #ControlRow {
                    LayoutMode: Left;

                    Label #SortLabel {
                        Text: "Sort";
                        Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, VerticalAlignment: Center);
                        Anchor: (Width: 40);
                    }

                    $C.@TextButton #SortByButton {
                        Text: "BY: PRESTIGE";
                        Anchor: (Height: 30);
                        Padding: (Horizontal: 12, Vertical: 1);
                        Style: @FilterCompactStyle;
                    }

                    Group { Anchor: (Width: 6); }

                    $C.@TextButton #SortOrderButton {
                        Text: "ORDER: DESC";
                        Anchor: (Height: 30);
                        Padding: (Horizontal: 12, Vertical: 1);
                        Style: @FilterCompactStyle;
                    }

                    Group { Anchor: (Width: 12); }

                    Label #FilterLabel {
                        Text: "Filter";
                        Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, VerticalAlignment: Center);
                        Anchor: (Width: 50);
                    }

                    $C.@TextButton #RaceFilterButton {
                        Text: "RACE: ALL";
                        Anchor: (Height: 30);
                        Padding: (Horizontal: 12, Vertical: 1);
                        Style: @FilterCompactStyle;
                    }

                    Group { Anchor: (Width: 6); }

                    $C.@TextButton #ClassFilterButton {
                        Text: "CLASS: ALL";
                        Anchor: (Height: 30);
                        Padding: (Horizontal: 12, Vertical: 1);
                        Style: @FilterCompactStyle;
                    }

                    Group { Anchor: (Width: 12); }

                    $C.@TextButton #ViewToggleButton {
                        Text: "VIEW: PODIUM";
                        Anchor: (Height: 30);
                        Padding: (Horizontal: 12, Vertical: 1);
                        Style: @FilterCompactStyle;
                    }

                    Group { FlexWeight: 1; }

                    $C.@CancelTextButton #ResetFiltersButton {
                        Text: "RESET";
                        Anchor: (Width: 86, Height: 30);
                        Padding: (Horizontal: 2, Vertical: 1);
                    }
                }

                Group { Anchor: (Height: 4); }

                Label #LeaderboardsFilterSummary {
                    Text: "Showing all players.";
                    Style: (TextColor: #9ab6d4, FontSize: 11);
                    Padding: (Left: 2);
                }
            }

            Group { Anchor: (Height: 1); Padding: (Horizontal: 16); Group { Background: #2b3f58; } }

            // ================= CONTENT PANELS =================
            Group {
                LayoutMode: Left;
                FlexWeight: 1;
                Padding: (Top: 4);

                // ===== LEFT: PODIUM =====
                Group #PodiumSection {
                    Anchor: (Width: 370);
                    LayoutMode: Top;
                    Padding: (Left: 16, Right: 6, Top: 2, Bottom: 8);

                    Group {
                        LayoutMode: Top;
                        Background: (TexturePath: "../../Hud/ObjectivePanelContainer.png", Border: 15);
                        Padding: (Horizontal: 10, Top: 6, Bottom: 4);

                        Label #PodiumTitle {
                            Text: "TOP CHAMPIONS";
                            Style: (FontSize: 12, TextColor: #f0c040, RenderBold: true, LetterSpacing: 2, HorizontalAlignment: Center);
                            Anchor: (Height: 16);
                        }
                    }

                    Group { Anchor: (Height: 6); }

                    Group #PodiumCards {
                        LayoutMode: Top;
                    }
                }

                // ===== RIGHT: TABLE =====
                Group #TableSection {
                    FlexWeight: 1;
                    LayoutMode: Top;
                    Padding: (Left: 6, Right: 16, Top: 2, Bottom: 8);

                    Group #HeaderCard {
                        LayoutMode: Top;
                        Padding: (Horizontal: 12, Vertical: 6);

                        Group #Headers {
                            LayoutMode: Left;
                            Padding: (Vertical: 4);

                            Label #HeaderRank {
                                Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true);
                                Text: "Rank";
                                Anchor: (Width: 60);
                            }

                            Label #HeaderPlayer {
                                Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true);
                                Text: "Player";
                                FlexWeight: 1;
                            }

                            Label #HeaderRace {
                                Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true);
                                Text: "Race";
                                Anchor: (Width: 140);
                            }

                            Label #HeaderClass {
                                Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true);
                                Text: "Class";
                                Anchor: (Width: 140);
                            }

                            Label #HeaderPrestige {
                                Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true);
                                Text: "Prestige";
                                Anchor: (Width: 80);
                            }

                            Label #HeaderLevel {
                                Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true);
                                Text: "Level";
                                Anchor: (Width: 70);
                            }

                            Label #HeaderXp {
                                Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true);
                                Text: "XP";
                                Anchor: (Width: 100);
                            }
                        }

                        Group { Anchor: (Height: 1); Background: #2b3f58; }
                    }

                    Group #RowsContainer {
                        LayoutMode: Top;
                        FlexWeight: 1;
                        Background: #0b1520(0.85);
                        Padding: (Full: 8);

                        Group #Rows {
                            FlexWeight: 1;
                            LayoutMode: TopScrolling;
                            ScrollbarStyle: $C.@DefaultScrollbarStyle;

                            Group #RowCards {
                                LayoutMode: Top;
                            }
                        }
                    }
                }
            }
        }
    }
        }

        Group { Anchor: (Height: 14); }

        // ====================== FOOTER NAVBAR ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Height: 92);
                $Nav.@BottomNavBar {}
            }
        }
    }
}

$C.@BackButton {}
