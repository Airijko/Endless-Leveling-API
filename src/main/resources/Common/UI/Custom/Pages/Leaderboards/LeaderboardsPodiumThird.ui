$C = "../../Common.ui";

Group {
    Anchor: (Height: 135);
    LayoutMode: Top;
    Padding: (Bottom: 6);

    Group {
        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
        Background: (TexturePath: "../../Tiles/TileDefault2x.png", Border: 16, Color: #2b1a0f);
    }

    Group {
        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
        LayoutMode: Left;
        Padding: (Left: 10, Right: 12, Top: 8, Bottom: 8);

        Group {
            Anchor: (Width: 62);
            LayoutMode: Top;
            Padding: (Top: 6);

            Label #Rank {
                Style: (FontSize: 16, TextColor: #d89b64, RenderBold: true, HorizontalAlignment: Center);
                Anchor: (Height: 20);
                Text: "3RD";
            }

            Group { Anchor: (Height: 4); }

            Group {
                LayoutMode: Middle;
                Anchor: (Height: 42);

                Group {
                    Anchor: (Width: 42, Height: 42);
                    Background: (TexturePath: "../../Tiles/TileBorderCommon.png");
                    LayoutMode: Middle;
                    Padding: (Full: 4);

                    ItemIcon #PodiumIcon {
                        Anchor: (Width: 30, Height: 30);
                    }
                }
            }
        }

        Group {
            Anchor: (Width: 1);
            Padding: (Vertical: 8);
            Group { Background: #d89b64(0.20); }
        }

        Group { Anchor: (Width: 10); }

        Group {
            FlexWeight: 1;
            LayoutMode: Top;
            Padding: (Top: 2);

            Label #Name {
                Style: (FontSize: 13, TextColor: #d89b64, RenderBold: true);
                Anchor: (Height: 17);
                Text: "-";
            }

            Group { Anchor: (Height: 2); }
            Group { Anchor: (Height: 1); Group { Background: #d89b64(0.15); } }
            Group { Anchor: (Height: 4); }

            Group {
                LayoutMode: Top;

                Group {
                    LayoutMode: Left;
                    Padding: (Vertical: 2);
                    Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                    Label { Style: (FontSize: 10, TextColor: #ddb189); Text: "Race"; FlexWeight: 1; Padding: (Left: 6); }
                    Label #Race { Style: (FontSize: 10, TextColor: #d89b64, RenderBold: true); Text: "-"; Padding: (Right: 6); }
                }

                Group {
                    LayoutMode: Left;
                    Padding: (Vertical: 2);
                    Label { Style: (FontSize: 10, TextColor: #e6c5a8); Text: "Class"; FlexWeight: 1; Padding: (Left: 6); }
                    Label #Class { Style: (FontSize: 10, TextColor: #d89b64, RenderBold: true); Text: "-"; Padding: (Right: 6); }
                }

                Group {
                    LayoutMode: Left;
                    Padding: (Vertical: 2);
                    Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                    Label { Style: (FontSize: 10, TextColor: #ddb189); Text: "Prestige"; FlexWeight: 1; Padding: (Left: 6); }
                    Label #Prestige { Style: (FontSize: 10, TextColor: #f2c79e, RenderBold: true); Text: "-"; Padding: (Right: 6); }
                }

                Group {
                    LayoutMode: Left;
                    Padding: (Vertical: 2);
                    Label { Style: (FontSize: 10, TextColor: #e6c5a8); Text: "Level"; FlexWeight: 1; Padding: (Left: 6); }
                    Label #Level { Style: (FontSize: 10, TextColor: #e4c7ad, RenderBold: true); Text: "-"; Padding: (Right: 6); }
                }

                Group {
                    LayoutMode: Left;
                    Padding: (Vertical: 2);
                    Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                    Label { Style: (FontSize: 10, TextColor: #ddb189); Text: "XP"; FlexWeight: 1; Padding: (Left: 6); }
                    Label #Exp { Style: (FontSize: 10, TextColor: #dfbe9f, RenderBold: true); Text: "-"; Padding: (Right: 6); }
                }
            }
        }
    }
}
