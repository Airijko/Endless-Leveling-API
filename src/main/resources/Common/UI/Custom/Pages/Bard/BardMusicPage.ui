$C = "../../Common.ui";

@CustomStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;

        Group {
            Anchor: (Width: 720, Height: 580);
            Background: (TexturePath: "Images/ObjectivePanelContainer.png", Border: 15);
            LayoutMode: Top;
            Padding: (Full: 16);

            // ---- Title ----
            Label {
                Text: "BARD MUSIC";
                Anchor: (Height: 26);
                Style: (FontSize: 16, TextColor: #f0c040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 1); Background: #7a5a10; }
            Group { Anchor: (Height: 4); }

            Label {
                Text: "Songs to soothe allies and inspire greatness.";
                Anchor: (Height: 16);
                Style: (FontSize: 11, TextColor: #e8e8b0, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 12); }

            // ===== NOW PLAYING CARD =====
            Group {
                LayoutMode: Top;
                Background: #0b141f(0.88);
                Padding: (Full: 14);

                Group {
                    Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                    Background: #f0c040;
                }

                Group {
                    LayoutMode: Top;
                    Padding: (Left: 12);

                    Label {
                        Text: "NOW PLAYING";
                        Style: (FontSize: 10, TextColor: #f0c040, RenderBold: true, LetterSpacing: 2);
                        Anchor: (Height: 14);
                    }

                    Group { Anchor: (Height: 1); Background: #ffffff(0.07); }
                    Group { Anchor: (Height: 6); }

                    Label #NowPlayingLabel {
                        Text: "Nothing playing";
                        Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true);
                        Anchor: (Height: 22);
                    }

                    Group { Anchor: (Height: 2); }

                    Label #NowPlayingStatusLabel {
                        Text: "Idle";
                        Style: (FontSize: 11, TextColor: #7a9abf);
                        Anchor: (Height: 16);
                    }
                }
            }

            Group { Anchor: (Height: 10); }

            // ===== SONG LIBRARY =====
            Group {
                LayoutMode: Top;
                Background: #0b141f(0.88);
                Padding: (Full: 14);
                FlexWeight: 1;

                Group {
                    Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                    Background: #f2a2e8;
                }

                Group {
                    LayoutMode: Top;
                    Padding: (Left: 12);
                    FlexWeight: 1;

                    Label {
                        Text: "SONG LIBRARY";
                        Style: (FontSize: 10, TextColor: #f2a2e8, RenderBold: true, LetterSpacing: 2);
                        Anchor: (Height: 14);
                    }

                    Group { Anchor: (Height: 1); Background: #ffffff(0.07); }
                    Group { Anchor: (Height: 6); }

                    Group {
                        FlexWeight: 1;
                        LayoutMode: TopScrolling;
                        ScrollbarStyle: $C.@DefaultScrollbarStyle;
                        Background: #040c17(0.85);
                        Padding: (Full: 6);

                        Group #SongRows {
                            LayoutMode: Top;
                        }
                    }
                }
            }
        }
    }
}
