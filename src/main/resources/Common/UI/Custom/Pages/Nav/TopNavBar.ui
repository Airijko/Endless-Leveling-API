// =============================================================
// Footer secondary navbar (Support / Settings)
// =============================================================
@BottomNavBar = Group {
    LayoutMode: Top;
    Anchor: (Height: @TopNavBarHeight);
    Padding: (Vertical: 8);

    Group {
        LayoutMode: Center;

        Group {
            LayoutMode: Left;

            // ---- SUPPORT ----
            Group {
                Anchor: (MinWidth: @TopNavButtonWidth, Height: @TopNavButtonHeight);
                Background: PatchStyle(TexturePath: "../../Common/ColorPickerButton.png", Border: 14, Color: @NavButtonBorderColor);

                Group {
                    Anchor: (Left: @NavButtonBorderInset, Right: @NavButtonBorderInset, Top: @NavButtonBorderInset, Bottom: @NavButtonBorderInset);
                    Background: PatchStyle(TexturePath: "../../Common/ColorPickerFill.png", Border: 14, Color: @NavButtonFillColor);

                    Button #NavSupport {
                        Anchor: (Top: 0, Bottom: 0);
                        Style: @TopNavButtonStyle;

                        Group {
                            LayoutMode: Left;
                            Padding: (Horizontal: 14);

                            Group {
                                Anchor: (Width: 52, Height: 52);
                                LayoutMode: Middle;
                                Group #NavSupportIcon {
                                    Anchor: (Width: @TopNavIconSize, Height: @TopNavIconSize);
                                    Background: (TexturePath: "Icons/NavSupportIcon.png");
                                }
                            }

                            Group { Anchor: (Width: 8); }

                            Group {
                                LayoutMode: Middle;
                                Padding: (Right: 6);
                                Label #NavSupportLabel {
                                    Text: "SUPPORT";
                                    Style: @TopNavLabelDefault;
                                }
                            }
                        }
                    }
                }
            }

            Group { Anchor: (Width: @TopNavButtonGap); }

            // ---- SETTINGS ----
            Group {
                Anchor: (MinWidth: @TopNavButtonWidth, Height: @TopNavButtonHeight);
                Background: PatchStyle(TexturePath: "../../Common/ColorPickerButton.png", Border: 14, Color: @NavButtonBorderColor);

                Group {
                    Anchor: (Left: @NavButtonBorderInset, Right: @NavButtonBorderInset, Top: @NavButtonBorderInset, Bottom: @NavButtonBorderInset);
                    Background: PatchStyle(TexturePath: "../../Common/ColorPickerFill.png", Border: 14, Color: @NavButtonFillColor);

                    Button #NavSettings {
                        Anchor: (Top: 0, Bottom: 0);
                        Style: @TopNavButtonStyle;

                        Group {
                            LayoutMode: Left;
                            Padding: (Horizontal: 14);

                            Group {
                                Anchor: (Width: 52, Height: 52);
                                LayoutMode: Middle;
                                Group #NavSettingsIcon {
                                    Anchor: (Width: @TopNavIconSize, Height: @TopNavIconSize);
                                    Background: (TexturePath: "Icons/NavSettingsIcon.png");
                                }
                            }

                            Group { Anchor: (Width: 8); }

                            Group {
                                LayoutMode: Middle;
                                Padding: (Right: 6);
                                Label #NavSettingsLabel {
                                    Text: "SETTINGS";
                                    Style: @TopNavLabelDefault;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
};
