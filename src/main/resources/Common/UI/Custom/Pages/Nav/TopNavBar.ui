                        Group {
                            LayoutMode: Left;
                            Padding: (Horizontal: 14);

                            Group {
                                Anchor: (Width: 52, Height: 52);
                                LayoutMode: Middle;
                                Group #NavClassesIcon {
                                    Anchor: (Width: @TopNavIconSize, Height: @TopNavIconSize);
                                    Background: (TexturePath: "Icons/NavClassesIcon.png");
                                }
                            }

                            Group { Anchor: (Width: 8); }

                            Group {
                                LayoutMode: Middle;
                                Padding: (Right: 6);
                                Label #NavClassesLabel {
                                    Text: "CLASSES";
                                    Style: @TopNavLabelDefault;
                                }
                            }
                        }
                    }
                }
            }

            Group { Anchor: (Width: @TopNavButtonGap); }

            // ---- GATES ----
            Group {
                Anchor: (MinWidth: @TopNavButtonWidth, Height: @TopNavButtonHeight);
                Background: PatchStyle(TexturePath: "../../Common/ColorPickerButton.png", Border: 14, Color: @NavButtonBorderColor);

                Group {
                    Anchor: (Left: @NavButtonBorderInset, Right: @NavButtonBorderInset, Top: @NavButtonBorderInset, Bottom: @NavButtonBorderInset);
                    Background: PatchStyle(TexturePath: "../../Common/ColorPickerFill.png", Border: 14, Color: @NavButtonFillColor);

                    Button #NavGates {
                        Anchor: (Top: 0, Bottom: 0);
                        Style: @TopNavButtonStyle;

                        Group {
                            LayoutMode: Left;
                            Padding: (Horizontal: 14);

                            Group {
                                Anchor: (Width: 52, Height: 52);
                                LayoutMode: Middle;
                                Group #NavGatesIcon {
                                    Anchor: (Width: @TopNavIconSize, Height: @TopNavIconSize);
                                    Background: (TexturePath: "Icons/NavGatesIcon.png");
                                }
                            }

                            Group { Anchor: (Width: 8); }

                            Group {
                                LayoutMode: Middle;
                                Padding: (Right: 6);
                                Label #NavGatesLabel {
                                    Text: "GATES";
                                    Style: @TopNavLabelDefault;
                                }
                            }
                        }
                    }
                }
            }

            Group { Anchor: (Width: @TopNavButtonGap); }

            // ---- DUNGEONS ----
            Group {
                Anchor: (MinWidth: @TopNavButtonWidth, Height: @TopNavButtonHeight);
                Background: PatchStyle(TexturePath: "../../Common/ColorPickerButton.png", Border: 14, Color: @NavButtonBorderColor);

                Group {
                    Anchor: (Left: @NavButtonBorderInset, Right: @NavButtonBorderInset, Top: @NavButtonBorderInset, Bottom: @NavButtonBorderInset);
                    Background: PatchStyle(TexturePath: "../../Common/ColorPickerFill.png", Border: 14, Color: @NavButtonFillColor);

                    Button #NavDungeons {
                        Anchor: (Top: 0, Bottom: 0);
                        Style: @TopNavButtonStyle;

                        Group {
                            LayoutMode: Left;
                            Padding: (Horizontal: 14);

                            Group {
                                Anchor: (Width: 52, Height: 52);
                                LayoutMode: Middle;
                                Group #NavDungeonsIcon {
                                    Anchor: (Width: @TopNavIconSize, Height: @TopNavIconSize);
                                    Background: (TexturePath: "Icons/NavDungeonsIcon.png");
                                }
                            }

                            Group { Anchor: (Width: 8); }

                            Group {
                                LayoutMode: Middle;
                                Padding: (Right: 6);
                                Label #NavDungeonsLabel {
                                    Text: "DUNGEONS";
                                    Style: @TopNavLabelDefault;
                                }
                            }
                        }
                    }
                }
            }

            Group { Anchor: (Width: @TopNavButtonGap); }

            // ---- ADDONS ----
            Group {
                Anchor: (MinWidth: @TopNavButtonWidth, Height: @TopNavButtonHeight);
                Background: PatchStyle(TexturePath: "../../Common/ColorPickerButton.png", Border: 14, Color: @NavButtonBorderColor);

                Group {
                    Anchor: (Left: @NavButtonBorderInset, Right: @NavButtonBorderInset, Top: @NavButtonBorderInset, Bottom: @NavButtonBorderInset);
                    Background: PatchStyle(TexturePath: "../../Common/ColorPickerFill.png", Border: 14, Color: @NavButtonFillColor);

                    Button #NavAddons {
                        Anchor: (Top: 0, Bottom: 0);
                        Style: @TopNavButtonStyle;

                        Group {
                            LayoutMode: Left;
                            Padding: (Horizontal: 14);

                            Group {
                                Anchor: (Width: 52, Height: 52);
                                LayoutMode: Middle;
                                Group #NavAddonsIcon {
                                    Anchor: (Width: @TopNavIconSize, Height: @TopNavIconSize);
                                    Background: (TexturePath: "Icons/NavAddonsIcon.png");
                                }
                            }

                            Group { Anchor: (Width: 8); }

