$C = "../../Common.ui";
$Nav = "../Nav/TopNavBar.ui";

@CustomStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;
        Padding: (Vertical: 12);

        // ====================== TOP NAVBAR ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Height: 92);
                $Nav.@TopNavBar {}
            }
        }

        Group { Anchor: (Height: 14); }

        // ====================== MAIN CONTENT ======================
        Group {
            LayoutMode: Middle;

            Group {
                LayoutMode: Left;
                Anchor: (Width: 1680, Height: 700);

                Group {
                    LayoutMode: Top;
                    Anchor: (Width: 1680, Height: 700);

                    // ========================================================
                    //  CAROUSEL VIEW
                    // ========================================================
                    Group #CarouselView {
                        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                        LayoutMode: Top;
                        Visible: true;

                        // ---- Header (centered, ObjectiveContainer bg) ----
                        Group {
                            LayoutMode: Center;

                            Group {
                                Background: (TexturePath: "../../Hud/ObjectivePanelContainer.png", Border: 15);
                                LayoutMode: Top;
                                Padding: (Horizontal: 24, Vertical: 12);

                                // Line 1: title + class count
                                Group {
                                    LayoutMode: Left;
                                    Anchor: (Height: 18);

                                    Label #ClassTitle {
                                        Text: "ENDLESS LEVELING";
                                        Style: (FontSize: 14, TextColor: #f0c040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                                    }

                                    Group { Anchor: (Width: 10); }

                                    Label #CarouselClassCount {
                                        Text: "0 classes";
                                        Style: (FontSize: 11, TextColor: #9fb6d3, RenderBold: true, VerticalAlignment: Center);
                                    }
                                }

                                // Line 2: primary + secondary + cooldown
                                Group {
                                    LayoutMode: Left;
                                    Anchor: (Height: 16);

                                    Label #CarouselPrimaryBadge {
                                        Text: "Primary:";
                                        Style: (FontSize: 11, TextColor: #4fd7f7, RenderBold: true, VerticalAlignment: Center);
                                    }

                                    Group { Anchor: (Width: 4); }

                                    Label #CarouselPrimaryClass {
                                        Text: "--";
                                        Style: (FontSize: 11, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                                    }

                                    Group { Anchor: (Width: 12); }

                                    Label #CarouselSecondaryBadge {
                                        Text: "Secondary:";
                                        Style: (FontSize: 10, TextColor: #d4b5ff, RenderBold: true, VerticalAlignment: Center);
                                    }

                                    Group { Anchor: (Width: 4); }

                                    Label #CarouselSecondaryClass {
                                        Text: "--";
                                        Style: (FontSize: 10, TextColor: #ffffff, VerticalAlignment: Center);
                                    }
                                }

                                // Line 3: subtitle
                                Label #CarouselSubheading {
                                    Text: "Select a class to view details.";
                                    Style: (FontSize: 10, TextColor: #8aa1bf, HorizontalAlignment: Center);
                                    Anchor: (Height: 14);
                                }
                            }
                        }

                        Group { Anchor: (Height: 12); }

                        // ---- Card scroll area ----
                        Group #CarouselScrollArea {
                            FlexWeight: 1;
                            LayoutMode: LeftScrolling;
                            ScrollbarStyle: $C.@DefaultScrollbarStyle;
                            Padding: (Left: 24, Right: 24, Top: 6, Bottom: 20);

                            Group #CarouselCards {
                                LayoutMode: Left;
                            }
                        }
                    }

                    // ========================================================
                    //  DETAIL VIEW (shown when a carousel card is clicked)
                    // ========================================================
                    Group #DetailView {
                        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                        LayoutMode: Top;
                        Visible: false;

                        Group {
                            LayoutMode: Middle;

                            Group {
                                Anchor: (Width: 1500);
                                LayoutMode: Top;

                                // ============ HEADER ============
                                Group {
                                    LayoutMode: Left;
                                    Background: (TexturePath: "../../Hud/ObjectivePanelContainer.png", Border: 15);
                                    Padding: (Left: 20, Right: 20, Top: 16, Bottom: 16);

                                    // Class icon with tile border
                                    Group {
                                        LayoutMode: Middle;
                                        Anchor: (Width: 80);

                                        Group {
                                            Anchor: (Width: 74, Height: 74);

                                            Group {
                                                Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                                                Background: (TexturePath: "../../Tiles/TileBorderCommon.png");
                                            }

                                            Group {
                                                Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                                                LayoutMode: Middle;
                                                ItemIcon #DetailClassIcon {
                                                    Anchor: (Width: 52, Height: 52);
                                                }
                                            }
                                        }
                                    }

                                    Group { Anchor: (Width: 18); }

                                    // Name + subtitle + role + lore
                                    Group {
                                        LayoutMode: Top;
                                        FlexWeight: 1;

                                        Label #SelectedClassLabel {
                                            Text: "Select a Class";
                                            Style: (FontSize: 24, TextColor: #f0c040, RenderBold: true);
                                            Anchor: (Height: 28);
                                        }

                                        Group {
                                            LayoutMode: Left;
                                            Anchor: (Height: 16);

                                            Label #SelectedClassSubtitle {
                                                Text: "Preview role and passives.";
                                                Style: (FontSize: 12, TextColor: #8aa1bf);
                                            }

                                            Group { Anchor: (Width: 12); }

                                            Label #ClassRoleValue {
                                                Text: "Role: --";
                                                Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true);
                                            }
                                        }

                                        Group { Anchor: (Height: 4); }

                                        Label #ClassLoreText {
                                            Text: "Dive into the fantasy and goals of this class.";
                                            Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true);
                                            Anchor: (Height: 34);
                                        }
                                    }

                                    Group { Anchor: (Width: 24); }

                                    // Status info (right side)
                                    Group {
                                        LayoutMode: Top;
                                        Anchor: (Width: 260);

                                        Group {
                                            Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                                            Background: (TexturePath: "../../Tiles/TileDefault2x.png", Border: 16, Color: #1a2538);
                                        }

                                        Group {
                                            Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                                            LayoutMode: Top;
                                            Padding: (Full: 12);

                                            Label #ClassAssignmentsTitle {
                                                Text: "Class Assignments";
                                                Style: (FontSize: 10, TextColor: #f0c040, RenderBold: true, RenderUppercase: true, LetterSpacing: 1);
                                                Anchor: (Height: 14);
                                            }

                                            Group { Anchor: (Height: 4); }

                                            Group {
                                                LayoutMode: Left;
                                                Anchor: (Height: 18);
                                                Label #ClassPrimaryStatusLabel {
                                                    Text: "Primary";
                                                    Style: (FontSize: 11, TextColor: #6fe3ff, RenderBold: true);
                                                }
                                                Group { Anchor: (Width: 6); }
                                                Label #CurrentPrimaryValue {
                                                    Text: "--";
                                                    Style: (FontSize: 12, TextColor: #ffffff, RenderBold: true);
                                                    FlexWeight: 1;
                                                }
                                            }

                                            Group {
                                                LayoutMode: Left;
                                                Anchor: (Height: 18);
                                                Label #ClassSecondaryStatusLabel {
                                                    Text: "Secondary";
                                                    Style: (FontSize: 11, TextColor: #d4b5ff, RenderBold: true);
                                                }
                                                Group { Anchor: (Width: 6); }
                                                Label #CurrentSecondaryValue {
                                                    Text: "None";
                                                    Style: (FontSize: 12, TextColor: #ffffff, RenderBold: true);
                                                    FlexWeight: 1;
                                                }
                                            }

                                            Group { Anchor: (Height: 2); }
                                            Group { Anchor: (Height: 1); Background: #ffffff(0.06); }
                                            Group { Anchor: (Height: 2); }

                                            Group {
                                                LayoutMode: Left;
                                                Anchor: (Height: 16);
                                                Label #ClassSwapCooldownCardTitle {
                                                    Text: "Cooldown";
                                                    Style: (FontSize: 10, TextColor: #8aa1bf, LetterSpacing: 1);
                                                }
                                                Group { FlexWeight: 1; }
                                                Label #ClassPrimaryCooldownLabel {
                                                    Text: "Pri:";
                                                    Style: (FontSize: 10, TextColor: #6fe3ff);
                                                }
                                                Group { Anchor: (Width: 2); }
                                                Label #ClassPrimaryCooldownValue {
                                                    Text: "--";
                                                    Style: (FontSize: 10, TextColor: #ffffff, RenderBold: true);
                                                }
                                                Group { Anchor: (Width: 8); }
                                                Label #ClassSecondaryCooldownLabel {
                                                    Text: "Sec:";
                                                    Style: (FontSize: 10, TextColor: #d4b5ff);
                                                }
                                                Group { Anchor: (Width: 2); }
                                                Label #ClassSecondaryCooldownValue {
                                                    Text: "--";
                                                    Style: (FontSize: 10, TextColor: #ffffff, RenderBold: true);
                                                }
                                            }
                                        }

                                        // Hidden labels (still referenced by Java)
                                        Label #ClassesTitleLabel { Text: ""; Anchor: (Height: 0); Visible: false; }
                                        Label #ClassSecondaryShareHint { Text: ""; Anchor: (Height: 0); Visible: false; }
                                        Label #ClassSwapCooldownHint { Text: ""; Anchor: (Height: 0); Visible: false; }
                                        Label #ClassSorceryLabel { Text: ""; Anchor: (Height: 0); Visible: false; }
                                        Label #ClassSorceryValue { Text: ""; Anchor: (Height: 0); Visible: false; }
                                        Label #ClassLoreTitle { Text: ""; Anchor: (Height: 0); Visible: false; }
                                        Label #ClassesInfoPanel { Text: ""; Anchor: (Height: 0); Visible: false; }
                                        Label #ClassCountLabel { Text: ""; Anchor: (Height: 0); Visible: false; }
                                        Label #ClassListTitle { Text: ""; Anchor: (Height: 0); Visible: false; }
                                    }
                                }

                                Group { Anchor: (Height: 10); }

                                // ============ THREE-COLUMN BODY ============
                                Group {
                                    LayoutMode: Left;
                                    FlexWeight: 1;

                                    // ---- Column 1: Weapons + Innates ----
                                    $Nav.@ObjectiveContainer {
                                        Anchor: (Width: 420);

                                        #Title {
                                            Label #ClassWeaponsTitle {
                                                Text: "Weapon Affinities";
                                                Style: $Nav.@PanelTitleStyle;
                                            }
                                        }

                                        #Content {
                                            LayoutMode: Top;
                                            Padding: (Horizontal: 12, Top: 6, Bottom: 8);

                                            Label #ClassWeaponSummary {
                                                Text: "No weapon bonuses defined.";
                                                Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true);
                                                Anchor: (Height: 18);
                                            }

                                            Group #ClassWeaponEntries {
                                                LayoutMode: Top;
                                            }

                                            Group { Anchor: (Height: 12); }

                                            // Innate section within same column
                                            Label #ClassInnateTitle {
                                                Text: "Innate Gains";
                                                Style: (FontSize: 13, TextColor: #f0c040, RenderBold: true, LetterSpacing: 1);
                                                Anchor: (Height: 18);
                                            }

                                            Group { Anchor: (Height: 1); Background: #ffffff(0.06); }
                                            Group { Anchor: (Height: 4); }

                                            Label #ClassInnateSummary {
                                                Text: "No innate attribute bonuses.";
                                                Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true);
                                                Anchor: (Height: 18);
                                            }

                                            Group #ClassInnateScrollArea {
                                                FlexWeight: 1;
                                                LayoutMode: TopScrolling;
                                                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                                Group #ClassInnateEntries {
                                                    LayoutMode: Top;
                                                }
                                            }
                                        }
                                    }

                                    Group { Anchor: (Width: 10); }

                                    // ---- Column 2: Passives ----
                                    $Nav.@ObjectiveContainer {
                                        Anchor: (Width: 420);

                                        #Title {
                                            Label #ClassPassivesTitle {
                                                Text: "Passives";
                                                Style: $Nav.@PanelTitleStyle;
                                            }
                                        }

                                        #Content {
                                            LayoutMode: Top;
                                            Padding: (Horizontal: 12, Top: 6, Bottom: 8);

                                            Label #ClassPassiveSummary {
                                                Text: "Inspect a class to preview its passive bonuses.";
                                                Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true);
                                                Anchor: (Height: 18);
                                            }

                                            Group #ClassPassiveScrollArea {
                                                FlexWeight: 1;
                                                LayoutMode: TopScrolling;
                                                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                                Group #ClassPassiveEntries {
                                                    LayoutMode: Top;
                                                }
                                            }
                                        }
                                    }

                                    Group { Anchor: (Width: 10); }

                                    // ---- Column 3: Class Paths ----
                                    $Nav.@ObjectiveContainer {
                                        FlexWeight: 1;

                                        #Title {
                                            Label #ClassEvolutionTitle {
                                                Text: "Class Paths";
                                                Style: $Nav.@PanelTitleStyle;
                                            }
                                        }

                                        #Content {
                                            LayoutMode: Top;
                                            Padding: (Horizontal: 12, Top: 6, Bottom: 8);

                                            Label #ClassEvolutionSummary {
                                                Text: "Select a class to inspect ascension branches.";
                                                Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true);
                                                Anchor: (Height: 32);
                                            }

                                            Group { Anchor: (Height: 4); }

                                            Group #ClassEvolutionScrollArea {
                                                FlexWeight: 1;
                                                LayoutMode: TopScrolling;
                                                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                                Group #ClassEvolutionEntries {
                                                    LayoutMode: Top;
                                                }
                                            }
                                        }
                                    }
                                }

                                Group { Anchor: (Height: 8); }

                                // ============ ACTION BAR ============
                                Group {
                                    LayoutMode: Left;
                                    Background: (TexturePath: "../../Hud/ObjectivePanelContainer.png", Border: 15);
                                    Padding: (Left: 18, Right: 18, Top: 12, Bottom: 12);

                                    $C.@TextButton #BackToCarouselButton {
                                        Text: "BACK";
                                        Anchor: (Height: 34, Width: 130);
                                        Style: @CustomStyle;
                                    }

                                    Group { Anchor: (Width: 8); }

                                    $C.@TextButton #ViewClassPathsButton {
                                        Text: "VIEW PATHS";
                                        Anchor: (Height: 34, Width: 150);
                                        Style: @CustomStyle;
                                    }

                                    Group { FlexWeight: 1; }

                                    Label #ClassDetailStatus {
                                        Text: "Changes apply instantly.";
                                        Style: (FontSize: 11, TextColor: #ffc300, RenderBold: true, VerticalAlignment: Center);
                                    }

                                    Group { FlexWeight: 1; }

                                    $C.@TextButton #ConfirmPrimaryButton {
                                        Text: "SET PRIMARY";
                                        Anchor: (Height: 34, Width: 160);
                                        Style: @CustomStyle;
                                    }

                                    Group { Anchor: (Width: 8); }

                                    $C.@TextButton #ConfirmSecondaryButton {
                                        Text: "SET SECONDARY";
                                        Anchor: (Height: 34, Width: 170);
                                        Style: @CustomStyle;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Group { Anchor: (Height: 14); }

        // ====================== FOOTER NAVBAR ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Height: 92);
                $Nav.@BottomNavBar {}
            }
        }
    }
}

$C.@BackButton {}
