Group {
    LayoutMode: Left;
    Anchor: (Height: 24);
    Background: #0f1824(0.8);
    Padding: (Left: 10, Right: 10, Top: 3, Bottom: 3);

    Label #WeaponName {
        Text: "Weapon";
        Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true);
        Anchor: (Height: 16);
    }

    Group { FlexWeight: 1; }

    Label #WeaponMultiplier {
        Text: "+0% dmg";
        Style: (FontSize: 12, TextColor: #6fe3ff, RenderBold: true);
        Anchor: (Height: 16);
    }
}
