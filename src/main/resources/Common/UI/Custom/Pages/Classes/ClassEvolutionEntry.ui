Group {
    LayoutMode: Top;
    Anchor: (Bottom: 6);

    Group {
        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
        Background: (TexturePath: "../../Tiles/TileDefault2x.png", Border: 16, Color: #1a2538);
    }

    Group {
        LayoutMode: Top;
        Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);

        Group {
            LayoutMode: Left;
            Anchor: (Bottom: 2);

            Label #EvolutionName {
                Style: (FontSize: 12, TextColor: #e5c68a, RenderBold: true);
                Text: "Class Path";
                Anchor: (Height: 16);
            }

            Group { FlexWeight: 1; }

            Label #EvolutionStatus {
                Style: (FontSize: 12, TextColor: #ffc300, RenderBold: true);
                Text: "LOCKED";
                Anchor: (Height: 16);
            }
        }

        Label #EvolutionMeta {
            Style: (FontSize: 11, TextColor: #9fb6d3, Wrap: true);
            Text: "Type: Damage | Stage: Tier 1";
            Padding: (Bottom: 2);
        }

        Label #EvolutionCriteria {
            Style: (FontSize: 11, TextColor: #d7e3f2, Wrap: true);
            Text: "Requirements: Prestige >= 2";
            Padding: (Bottom: 1);
        }

        Label #EvolutionSkillCriteria {
            Style: (FontSize: 11, TextColor: #9be3ff, Wrap: true);
            Text: "";
            Visible: false;
            Padding: (Bottom: 2);
        }

        Label #EvolutionProgress {
            Style: (FontSize: 11, TextColor: #ffc300, Wrap: true);
            Text: "Missing: Requires prestige 2.";
        }
    }
}
