Group {
    Anchor: (Width: 250, Height: 312, Right: 12);
    LayoutMode: Top;
    Background: #0b141f(0.92);
    Padding: (Full: 14);

    Group {
        Anchor: (Height: 118, Bottom: 14);
        Background: #18354b;
        Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);

        Label {
            Text: "DUNGEON GATES";
            Anchor: (Height: 16);
            Style: (FontSize: 10, TextColor: #e6eff9, RenderBold: true, LetterSpacing: 1);
        }

        Label {
            Text: "EL Addon";
            Anchor: (Bottom: 4, Height: 40);
            Style: (FontSize: 20, TextColor: #ffffff, RenderBold: true, Wrap: true);
        }
    }

    Label {
        Text: "EndlessDungeonsAndGates";
        Anchor: (Height: 24, Bottom: 6);
        Style: (FontSize: 17, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
    }

    Label {
        Text: "v2.2.0";
        Anchor: (Height: 18, Bottom: 8);
        Style: (FontSize: 11, TextColor: #89c4ff, RenderBold: true, VerticalAlignment: Center);
    }

    Label {
        Text: "The integration layer that bridges Endless Leveling with external dungeon content, registers instance dungeons, and manages gate runtime routing.";
        FlexWeight: 1;
        Style: (FontSize: 12, TextColor: #bdd0e8, Wrap: true);
    }

    Group { Anchor: (Height: 10); }

    Group {
        Anchor: (Height: 1);
        Background: #ffffff(0.08);
    }

    Group { Anchor: (Height: 10); }

    Label {
        Text: "Optional deps: MajorDungeons, Endgame&QoL";
        Anchor: (Height: 18);
        Style: (FontSize: 11, TextColor: #7d91a8);
    }
}