Button #RoguetaleAddonCard {
    Anchor: (Width: 250, Height: 312, Right: 12);
    LayoutMode: Top;
    Background: #0b141f(0.92);
    Padding: (Full: 14);

    Group {
        Anchor: (Height: 118, Bottom: 14);
        Background: #2d1f3f;
        Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);

        Label {
            Text: "COMMUNITY ADDON";
            Anchor: (Height: 16);
            Style: (FontSize: 10, TextColor: #e6eff9, RenderBold: true, LetterSpacing: 1);
        }

        Label {
            Text: "Roguetale";
            Anchor: (Bottom: 4, Height: 40);
            Style: (FontSize: 20, TextColor: #ffffff, RenderBold: true, Wrap: true);
        }
    }

    Label {
        Text: "By Zbeve";
        Anchor: (Height: 18, Bottom: 8);
        Style: (FontSize: 11, TextColor: #c79bff, RenderBold: true, VerticalAlignment: Center);
    }

    Label {
        Text: "A roguelike-inspired community addon that layers run-based progression mechanics on top of Endless Leveling.";
        FlexWeight: 1;
        Style: (FontSize: 12, TextColor: #bdd0e8, Wrap: true);
    }
}
