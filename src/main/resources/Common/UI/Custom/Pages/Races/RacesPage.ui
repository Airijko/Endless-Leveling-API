$C = "../../Common.ui";
$Nav = "../Nav/TopNavBar.ui";

@CustomStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;
        Padding: (Vertical: 12);

        // ====================== TOP NAVBAR ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Height: 92);
                $Nav.@TopNavBar {}
            }
        }

        Group { Anchor: (Height: 14); }

        // ====================== MAIN CONTENT ======================
        Group {
            LayoutMode: Middle;

            Group {
                LayoutMode: Left;
                Anchor: (Width: 1680, Height: 700);

                Group {
                    LayoutMode: Top;
                    Anchor: (Width: 1680, Height: 700);

                    // ========================================================
                    //  CAROUSEL VIEW
                    // ========================================================
                    Group #CarouselView {
                        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                        LayoutMode: Top;
                        Visible: true;

                        Group {
                            LayoutMode: Center;

                            Group {
                                Background: (TexturePath: "../../Hud/ObjectivePanelContainer.png", Border: 15);
                                LayoutMode: Top;
                                Padding: (Horizontal: 24, Vertical: 12);

                                // Line 1: title + race count
                                Group {
                                    LayoutMode: Left;
                                    Anchor: (Height: 18);

                                    Label #RacesTitle {
                                        Text: "ENDLESS LEVELING";
                                        Style: (FontSize: 14, TextColor: #f0c040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                                    }

                                    Group { Anchor: (Width: 10); }

                                    Label #CarouselRaceCount {
                                        Text: "12 races";
                                        Style: (FontSize: 11, TextColor: #9fb6d3, RenderBold: true, VerticalAlignment: Center);
                                    }
                                }

                                // Line 2: active race + cooldown
                                Group {
                                    LayoutMode: Left;
                                    Anchor: (Height: 16);

                                    Label #CarouselCurrentBadge {
                                        Text: "Active:";
                                        Style: (FontSize: 11, TextColor: #4fd7f7, RenderBold: true, VerticalAlignment: Center);
                                    }

                                    Group { Anchor: (Width: 4); }

                                    Label #CarouselCurrentRace {
                                        Text: "--";
                                        Style: (FontSize: 11, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                                    }

                                    Group { Anchor: (Width: 12); }

                                    Label #CarouselCooldownLabel {
                                        Text: "Cooldown:";
                                        Style: (FontSize: 10, TextColor: #6a8099, VerticalAlignment: Center);
                                    }

                                    Group { Anchor: (Width: 4); }

                                    Label #CarouselCooldownValue {
                                        Text: "Ready";
                                        Style: (FontSize: 10, TextColor: #6fe3ff, RenderBold: true, VerticalAlignment: Center);
                                    }
                                }

                                // Line 3: subtitle
                                Label #CarouselSubheading {
                                    Text: "Select a race to view details.";
                                    Style: (FontSize: 10, TextColor: #8aa1bf, HorizontalAlignment: Center);
                                    Anchor: (Height: 14);
                                }
                            }
                        }

                        Group { Anchor: (Height: 12); }

                        // ---- Card scroll area ----
                        Group #CarouselScrollArea {
                            FlexWeight: 1;
                            LayoutMode: LeftScrolling;
                            ScrollbarStyle: $C.@DefaultScrollbarStyle;
                            Padding: (Left: 24, Right: 24, Top: 6, Bottom: 20);

                            Group #CarouselCards {
                                LayoutMode: Left;
                            }
                        }
                    }

                    // ========================================================
                    //  DETAIL VIEW (shown when a carousel card is clicked)
                    // ========================================================
                    Group #DetailView {
                        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                        LayoutMode: Top;
                        Visible: false;

                        Group {
                            LayoutMode: Middle;

                            Group {
                                Anchor: (Width: 1500);
                                LayoutMode: Top;

                                // ============ HEADER: icon + name + lore + status ============
                                Group {
                                    LayoutMode: Left;
                                    Background: (TexturePath: "../../Hud/ObjectivePanelContainer.png", Border: 15);
                                    Padding: (Left: 20, Right: 20, Top: 16, Bottom: 16);

                                    // Race icon with tile border frame
                                    Group {
                                        LayoutMode: Middle;
                                        Anchor: (Width: 80);

                                        Group {
                                            Anchor: (Width: 74, Height: 74);

                                            // Icon border frame
                                            Group {
                                                Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                                                Background: (TexturePath: "../../Tiles/TileBorderCommon.png");
                                            }

                                            // Icon centered inside
                                            Group {
                                                Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                                                LayoutMode: Middle;
                                                ItemIcon #DetailRaceIcon {
                                                    Anchor: (Width: 52, Height: 52);
                                                }
                                            }
                                        }
                                    }

                                    Group { Anchor: (Width: 18); }

                                    // Name + subtitle + lore
                                    Group {
                                        LayoutMode: Top;
                                        FlexWeight: 1;

                                        Label #SelectedRaceLabel {
                                            Text: "Select a Race";
                                            Style: (FontSize: 24, TextColor: #f0c040, RenderBold: true);
                                            Anchor: (Height: 28);
                                        }

                                        Label #SelectedRaceSubtitle {
                                            Text: "Preview identity, stats, and passives.";
                                            Style: (FontSize: 12, TextColor: #8aa1bf);
                                            Anchor: (Height: 16);
                                        }

                                        Group { Anchor: (Height: 6); }

                                        Label #RaceLoreText {
                                            Text: "Dive into the mythos behind this race.";
                                            Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true);
                                            Anchor: (Height: 34);
                                        }
                                    }

                                    Group { Anchor: (Width: 24); }

                                    // Status info (right side) with tile background
                                    Group {
                                        LayoutMode: Top;
                                        Anchor: (Width: 240);

                                        Group {
                                            Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                                            Background: (TexturePath: "../../Tiles/TileDefault2x.png", Border: 16, Color: #1a2538);
                                        }

                                        Group {
                                            Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                                            LayoutMode: Top;
                                            Padding: (Full: 12);

                                            Group {
                                                LayoutMode: Left;
                                                Anchor: (Height: 16);
                                                Label #RaceCurrentTitle {
                                                    Text: "Current Race";
                                                    Style: (FontSize: 10, TextColor: #f0c040, RenderBold: true, RenderUppercase: true, LetterSpacing: 1);
                                                }
                                            }

                                            Group { Anchor: (Height: 6); }

                                            Group {
                                                LayoutMode: Left;
                                                Anchor: (Height: 20);
                                                Label #RaceCurrentBadge {
                                                    Text: "Active";
                                                    Style: (FontSize: 11, TextColor: #6fe3ff, RenderBold: true);
                                                }
                                                Group { Anchor: (Width: 6); }
                                                Label #CurrentRaceValue {
                                                    Text: "--";
                                                    Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true);
                                                    FlexWeight: 1;
                                                }
                                            }

                                            Group { Anchor: (Height: 4); }
                                            Group { Anchor: (Height: 1); Background: #ffffff(0.06); }
                                            Group { Anchor: (Height: 4); }

                                            Group {
                                                LayoutMode: Left;
                                                Anchor: (Height: 18);
                                                Label #RaceSwapCooldownCardTitle {
                                                    Text: "Cooldown";
                                                    Style: (FontSize: 10, TextColor: #8aa1bf, LetterSpacing: 1);
                                                }
                                                Group { FlexWeight: 1; }
                                                Label #RaceSwapCooldownValue {
                                                    Text: "--";
                                                    Style: (FontSize: 14, TextColor: #6fe3ff, RenderBold: true);
                                                }
                                            }
                                        }

                                        // Hidden labels (still referenced by Java)
                                        Label #RaceCurrentHint { Text: ""; Anchor: (Height: 0); Visible: false; }
                                        Label #RaceSwapCooldownHint { Text: ""; Anchor: (Height: 0); Visible: false; }
                                        Label #RaceLoreTitle { Text: ""; Anchor: (Height: 0); Visible: false; }
                                        Label #RacesInfoPanel { Text: ""; Anchor: (Height: 0); Visible: false; }
                                    }
                                }

                                Group { Anchor: (Height: 10); }

                                // ============ THREE-COLUMN BODY ============
                                Group {
                                    LayoutMode: Left;
                                    FlexWeight: 1;

                                    // ---- Column 1: Race Stats (ObjectiveContainer) ----
                                    $Nav.@ObjectiveContainer {
                                        Anchor: (Width: 420);

                                        #Title {
                                            Label #RaceStatsTitle {
                                                Text: "Race Stats";
                                                Style: $Nav.@PanelTitleStyle;
                                            }
                                        }

                                        #Content {
                                            LayoutMode: Top;
                                            Padding: (Horizontal: 12, Top: 6, Bottom: 8);

                                            Group #RaceAttributeList {
                                                LayoutMode: Top;

                                                Group {
                                                    LayoutMode: Left;
                                                    Anchor: (Height: 26);
                                                    Padding: (Horizontal: 8);
                                                    Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                                                    Label #RaceAttributeLifeForceLabel { Text: "Life Force"; Style: (FontSize: 12, TextColor: #7be0ff, VerticalAlignment: Center); }
                                                    Group { FlexWeight: 1; }
                                                    Label #RaceAttributeLifeForceValue { Text: "--"; Style: (FontSize: 12, TextColor: #4fd7f7, RenderBold: true, VerticalAlignment: Center); }
                                                    Group { Anchor: (Width: 10); }
                                                    Label #RaceAttributeLifeForceNote { Text: "--"; Style: (FontSize: 11, TextColor: #8aa1bf, VerticalAlignment: Center); }
                                                }
                                                Group { Anchor: (Height: 2); }
                                                Group {
                                                    LayoutMode: Left;
                                                    Anchor: (Height: 26);
                                                    Padding: (Horizontal: 8);
                                                    Label #RaceAttributeStrengthLabel { Text: "Strength"; Style: (FontSize: 12, TextColor: #ffb347, VerticalAlignment: Center); }
                                                    Group { FlexWeight: 1; }
                                                    Label #RaceAttributeStrengthValue { Text: "--"; Style: (FontSize: 12, TextColor: #ffdf8f, RenderBold: true, VerticalAlignment: Center); }
                                                    Group { Anchor: (Width: 10); }
                                                    Label #RaceAttributeStrengthNote { Text: "--"; Style: (FontSize: 11, TextColor: #8aa1bf, VerticalAlignment: Center); }
                                                }
                                                Group { Anchor: (Height: 2); }
                                                Group {
                                                    LayoutMode: Left;
                                                    Anchor: (Height: 26);
                                                    Padding: (Horizontal: 8);
                                                    Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                                                    Label #RaceAttributeSorceryLabel { Text: "Sorcery"; Style: (FontSize: 12, TextColor: #d7baff, VerticalAlignment: Center); }
                                                    Group { FlexWeight: 1; }
                                                    Label #RaceAttributeSorceryValue { Text: "--"; Style: (FontSize: 12, TextColor: #e8d5ff, RenderBold: true, VerticalAlignment: Center); }
                                                    Group { Anchor: (Width: 10); }
                                                    Label #RaceAttributeSorceryNote { Text: "--"; Style: (FontSize: 11, TextColor: #8aa1bf, VerticalAlignment: Center); }
                                                }
                                                Group { Anchor: (Height: 2); }
                                                Group {
                                                    LayoutMode: Left;
                                                    Anchor: (Height: 26);
                                                    Padding: (Horizontal: 8);
                                                    Label #RaceAttributeDefenseLabel { Text: "Defense"; Style: (FontSize: 12, TextColor: #8be0b2, VerticalAlignment: Center); }
                                                    Group { FlexWeight: 1; }
                                                    Label #RaceAttributeDefenseValue { Text: "--"; Style: (FontSize: 12, TextColor: #6ee7b7, RenderBold: true, VerticalAlignment: Center); }
                                                    Group { Anchor: (Width: 10); }
                                                    Label #RaceAttributeDefenseNote { Text: "--"; Style: (FontSize: 11, TextColor: #8aa1bf, VerticalAlignment: Center); }
                                                }
                                                Group { Anchor: (Height: 2); }
                                                Group {
                                                    LayoutMode: Left;
                                                    Anchor: (Height: 26);
                                                    Padding: (Horizontal: 8);
                                                    Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                                                    Label #RaceAttributeHasteLabel { Text: "Haste"; Style: (FontSize: 12, TextColor: #f2a2e8, VerticalAlignment: Center); }
                                                    Group { FlexWeight: 1; }
                                                    Label #RaceAttributeHasteValue { Text: "--"; Style: (FontSize: 12, TextColor: #f78bd9, RenderBold: true, VerticalAlignment: Center); }
                                                    Group { Anchor: (Width: 10); }
                                                    Label #RaceAttributeHasteNote { Text: "--"; Style: (FontSize: 11, TextColor: #8aa1bf, VerticalAlignment: Center); }
                                                }
                                                Group { Anchor: (Height: 2); }
                                                Group {
                                                    LayoutMode: Left;
                                                    Anchor: (Height: 26);
                                                    Padding: (Horizontal: 8);
                                                    Label #RaceAttributePrecisionLabel { Text: "Precision"; Style: (FontSize: 12, TextColor: #9ad4ff, VerticalAlignment: Center); }
                                                    Group { FlexWeight: 1; }
                                                    Label #RaceAttributePrecisionValue { Text: "--"; Style: (FontSize: 12, TextColor: #7cb8ff, RenderBold: true, VerticalAlignment: Center); }
                                                    Group { Anchor: (Width: 10); }
                                                    Label #RaceAttributePrecisionNote { Text: "--"; Style: (FontSize: 11, TextColor: #8aa1bf, VerticalAlignment: Center); }
                                                }
                                                Group { Anchor: (Height: 2); }
                                                Group {
                                                    LayoutMode: Left;
                                                    Anchor: (Height: 26);
                                                    Padding: (Horizontal: 8);
                                                    Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                                                    Label #RaceAttributeFerocityLabel { Text: "Ferocity"; Style: (FontSize: 12, TextColor: #ff7b7b, VerticalAlignment: Center); }
                                                    Group { FlexWeight: 1; }
                                                    Label #RaceAttributeFerocityValue { Text: "--"; Style: (FontSize: 12, TextColor: #ff5555, RenderBold: true, VerticalAlignment: Center); }
                                                    Group { Anchor: (Width: 10); }
                                                    Label #RaceAttributeFerocityNote { Text: "--"; Style: (FontSize: 11, TextColor: #8aa1bf, VerticalAlignment: Center); }
                                                }
                                                Group { Anchor: (Height: 2); }
                                                Group {
                                                    LayoutMode: Left;
                                                    Anchor: (Height: 26);
                                                    Padding: (Horizontal: 8);
                                                    Label #RaceAttributeStaminaLabel { Text: "Stamina"; Style: (FontSize: 12, TextColor: #ffc56f, VerticalAlignment: Center); }
                                                    Group { FlexWeight: 1; }
                                                    Label #RaceAttributeStaminaValue { Text: "--"; Style: (FontSize: 12, TextColor: #ffad42, RenderBold: true, VerticalAlignment: Center); }
                                                    Group { Anchor: (Width: 10); }
                                                    Label #RaceAttributeStaminaNote { Text: "--"; Style: (FontSize: 11, TextColor: #8aa1bf, VerticalAlignment: Center); }
                                                }
                                                Group { Anchor: (Height: 2); }
                                                Group {
                                                    LayoutMode: Left;
                                                    Anchor: (Height: 26);
                                                    Padding: (Horizontal: 8);
                                                    Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                                                    Label #RaceAttributeFlowLabel { Text: "Flow"; Style: (FontSize: 12, TextColor: #9be3ff, VerticalAlignment: Center); }
                                                    Group { FlexWeight: 1; }
                                                    Label #RaceAttributeFlowValue { Text: "--"; Style: (FontSize: 12, TextColor: #7dd6ff, RenderBold: true, VerticalAlignment: Center); }
                                                    Group { Anchor: (Width: 10); }
                                                    Label #RaceAttributeFlowNote { Text: "--"; Style: (FontSize: 11, TextColor: #8aa1bf, VerticalAlignment: Center); }
                                                }
                                                Group { Anchor: (Height: 2); }
                                                Group {
                                                    LayoutMode: Left;
                                                    Anchor: (Height: 26);
                                                    Padding: (Horizontal: 8);
                                                    Label #RaceAttributeDisciplineLabel { Text: "Discipline"; Style: (FontSize: 12, TextColor: #d5dfff, VerticalAlignment: Center); }
                                                    Group { FlexWeight: 1; }
                                                    Label #RaceAttributeDisciplineValue { Text: "--"; Style: (FontSize: 12, TextColor: #9fe0ff, RenderBold: true, VerticalAlignment: Center); }
                                                    Group { Anchor: (Width: 10); }
                                                    Label #RaceAttributeDisciplineNote { Text: "--"; Style: (FontSize: 11, TextColor: #8aa1bf, VerticalAlignment: Center); }
                                                }
                                            }
                                        }
                                    }

                                    Group { Anchor: (Width: 10); }

                                    // ---- Column 2: Passives (ObjectiveContainer) ----
                                    $Nav.@ObjectiveContainer {
                                        Anchor: (Width: 420);

                                        #Title {
                                            Label #RacePassivesTitle {
                                                Text: "Passives";
                                                Style: $Nav.@PanelTitleStyle;
                                            }
                                        }

                                        #Content {
                                            LayoutMode: Top;
                                            Padding: (Horizontal: 12, Top: 6, Bottom: 8);

                                            Label #RacePassiveSummary {
                                                Text: "Inspect a race to preview its passive bonuses.";
                                                Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true);
                                                Anchor: (Height: 18);
                                            }

                                            Group { Anchor: (Height: 4); }

                                            Group #RacePassiveScrollArea {
                                                FlexWeight: 1;
                                                LayoutMode: TopScrolling;
                                                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                                Group #RacePassiveEntries {
                                                    LayoutMode: Top;
                                                }
                                            }
                                        }
                                    }

                                    Group { Anchor: (Width: 10); }

                                    // ---- Column 3: Evolution Paths (ObjectiveContainer) ----
                                    $Nav.@ObjectiveContainer {
                                        FlexWeight: 1;

                                        #Title {
                                            Label #RaceEvolutionTitle {
                                                Text: "Evolution Paths";
                                                Style: $Nav.@PanelTitleStyle;
                                            }
                                        }

                                        #Content {
                                            LayoutMode: Top;
                                            Padding: (Horizontal: 12, Top: 6, Bottom: 8);

                                            Label #RaceEvolutionSummary {
                                                Text: "Select a race to inspect evolution branches.";
                                                Style: (FontSize: 12, TextColor: #9fb6d3, Wrap: true);
                                                Anchor: (Height: 32);
                                            }

                                            Group { Anchor: (Height: 4); }

                                            Group #RaceEvolutionScrollArea {
                                                FlexWeight: 1;
                                                LayoutMode: TopScrolling;
                                                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                                Group #RaceEvolutionEntries {
                                                    LayoutMode: Top;
                                                }
                                            }
                                        }
                                    }
                                }

                                Group { Anchor: (Height: 8); }

                                // ============ ACTION BAR (ObjectiveContainer) ============
                                Group {
                                    LayoutMode: Left;
                                    Background: (TexturePath: "../../Hud/ObjectivePanelContainer.png", Border: 15);
                                    Padding: (Left: 18, Right: 18, Top: 12, Bottom: 12);

                                    $C.@TextButton #BackToCarouselButton {
                                        Text: "BACK";
                                        Anchor: (Height: 34, Width: 140);
                                        Style: @CustomStyle;
                                    }

                                    Group { Anchor: (Width: 10); }

                                    $C.@TextButton #ViewRacePathsButton {
                                        Text: "VIEW PATHS";
                                        Anchor: (Height: 34, Width: 160);
                                        Style: @CustomStyle;
                                    }

                                    Group { FlexWeight: 1; }

                                    Label #RaceDetailCooldownWarning {
                                        Text: "Swapping will trigger a cooldown.";
                                        Style: (FontSize: 11, TextColor: #ffc300, RenderBold: true, VerticalAlignment: Center);
                                    }

                                    Group { FlexWeight: 1; }

                                    $C.@TextButton #ConfirmRaceButton {
                                        Text: "SWAP RACE";
                                        Anchor: (Height: 34, Width: 160);
                                        Style: @CustomStyle;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Group { Anchor: (Height: 14); }

        // ====================== FOOTER NAVBAR ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Height: 92);
                $Nav.@BottomNavBar {}
            }
        }
    }
}

$C.@BackButton {}
