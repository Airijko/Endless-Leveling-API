$C = "../../Common.ui";

Group {
    LayoutMode: Top;

    Group {
        LayoutMode: Left;
        Background: #2b1a0f(0.55);
        Padding: (Horizontal: 12, Vertical: 8);

        Label #Rank { Style: (FontSize: 13, TextColor: #d89b64, RenderBold: true); Anchor: (Width: 60); Text: "-"; }
        Label #Name { Style: (FontSize: 13, TextColor: #d89b64, RenderBold: true); FlexWeight: 1; Text: "-"; }
        Label #Profile { Style: (FontSize: 13, TextColor: #ddb189); Anchor: (Width: 120); Text: "-"; }
        Label #Prestige { Style: (FontSize: 13, TextColor: #e6c5a8, RenderBold: true); Anchor: (Width: 80); Text: "-"; }
        Label #Level { Style: (FontSize: 13, TextColor: #f2c79e, RenderBold: true); Anchor: (Width: 70); Text: "-"; }
        Label #Value { Style: (FontSize: 13, TextColor: #ddb189); Anchor: (Width: 140); Text: "-"; }
    }

    Group { Anchor: (Height: 6); }
}
