$C = "../../Common.ui";
$Nav = "../Nav/TopNavBar.ui";

@TabLabelStyle = LabelStyle(
    FontSize: 14,
    TextColor: #bfcdd5,
    RenderBold: true,
    RenderUppercase: true,
    HorizontalAlignment: Center,
    VerticalAlignment: Center
);

@TabStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @TabLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: @TabLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @TabLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: @TabLabelStyle),
    Sounds: $C.@ButtonSounds,
);

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;
        Padding: (Vertical: 12);

        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);
            Group {
                Anchor: (Height: 92);
                $Nav.@TopNavBar {}
            }
        }

        Group { Anchor: (Height: 14); }

        Group {
            LayoutMode: Middle;

    $Nav.@ObjectiveContainer {
        Anchor: (Width: 1400, Height: 700);
        #Title {
            Label #XpStatsTitle {
                Text: "ENDLESS LEVELING";
                Style: $Nav.@PanelTitleStyle;
            }
        }

        #Content {
            LayoutMode: Top;
            Padding: (Full: 0);

            // ================= HEADER =================
            Group #Header {
                LayoutMode: Top;
                Padding: (Horizontal: 16, Top: 10, Bottom: 6);

                Group {
                    LayoutMode: Left;

                    Label #PageTitleLabel {
                        Text: "XP Statistics";
                        Style: (FontSize: 22, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                        Anchor: (Height: 40);
                    }

                    Group { FlexWeight: 1; }

                    Group {
                        LayoutMode: Left;
                        Background: (TexturePath: "../../Hud/ObjectivePanelContainer.png", Border: 15);
                        Anchor: (Height: 36);
                        Padding: (Horizontal: 14, Vertical: 6);

                        Label #SubtitleText {
                            Style: (TextColor: #f0c040, FontSize: 12, RenderBold: true, VerticalAlignment: Center);
                            Text: "";
                        }
                    }
                }
            }

            // ================= TAB BAR =================
            Group #TabBar {
                LayoutMode: Left;
                Anchor: (Height: 36);
                Padding: (Horizontal: 16);

                $C.@TextButton #TabMyStats {
                    Text: "MY STATS";
                    Anchor: (Height: 30);
                    Padding: (Horizontal: 16, Vertical: 1);
                    Style: @TabStyle;
                }

                Group { Anchor: (Width: 6); }

                $C.@TextButton #TabLeaderboard {
                    Text: "LEADERBOARD";
                    Anchor: (Height: 30);
                    Padding: (Horizontal: 16, Vertical: 1);
                    Style: @TabStyle;
                }

                Group { Anchor: (Width: 6); }

                $C.@TextButton #TabAdmin {
                    Text: "ADMIN";
                    Anchor: (Height: 30);
                    Padding: (Horizontal: 16, Vertical: 1);
                    Style: @TabStyle;
                }

                Group { Anchor: (Width: 12); }

                Label #ActiveTabLabel {
                    Style: (TextColor: #9ab6d4, FontSize: 12, VerticalAlignment: Center);
                    Text: "";
                }
            }

            Group { Anchor: (Height: 1); Padding: (Horizontal: 16); Group { Background: #2b3f58; } }

            Group { Anchor: (Height: 6); }

            // ================= CONTENT AREA =================
            Group #Main {
                LayoutMode: Top;
                FlexWeight: 1;
                Padding: (Horizontal: 16, Bottom: 8);

                Group #ContentArea {
                    LayoutMode: Top;
                    FlexWeight: 1;
                    Background: #0b1520(0.85);
                    Padding: (Full: 8);

                    Group #ContentScroll {
                        FlexWeight: 1;
                        LayoutMode: TopScrolling;
                        ScrollbarStyle: $C.@DefaultScrollbarStyle;

                        Group #ContentRows {
                            LayoutMode: Top;
                        }
                    }
                }

                Group #PaginationBar {
                    LayoutMode: Left;
                    Anchor: (Height: 36);
                    Padding: (Horizontal: 8, Top: 6);

                    $C.@TextButton #PrevPageButton {
                        Text: "< PREV";
                        Anchor: (Width: 90, Height: 28);
                        Style: @TabStyle;
                    }

                    Group { FlexWeight: 1; }

                    Label #PageLabel {
                        Style: (TextColor: #9ab6d4, FontSize: 13, HorizontalAlignment: Center, VerticalAlignment: Center);
                        Text: "Page 1/1";
                    }

                    Group { FlexWeight: 1; }

                    $C.@TextButton #NextPageButton {
                        Text: "NEXT >";
                        Anchor: (Width: 90, Height: 28);
                        Style: @TabStyle;
                    }
                }
            }
        }
    }
        }

        Group { Anchor: (Height: 14); }

        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);
            Group {
                Anchor: (Height: 92);
                $Nav.@BottomNavBar {}
            }
        }
    }
}

$C.@BackButton {}
