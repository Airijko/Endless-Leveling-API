$C = "../../Common.ui";
$Nav = "../Nav/TopNavBar.ui";

@TabLabelStyle = LabelStyle(
    FontSize: 14,
    TextColor: #bfcdd5,
    RenderBold: true,
    RenderUppercase: true,
    HorizontalAlignment: Center,
    VerticalAlignment: Center
);

@TabStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @TabLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: @TabLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @TabLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: @TabLabelStyle),
    Sounds: $C.@ButtonSounds,
);

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;
        Padding: (Vertical: 12);

        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);
            Group {
                Anchor: (Height: 92);
                $Nav.@TopNavBar {}
            }
        }

        Group { Anchor: (Height: 14); }

        Group {
            LayoutMode: Middle;

    $Nav.@ObjectiveContainer {
        Anchor: (Width: 1000, Height: 700);
        #Title {
            Label #LbTitle {
                Text: "ENDLESS LEVELING";
                Style: $Nav.@PanelTitleStyle;
            }
        }

        #Content {
            LayoutMode: Left;
            Padding: (Full: 0);

            Group #RightPanel {
                FlexWeight: 1;
                LayoutMode: Top;

                Group #Header {
                    LayoutMode: Left;
                    Anchor: (Height: 60);
                    Padding: (Horizontal: 16, Vertical: 10);

                    Label #PageTitleLabel {
                        Text: "XP Leaderboards";
                        Anchor: (Height: 60);
                        Style: (FontSize: 22, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                    }

                    Group { FlexWeight: 1; }

                    Label #PlayerCountLabel {
                        Style: (TextColor: #aaccff, FontSize: 14, VerticalAlignment: Center);
                        Text: "";
                    }
                }

                Group { Anchor: (Height: 1); Background: #2b3542; }

                Group #Main {
                    LayoutMode: Top;
                    FlexWeight: 1;
                    Padding: (Full: 16);

                    Group #TabBar {
                        LayoutMode: Left;
                        Anchor: (Height: 36);

                        $C.@TextButton #TabXp24h {
                            Text: "XP 24H";
                            Anchor: (Width: 100, Height: 30);
                            Style: @TabStyle;
                        }

                        Group { Anchor: (Width: 6); }

                        $C.@TextButton #TabXp7d {
                            Text: "XP 7D";
                            Anchor: (Width: 100, Height: 30);
                            Style: @TabStyle;
                        }

                        Group { Anchor: (Width: 6); }

                        $C.@TextButton #TabTotalXp {
                            Text: "TOTAL XP";
                            Anchor: (Width: 100, Height: 30);
                            Style: @TabStyle;
                        }

                        Group { Anchor: (Width: 6); }

                        $C.@TextButton #TabMomentum {
                            Text: "MOMENTUM";
                            Anchor: (Width: 120, Height: 30);
                            Style: @TabStyle;
                        }

                        Group { FlexWeight: 1; }

                        Label #ActiveTabLabel {
                            Style: (TextColor: #9ab6d4, FontSize: 12, VerticalAlignment: Center);
                            Text: "Sorted by: XP 24H";
                        }
                    }

                    Group { Anchor: (Height: 8); }

                    Group #HeaderCard {
                        LayoutMode: Top;
                        Background: #0b141f(0.92);
                        Padding: (Full: 12);

                        Group #Headers {
                            LayoutMode: Left;
                            Padding: (Vertical: 4);

                            Label #HeaderRank { Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true); Text: "Rank"; Anchor: (Width: 60); }
                            Label #HeaderPlayer { Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true); Text: "Player"; FlexWeight: 1; }
                            Label #HeaderProfile { Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true); Text: "Profile"; Anchor: (Width: 120); }
                            Label #HeaderPrestige { Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true); Text: "Prestige"; Anchor: (Width: 80); }
                            Label #HeaderLevel { Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true); Text: "Level"; Anchor: (Width: 70); }
                            Label #HeaderValue { Style: (TextColor: #c0cee5, FontSize: 13, RenderBold: true, RenderUppercase: true); Text: "XP 24H"; Anchor: (Width: 140); }
                        }

                        Group { Anchor: (Height: 1); Background: #2b3542; }
                    }

                    Group { Anchor: (Height: 8); }

                    Group #RowsContainer {
                        LayoutMode: Top;
                        FlexWeight: 1;
                        Background: #070b12(0.9);
                        Padding: (Full: 8);

                        Group #Rows {
                            FlexWeight: 1;
                            LayoutMode: TopScrolling;
                            ScrollbarStyle: $C.@DefaultScrollbarStyle;

                            Group #RowCards {
                                LayoutMode: Top;
                            }
                        }
                    }

                    Group #PaginationBar {
                        LayoutMode: Left;
                        Anchor: (Height: 36);
                        Padding: (Horizontal: 8, Top: 6);

                        $C.@TextButton #PrevPageButton {
                            Text: "< PREV";
                            Anchor: (Width: 90, Height: 28);
                            Style: @TabStyle;
                        }

                        Group { FlexWeight: 1; }

                        Label #PageLabel {
                            Style: (TextColor: #9ab6d4, FontSize: 13, HorizontalAlignment: Center, VerticalAlignment: Center);
                            Text: "Page 1/1";
                        }

                        Group { FlexWeight: 1; }

                        $C.@TextButton #NextPageButton {
                            Text: "NEXT >";
                            Anchor: (Width: 90, Height: 28);
                            Style: @TabStyle;
                        }
                    }
                }
            }
        }
    }
        }

        Group { Anchor: (Height: 14); }

        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);
            Group {
                Anchor: (Height: 92);
                $Nav.@BottomNavBar {}
            }
        }
    }
}

$C.@BackButton {}
