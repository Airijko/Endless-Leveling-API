$C = "../../Common.ui";
$S = "SettingsStyles.ui";

@ConfigSettingsPanel = Group {
    LayoutMode: Top;
    FlexWeight: 1;
    Visible: false;

    // ---- Header ----
    Group #ConfigSettingsHeader {
        LayoutMode: Left;
        Anchor: (Height: 50);
        Padding: (Horizontal: 16, Vertical: 10);

        Label #ConfigTitleLabel {
            Text: "Config Settings";
            Style: (FontSize: 20, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
        }

        Group { FlexWeight: 1; }

        Group {
            LayoutMode: Left;
            Background: #0b141f(0.92);
            Anchor: (Height: 32);
            Padding: (Horizontal: 10, Vertical: 6);

            Label #ConfigIntroText {
                Style: (TextColor: #f0cf78, FontSize: 12, VerticalAlignment: Center);
                Text: "Admin-only server configuration.";
            }
        }
    }

    // ---- Tab Bar ----
    Group #ConfigTabBar {
        LayoutMode: Left;
        Background: #070b12;
        Padding: (Horizontal: 12, Vertical: 6);

        $S.@ConfigTab #TabConfigYml { Text: "config.yml"; }
        Group { Anchor: (Width: 4); }
        $S.@ConfigTab #TabLevelingYml { Text: "leveling.yml"; }
        Group { Anchor: (Width: 4); }
        $S.@ConfigTab #TabWorldSettings { Text: "worlds.json"; }
        Group { Anchor: (Width: 4); }
        $S.@ConfigTab #TabEventsYml { Text: "events.yml"; }
        Group { Anchor: (Width: 4); }
        $S.@ConfigTab #TabWeaponsJson { Text: "weapons.json"; }
    }

    Group { Anchor: (Height: 1); Background: #2b3542; }

    // ---- Tab Content ----
    Group #ConfigTabContent {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        FlexWeight: 1;
        Padding: (Full: 16);

        // ================================================
        // CONFIG.YML TAB
        // ================================================
        Group #ConfigYmlPanel {
            LayoutMode: Top;

            // ---- RACE SYSTEM ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #f0cf78; }
                Group { Anchor: (Width: 8); }
                Label { Text: "RACE SYSTEM"; Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #CfgEnableRacesRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgEnableRacesLabel { Text: "Enable Races"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgEnableRacesValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #CfgEnableRacesToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgDefaultRaceRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgDefaultRaceLabel { Text: "Default Race"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgDefaultRaceValue { Text: "Human"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgRaceCooldownRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgRaceCooldownLabel { Text: "Race Cooldown (s)"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #CfgRaceCooldownInput { Value: 3600; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgRaceMaxSwitchesRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgRaceMaxSwitchesLabel { Text: "Max Race Switches"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #CfgRaceMaxSwitchesInput { Value: 1; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgGlobalRaceVisualsRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgGlobalRaceVisualsLabel { Text: "Global Race Visuals"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgGlobalRaceVisualsValue { Text: "off"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #CfgGlobalRaceVisualsCycle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Cycle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 12); }

            // ---- CLASS SYSTEM ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #f0cf78; }
                Group { Anchor: (Width: 8); }
                Label { Text: "CLASS SYSTEM"; Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #CfgEnableClassesRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgEnableClassesLabel { Text: "Enable Classes"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgEnableClassesValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #CfgEnableClassesToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgEnableSecondaryClassRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgEnableSecondaryClassLabel { Text: "Enable Secondary Class"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgEnableSecondaryClassValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #CfgEnableSecondaryClassToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgDefaultPrimaryClassRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgDefaultPrimaryClassLabel { Text: "Default Primary Class"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgDefaultPrimaryClassValue { Text: "Adventurer"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgOffClassPenaltyRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgOffClassPenaltyLabel { Text: "Off-Class Damage Penalty"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgOffClassPenaltyValue { Text: "-40%"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #ff7878, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgClassCooldownRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgClassCooldownLabel { Text: "Class Cooldown (s)"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #CfgClassCooldownInput { Value: 1800; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgClassMaxSwitchesRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgClassMaxSwitchesLabel { Text: "Max Class Switches"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #CfgClassMaxSwitchesInput { Value: 1; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 12); }

            // ---- SWAP ANTI-EXPLOIT ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #ff7878; }
                Group { Anchor: (Width: 8); }
                Label { Text: "SWAP ANTI-EXPLOIT"; Style: (TextColor: #ff7878, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #CfgSwapConsumeEnabledRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgSwapConsumeEnabledLabel { Text: "Auto-Consume at Level"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgSwapConsumeEnabledValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #CfgSwapConsumeEnabledToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgSwapConsumeThresholdRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgSwapConsumeThresholdLabel { Text: "Consume Threshold Level"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #CfgSwapConsumeThresholdInput { Value: 20; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 12); }

            // ---- LANGUAGE ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #b0c4de; }
                Group { Anchor: (Width: 8); }
                Label { Text: "LANGUAGE"; Style: (TextColor: #b0c4de, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #CfgLocaleRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgLocaleLabel { Text: "Locale"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgLocaleValue { Text: "en_US"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgFallbackLocaleRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label #CfgFallbackLocaleLabel { Text: "Fallback Locale"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgFallbackLocaleValue { Text: "en_US"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
            }

            Group { Anchor: (Height: 12); }

            // ---- BUILTIN CONTENT ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #6fe3ff; }
                Group { Anchor: (Width: 8); }
                Label { Text: "BUILTIN CONTENT"; Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #CfgEnableBuiltinRacesRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Enable Builtin Races"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgEnableBuiltinRacesValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #CfgEnableBuiltinRacesToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgEnableBuiltinClassesRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Enable Builtin Classes"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgEnableBuiltinClassesValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #CfgEnableBuiltinClassesToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #CfgEnableBuiltinAugmentsRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Enable Builtin Augments"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgEnableBuiltinAugmentsValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #CfgEnableBuiltinAugmentsToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 12); }

            // ---- DEBUG ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #7a8a9e; }
                Group { Anchor: (Width: 8); }
                Label { Text: "DEBUG"; Style: (TextColor: #7a8a9e, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #CfgEnableLoggingRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Enable Logging"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #CfgEnableLoggingValue { Text: "false"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #CfgEnableLoggingToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }
        }

        // ================================================
        // LEVELING.YML TAB
        // ================================================
        Group #LevelingYmlPanel {
            LayoutMode: Top;
            Visible: false;

            // ---- LEVELING FORMULA ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #f0cf78; }
                Group { Anchor: (Width: 8); }
                Label { Text: "LEVELING FORMULA"; Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #LvlExpressionRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "XP Expression"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlExpressionValue { Text: "base * ((log(level)+1) * (sqrt(level)))^1.8"; Anchor: (Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #9ab0ca, FontSize: 10); Background: #061420; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlLogModeRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Log Mode"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlLogModeValue { Text: "LOG10"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #LvlLogModeCycle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Cycle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlBaseRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Base XP"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #LvlBaseInput { Value: 100; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 12); }

            // ---- SKILL POINTS ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #6fe3ff; }
                Group { Anchor: (Width: 8); }
                Label { Text: "SKILL POINTS"; Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #LvlBaseSkillPointsRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Base Skill Points"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #LvlBaseSkillPointsInput { Value: 12; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlSkillPointsPerLevelRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Skill Points Per Level"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #LvlSkillPointsPerLevelInput { Value: 5; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlPlayerLevelCapRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Player Level Cap"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #LvlPlayerLevelCapInput { Value: 100; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 12); }

            // ---- PARTY XP SHARE ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #9fe7b3; }
                Group { Anchor: (Width: 8); }
                Label { Text: "PARTY XP SHARE"; Style: (TextColor: #9fe7b3, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #LvlPartyXpEnabledRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Party XP Sharing"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlPartyXpEnabledValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #LvlPartyXpEnabledToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlPartyXpRangeRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Share Range (blocks)"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #LvlPartyXpRangeInput { Value: 25; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlPartyXpSharePercentRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Member Share %"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #LvlPartyXpSharePercentInput { Value: 100; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 12); }

            // ---- PRESTIGE ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #d7baff; }
                Group { Anchor: (Width: 8); }
                Label { Text: "PRESTIGE"; Style: (TextColor: #d7baff, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #LvlPrestigeEnabledRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Prestige System"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlPrestigeEnabledValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #LvlPrestigeEnabledToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlPrestigeLevelCapRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Prestige Level Cap"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlPrestigeLevelCapValue { Text: "ENDLESS"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlPrestigeLevelCapIncRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Level Cap Increase / Prestige"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #LvlPrestigeLevelCapIncInput { Value: 10; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlPrestigeXpIncRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Base XP Increase / Prestige"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #LvlPrestigeXpIncInput { Value: 20; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 12); }

            // ---- MOB LEVELING ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #ff7878; }
                Group { Anchor: (Width: 8); }
                Label { Text: "MOB LEVELING"; Style: (TextColor: #ff7878, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #LvlMobLevelModeRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Level Source Mode"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlMobLevelModeValue { Text: "FIXED"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #LvlMobLevelModeCycle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Cycle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlMobXpEnabledRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Mob XP Enabled"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlMobXpEnabledValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #LvlMobXpEnabledToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlMobXpScalingModeRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "XP Scaling Mode"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlMobXpScalingModeValue { Text: "LINEAR"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #LvlMobXpScalingModeCycle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Cycle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlGlobalXpMultiplierRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Global XP Multiplier"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                NumberField #LvlGlobalXpMultiplierInput { Value: 1; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
            }

            Group { Anchor: (Height: 12); }

            // ---- NAMEPLATE ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #b0c4de; }
                Group { Anchor: (Width: 8); }
                Label { Text: "NAMEPLATE"; Style: (TextColor: #b0c4de, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #LvlNameplateEnabledRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Mob Nameplate Enabled"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlNameplateEnabledValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #LvlNameplateEnabledToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlNameplateShowLevelRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Show Level"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlNameplateShowLevelValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #LvlNameplateShowLevelToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlNameplateShowNameRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Show Name"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlNameplateShowNameValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #LvlNameplateShowNameToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlNameplateShowHealthRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Show Health"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlNameplateShowHealthValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #LvlNameplateShowHealthToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #LvlPlayerNameplateEnabledRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Player Nameplate Enabled"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #LvlPlayerNameplateEnabledValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #LvlPlayerNameplateEnabledToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }
        }

        // ================================================
        // WORLDS.JSON TAB
        // ================================================
        Group #WorldSettingsPanel {
            LayoutMode: Top;
            Visible: false;

            // ---- File navigation bar ----
            Group #WsFileNav {
                LayoutMode: Left;
                Background: #060a10;
                Padding: (Horizontal: 12, Vertical: 6);

                $S.@ConfigTab #WsPrevFile {
                    Text: "◄";
                    Anchor: (Height: 28, Width: 36);
                }

                Group { Anchor: (Width: 8); }

                Label #WsCurrentFileName {
                    Text: "Loading...";
                    FlexWeight: 1;
                    Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                }

                Group { Anchor: (Width: 8); }

                $S.@ConfigTab #WsNextFile {
                    Text: "►";
                    Anchor: (Height: 28, Width: 36);
                }

                Group { Anchor: (Width: 12); }

                Label #WsFilePosition {
                    Text: "0 / 0";
                    Style: (TextColor: #6e7da1, FontSize: 11, VerticalAlignment: Center);
                }
            }

            Group { Anchor: (Height: 1); Background: #2b3542; }

            // ---- File content area (populated dynamically) ----
            Group #WsFileContent {
                LayoutMode: Top;
                Padding: (Top: 8);
            }
        }

        // ================================================
        // EVENTS.YML TAB
        // ================================================
        Group #EventsYmlPanel {
            LayoutMode: Top;
            Visible: false;

            // ---- PRESTIGE LEVEL UP ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #d7baff; }
                Group { Anchor: (Width: 8); }
                Label { Text: "PRESTIGE LEVEL UP"; Style: (TextColor: #d7baff, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #EvtPrestigeEnabledRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Prestige Events Enabled"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #EvtPrestigeEnabledValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #EvtPrestigeEnabledToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #EvtPrestigeAsPlayerRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Run as Player"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #EvtPrestigeAsPlayerValue { Text: "false"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #EvtPrestigeAsPlayerToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 12); }

            // ---- PLAYER LEVEL UP ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #f0cf78; }
                Group { Anchor: (Width: 8); }
                Label { Text: "PLAYER LEVEL UP"; Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group #EvtLevelUpEnabledRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Level Up Events Enabled"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #EvtLevelUpEnabledValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #EvtLevelUpEnabledToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #EvtLevelUpAsPlayerRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Run as Player"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #EvtLevelUpAsPlayerValue { Text: "false"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #EvtLevelUpAsPlayerToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 3); }

            Group #EvtLevelUpRepeatPrestigesRow {
                LayoutMode: Left;
                Background: #0b141f(0.72);
                Padding: (Horizontal: 10, Vertical: 7);
                Label { Text: "Repeat Across Prestiges"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                Label #EvtLevelUpRepeatPrestigesValue { Text: "true"; Anchor: (Width: $S.@CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                Group { Anchor: (Width: 6); }
                $C.@TextButton #EvtLevelUpRepeatPrestigesToggle { Anchor: (Height: 26, Width: $S.@CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: $S.@CustomStyle; }
            }

            Group { Anchor: (Height: 12); }

            // ---- CONFIGURED COMMANDS ----
            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #7a8a9e; }
                Group { Anchor: (Width: 8); }
                Label { Text: "CONFIGURED COMMANDS"; Style: (TextColor: #7a8a9e, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group {
                LayoutMode: Top;
                Background: #0b141f(0.72);
                Padding: (Full: 10);

                Label {
                    Text: "Command mappings are loaded from events.yml. To edit command lists, modify the file directly.";
                    Style: (TextColor: #9ab0ca, FontSize: 11, Wrap: true);
                }

                Group { Anchor: (Height: 6); }

                Label #EvtCommandSummary {
                    Text: "Prestige: 1 rule | Level Up: 2 rules";
                    Style: (TextColor: #d5e4f7, FontSize: 13);
                }
            }
        }

        // ================================================
        // WEAPONS.JSON TAB
        // ================================================
        Group #WeaponsJsonPanel {
            LayoutMode: Top;
            Visible: false;

            Group {
                LayoutMode: Left;
                Padding: (Bottom: 6, Top: 4);
                Group { Anchor: (Width: 3, Height: 16); Background: #f0cf78; }
                Group { Anchor: (Width: 8); }
                Label { Text: "WEAPON TYPES"; Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
            }

            Group {
                LayoutMode: Top;
                Background: #0b141f(0.60);
                Padding: (Full: 8);
                Label { Text: "Weapon classifications used for class restrictions and damage calculations."; Style: (TextColor: #9ab0ca, FontSize: 11, Wrap: true); }
            }

            Group { Anchor: (Height: 6); }

            Group #WpnSwordRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Sword"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnSwordKeywords { Text: "sword, blade, saber, katana, rapier, cutlass, ..."; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
            Group { Anchor: (Height: 2); }
            Group #WpnAxeRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Axe"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnAxeKeywords { Text: "axe, hatchet, battleaxe"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
            Group { Anchor: (Height: 2); }
            Group #WpnGauntletRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Gauntlet"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnGauntletKeywords { Text: "gauntlet, glove, knuckle, bracer, fist"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
            Group { Anchor: (Height: 2); }
            Group #WpnBowRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Bow"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnBowKeywords { Text: "bow, weaver"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
            Group { Anchor: (Height: 2); }
            Group #WpnStaffRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Staff"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnStaffKeywords { Text: "staff, rod, spellbook, wand, necronomicon"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
            Group { Anchor: (Height: 2); }
            Group #WpnDaggerRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Dagger"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnDaggerKeywords { Text: "dagger, knife, dirk, whirlwinds"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
            Group { Anchor: (Height: 2); }
            Group #WpnMaceRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Mace"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnMaceKeywords { Text: "mace, hammer, club, flail, warhammer"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
            Group { Anchor: (Height: 2); }
            Group #WpnSpearRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Spear"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnSpearKeywords { Text: "spear, halberd, polearm, trident, glaive"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
            Group { Anchor: (Height: 2); }
            Group #WpnCrossbowRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Crossbow"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnCrossbowKeywords { Text: "crossbow"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
            Group { Anchor: (Height: 2); }
            Group #WpnHammerRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Hammer"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnHammerKeywords { Text: "hammer"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
            Group { Anchor: (Height: 2); }
            Group #WpnShieldRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Shield"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnShieldKeywords { Text: "shield"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
            Group { Anchor: (Height: 2); }
            Group #WpnGunsRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Guns"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnGunsKeywords { Text: "gun"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
            Group { Anchor: (Height: 2); }
            Group #WpnUnarmedRow { LayoutMode: Left; Background: #0b141f(0.72); Padding: (Horizontal: 10, Vertical: 6); Label { Text: "Unarmed"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); } Label #WpnUnarmedKeywords { Text: "fist"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; } }
        }
    }
};
