                                                    Label { Text: "MOB SCALING"; Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                Group #WsMobScalingRangeRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label { Text: "Mob Level Scaling Range"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    NumberField #WsMobScalingRangeInput { Value: 15; Anchor: (Width: @CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #WsPlayerScalingRangeRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label { Text: "Player Level Scaling Range"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    NumberField #WsPlayerScalingRangeInput { Value: 20; Anchor: (Width: @CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
                                                }

                                                Group { Anchor: (Height: 12); }

                                                // ---- MOB AUGMENTS ----
                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 6, Top: 4);
                                                    Group { Anchor: (Width: 3, Height: 16); Background: #d7baff; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "MOB AUGMENTS"; Style: (TextColor: #d7baff, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                Group #WsMobAugmentsEnabledRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label { Text: "Mob Augments Enabled"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #WsMobAugmentsEnabledValue { Text: "true"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #WsMobAugmentsEnabledToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #WsMobAugmentsBlacklistRow {
                                                    LayoutMode: Top;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Full: 10);

                                                    Label { Text: "Blacklisted Augments"; Style: (TextColor: #d5e4f7, FontSize: 13, RenderBold: true); }
                                                    Group { Anchor: (Height: 4); }
                                                    Label #WsMobAugmentsBlacklistValue {
                                                        Text: "burn, phase_rush, grasp_of_the_undying, haymaker, tank_engine";
                                                        Style: (TextColor: #9ab0ca, FontSize: 11, Wrap: true);
                                                    }
                                                }
                                            }

                                            // ================================================
                                            // EVENTS.YML TAB
                                            // ================================================
                                            Group #EventsYmlPanel {
                                                LayoutMode: Top;
                                                Visible: false;

                                                // ---- PRESTIGE LEVEL UP ----
                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 6, Top: 4);
                                                    Group { Anchor: (Width: 3, Height: 16); Background: #d7baff; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "PRESTIGE LEVEL UP"; Style: (TextColor: #d7baff, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                Group #EvtPrestigeEnabledRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label { Text: "Prestige Events Enabled"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #EvtPrestigeEnabledValue { Text: "true"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #EvtPrestigeEnabledToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #EvtPrestigeAsPlayerRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label { Text: "Run as Player"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #EvtPrestigeAsPlayerValue { Text: "false"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #EvtPrestigeAsPlayerToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 12); }

                                                // ---- PLAYER LEVEL UP ----
                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 6, Top: 4);
                                                    Group { Anchor: (Width: 3, Height: 16); Background: #f0cf78; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "PLAYER LEVEL UP"; Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                Group #EvtLevelUpEnabledRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label { Text: "Level Up Events Enabled"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #EvtLevelUpEnabledValue { Text: "true"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #EvtLevelUpEnabledToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #EvtLevelUpAsPlayerRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label { Text: "Run as Player"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #EvtLevelUpAsPlayerValue { Text: "false"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #EvtLevelUpAsPlayerToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #EvtLevelUpRepeatPrestigesRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label { Text: "Repeat Across Prestiges"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #EvtLevelUpRepeatPrestigesValue { Text: "true"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #EvtLevelUpRepeatPrestigesToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 12); }

                                                // ---- CONFIGURED COMMANDS ----
                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 6, Top: 4);
                                                    Group { Anchor: (Width: 3, Height: 16); Background: #7a8a9e; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "CONFIGURED COMMANDS"; Style: (TextColor: #7a8a9e, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                Group {
                                                    LayoutMode: Top;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Full: 10);

                                                    Label {
                                                        Text: "Command mappings are loaded from events.yml. To edit command lists, modify the file directly.";
                                                        Style: (TextColor: #9ab0ca, FontSize: 11, Wrap: true);
                                                    }

                                                    Group { Anchor: (Height: 6); }

                                                    Label #EvtCommandSummary {
                                                        Text: "Prestige: 1 rule | Level Up: 2 rules";
                                                        Style: (TextColor: #d5e4f7, FontSize: 13);
                                                    }
                                                }
                                            }

                                            // ================================================
                                            // WEAPONS.JSON TAB
                                            // ================================================
                                            Group #WeaponsJsonPanel {
                                                LayoutMode: Top;
                                                Visible: false;

                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 6, Top: 4);
                                                    Group { Anchor: (Width: 3, Height: 16); Background: #f0cf78; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "WEAPON TYPES"; Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                Group {
                                                    LayoutMode: Top;
                                                    Background: #0b141f(0.60);
                                                    Padding: (Full: 8);
                                                    Label { Text: "Weapon classifications used for class restrictions and damage calculations."; Style: (TextColor: #9ab0ca, FontSize: 11, Wrap: true); }
                                                }

                                                Group { Anchor: (Height: 6); }

                                                Group #WpnSwordRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Sword"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnSwordKeywords { Text: "sword, blade, saber, katana, rapier, cutlass, ..."; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }

                                                Group { Anchor: (Height: 2); }

                                                Group #WpnAxeRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Axe"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnAxeKeywords { Text: "axe, hatchet, battleaxe"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }

                                                Group { Anchor: (Height: 2); }

                                                Group #WpnGauntletRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Gauntlet"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnGauntletKeywords { Text: "gauntlet, glove, knuckle, bracer, fist"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }

                                                Group { Anchor: (Height: 2); }

                                                Group #WpnBowRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Bow"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnBowKeywords { Text: "bow, weaver"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }

                                                Group { Anchor: (Height: 2); }

                                                Group #WpnStaffRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Staff"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnStaffKeywords { Text: "staff, rod, spellbook, wand, necronomicon"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }

                                                Group { Anchor: (Height: 2); }

                                                Group #WpnDaggerRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Dagger"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnDaggerKeywords { Text: "dagger, knife, dirk, whirlwinds"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }

                                                Group { Anchor: (Height: 2); }

                                                Group #WpnMaceRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Mace"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnMaceKeywords { Text: "mace, hammer, club, flail, warhammer"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }

                                                Group { Anchor: (Height: 2); }

                                                Group #WpnSpearRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Spear"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnSpearKeywords { Text: "spear, halberd, polearm, trident, glaive"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }

                                                Group { Anchor: (Height: 2); }

                                                Group #WpnCrossbowRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Crossbow"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnCrossbowKeywords { Text: "crossbow"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }

                                                Group { Anchor: (Height: 2); }

                                                Group #WpnHammerRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Hammer"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnHammerKeywords { Text: "hammer"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }

                                                Group { Anchor: (Height: 2); }

                                                Group #WpnShieldRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Shield"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnShieldKeywords { Text: "shield"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }

                                                Group { Anchor: (Height: 2); }

                                                Group #WpnGunsRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Guns"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnGunsKeywords { Text: "gun"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }

                                                Group { Anchor: (Height: 2); }

                                                Group #WpnUnarmedRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 6);
                                                    Label { Text: "Unarmed"; Style: (TextColor: #f4f9ff, FontSize: 13, RenderBold: true); Anchor: (Width: 90); }
                                                    Label #WpnUnarmedKeywords { Text: "fist"; Style: (TextColor: #9ab0ca, FontSize: 11); FlexWeight: 1; }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Group { Anchor: (Width: 40); }

                        // ===========================================================
                        // RIGHT PANEL (300px) - SETTINGS NAVIGATION
                        // ===========================================================
                        $Nav.@ObjectiveContainer {
                            Anchor: (Width: 300, Height: 700);

                            #Title {
                                Label #SettingsNavTitle {
                                    Text: "SETTINGS";
                                    Style: $Nav.@PanelTitleStyle;
                                }
                            }

                            #Content {
                                LayoutMode: Top;
                                Padding: (Horizontal: 12, Bottom: 12);

                                Group {
                                    LayoutMode: Top;
                                    Padding: (Top: 12);

                                    Label {
                                        Text: "SECTIONS";
                                        Padding: (Left: 8, Bottom: 8);
                                        Style: (TextColor: #6e7da1, FontSize: 11, RenderBold: true, RenderUppercase: true, LetterSpacing: 1);
                                    }

                                    @SectionNavButton #NavPlayerSettings {
                                        Text: "Player Settings";
                                    }

                                    Group { Anchor: (Height: 4); }

                                    @SectionNavButton #NavConfigSettings {
                                        Text: "Config Settings";
                                    }
                                }

                                Group { Anchor: (Height: 16); }

                                Group {
                                    Anchor: (Height: 1);
                                    Background: #2b3542;
                                }

                                Group { Anchor: (Height: 16); }

                                Group #SettingsNavInfoArea {
                                    LayoutMode: Top;
                                    Background: #0b141f(0.72);
                                    Padding: (Full: 10);

                                    Label #SettingsNavInfoTitle {
                                        Text: "Player Settings";
                                        Style: (TextColor: #f4f9ff, FontSize: 14, RenderBold: true);
                                    }

                                    Group { Anchor: (Height: 4); }

                                    Label #SettingsNavInfoDesc {
                                        Text: "Manage your personal gameplay preferences including HUD display and notification settings.";
                                        Style: (TextColor: #9ab0ca, FontSize: 11, Wrap: true);
                                    }
                                }

                                Group { FlexWeight: 1; }

                                // ---- Action Buttons ----
                                Group #SettingsActions {
                                    LayoutMode: Top;
                                    Padding: (Bottom: 4);

                                    $C.@TextButton #SaveSettings {
                                        Text: "SAVE";
                                        Anchor: (Height: 36, Width: 276);
                                        Padding: (Horizontal: 8);
                                    }

                                    Group { Anchor: (Height: 8); }

                                    $C.@CancelTextButton #ReloadSettings {
                                        Text: "RELOAD";
                                        Anchor: (Height: 36, Width: 276);
                                        Padding: (Horizontal: 8);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        }

        Group { Anchor: (Height: 14); }

        // ====================== FOOTER NAVBAR (root, disconnected) ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Width: 480, Height: 92);
                $Nav.@BottomNavBar {}
            }
        }
    }
}

$C.@BackButton {}
