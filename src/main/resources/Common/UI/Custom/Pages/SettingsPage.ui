$C = "../Common.ui";
$Nav = "Nav/TopNavBar.ui";

@CustomStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

@SettingValueWidth = 80;
@ToggleButtonWidth = 90;
@CompactToggleWidth = 76;
@CompactValueWidth = 110;

// ---- Config tab button styles ----
@ConfigTabStyle = (
    Default: (
        Background: #0d1926,
        LabelStyle: (FontSize: 12, TextColor: #6e7da1, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
    ),
    Hovered: (
        Background: #162540,
        LabelStyle: (FontSize: 12, TextColor: #c0cee5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
    )
);

@ConfigTabStyleSelected = (
    Default: (
        Background: #142034,
        LabelStyle: (FontSize: 12, TextColor: #6fe3ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
    ),
    Hovered: (
        Background: #1a2d4a,
        LabelStyle: (FontSize: 12, TextColor: #6fe3ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)
    )
);

@ConfigTab = MenuItem {
    Anchor: (Height: 32);
    Padding: (Horizontal: 12, Vertical: 4);
    Style: @ConfigTabStyle;
    SelectedStyle: @ConfigTabStyleSelected;
};

// ---- Section navigation button styles (right panel) ----
@SectionNavStyle = (
    Default: (
        Background: #0b141f(0.88),
        LabelStyle: (FontSize: 15, TextColor: #c0cee5, RenderBold: true, VerticalAlignment: Center)
    ),
    Hovered: (
        Background: #162540,
        LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center)
    )
);

@SectionNavStyleSelected = (
    Default: (
        Background: #142034,
        LabelStyle: (FontSize: 15, TextColor: #6fe3ff, RenderBold: true, VerticalAlignment: Center)
    ),
    Hovered: (
        Background: #1a2d4a,
        LabelStyle: (FontSize: 15, TextColor: #6fe3ff, RenderBold: true, VerticalAlignment: Center)
    )
);

@SectionNavButton = MenuItem {
    Anchor: (Height: 44);
    Padding: (Left: 16, Right: 16);
    Style: @SectionNavStyle;
    SelectedStyle: @SectionNavStyleSelected;
};

// ==========================================================================
// PAGE LAYOUT
// ==========================================================================

$C.@PageOverlay {
    Group {
        // Middle stacks children top-to-bottom but centers the GROUP vertically,
        // so the top navbar / main panels / footer navbar all sit centered on
        // screen instead of pinned to the top.
        LayoutMode: Middle;
        Padding: (Vertical: 12);

        // ====================== TOP NAVBAR (root, disconnected) ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Width: 1280, Height: 92);
                $Nav.@TopNavBar {}
            }
        }

        Group { Anchor: (Height: 14); }

        // ====================== MAIN CONTENT ROW ======================
        Group {
            LayoutMode: Middle;

            Group {
                LayoutMode: Left;
                Anchor: (Width: 1680, Height: 700);

                Group {
                    LayoutMode: Top;
                    Anchor: (Width: 1680, Height: 700);

                    Group {
                        LayoutMode: Middle;
                        Anchor: (Width: 1680);

                        Group {
                            LayoutMode: Left;

                        // ===========================================================
                        // LEFT PANEL (300px) - OVERVIEW
                        // ===========================================================
                        $Nav.@ObjectiveContainer {
                            Anchor: (Width: 300, Height: 700);

                            #Title {
                                Label #OverviewPanelTitle {
                                    Text: "OVERVIEW";
                                    Style: $Nav.@PanelTitleStyle;
                                }
                            }

                            #Content {
                                LayoutMode: Top;
                                Padding: (Horizontal: 12, Bottom: 12);

                                // ---- Player Settings Info (visible by default) ----
                                Group #PlayerSettingsInfoPanel {
                                    LayoutMode: Top;
                                    Padding: (Top: 12);

                                    Group {
                                        LayoutMode: Top;
                                        Background: #0b141f(0.84);
                                        Padding: (Full: 10);

                                        Label {
                                            Text: "PLAYER PREFERENCES";
                                            Style: (TextColor: #6fe3ff, FontSize: 14, RenderBold: true, RenderUppercase: true, LetterSpacing: 1);
                                        }

                                        Group { Anchor: (Height: 6); }

                                        Label {
                                            Text: "Personal display and notification settings for your gameplay experience. These preferences are saved per-player.";
                                            Style: (TextColor: #c0cee5, FontSize: 12, Wrap: true);
                                        }
                                    }

                                    Group { Anchor: (Height: 8); }

                                    Group {
                                        LayoutMode: Top;
                                        Background: #0b141f(0.72);
                                        Padding: (Full: 10);

                                        Label {
                                            Text: "CURRENT STATUS";
                                            Style: (TextColor: #d5e4f7, FontSize: 12, RenderBold: true);
                                        }

                                        Group { Anchor: (Height: 6); }

                                        Group {
                                            LayoutMode: Left;
                                            Padding: (Vertical: 2);
                                            Label { Text: "HUD Display"; Style: (TextColor: #9ab0ca, FontSize: 12); FlexWeight: 1; }
                                            Label #InfoHudStatus { Text: "ON"; Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true); }
                                        }

                                        Group {
                                            LayoutMode: Left;
                                            Padding: (Vertical: 2);
                                            Label { Text: "Race Visuals"; Style: (TextColor: #9ab0ca, FontSize: 12); FlexWeight: 1; }
                                            Label #InfoRaceVisualsStatus { Text: "ON"; Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true); }
                                        }

                                        Group {
                                            LayoutMode: Left;
                                            Padding: (Vertical: 2);
                                            Label { Text: "Active Notifications"; Style: (TextColor: #9ab0ca, FontSize: 12); FlexWeight: 1; }
                                            Label #InfoActiveNotifCount { Text: "6/6"; Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true); }
                                        }
                                    }
                                }

                                // ---- Config Settings Info (hidden by default) ----
                                Group #ConfigSettingsInfoPanel {
                                    LayoutMode: Top;
                                    Padding: (Top: 12);
                                    Visible: false;

                                    Group {
                                        LayoutMode: Top;
                                        Background: #0b141f(0.84);
                                        Padding: (Full: 10);

                                        Label {
                                            Text: "ADMIN CONFIGURATION";
                                            Style: (TextColor: #f0cf78, FontSize: 14, RenderBold: true, RenderUppercase: true, LetterSpacing: 1);
                                        }

                                        Group { Anchor: (Height: 6); }

                                        Label {
                                            Text: "Server-wide settings that affect all players. Requires operator permissions to modify.";
                                            Style: (TextColor: #c0cee5, FontSize: 12, Wrap: true);
                                        }
                                    }

                                    Group { Anchor: (Height: 8); }

                                    Group {
                                        LayoutMode: Top;
                                        Background: #0b141f(0.72);
                                        Padding: (Full: 10);

                                        Label {
                                            Text: "EDITING";
                                            Style: (TextColor: #d5e4f7, FontSize: 12, RenderBold: true);
                                        }

                                        Group { Anchor: (Height: 6); }

                                        Label #ConfigInfoCurrentFile {
                                            Text: "config.yml";
                                            Style: (TextColor: #f0cf78, FontSize: 16, RenderBold: true);
                                        }

                                        Group { Anchor: (Height: 4); }

                                        Label #ConfigInfoDescription {
                                            Text: "Core plugin configuration including races, classes, content sync, and debug settings.";
                                            Style: (TextColor: #9ab0ca, FontSize: 11, Wrap: true);
                                        }
                                    }

                                    Group { Anchor: (Height: 8); }

                                    Group {
                                        LayoutMode: Top;
                                        Background: #0d1520(0.60);
                                        Padding: (Full: 10);

                                        Label {
                                            Text: "Changes take effect after saving. Some settings may require a server restart.";
                                            Style: (TextColor: #8a6e3c, FontSize: 11, Wrap: true);
                                        }
                                    }

                                    Group { Anchor: (Height: 8); }

                                    // ---- CONTENT SYNC (overview) ----
                                    Group {
                                        LayoutMode: Top;
                                        Background: #0b141f(0.84);
                                        Padding: (Horizontal: 6, Vertical: 6);

                                        Group {
                                            LayoutMode: Left;
                                            Padding: (Bottom: 6, Top: 2);
                                            Group { Anchor: (Width: 3, Height: 14); Background: #9b7edb; }
                                            Group { Anchor: (Width: 6); }
                                            Label { Text: "CONTENT SYNC"; Style: (TextColor: #9b7edb, FontSize: 11, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                        }

                                        Group #CfgForceConfigRow {
                                            LayoutMode: Left;
                                            Background: #0b141f(0.72);
                                            Padding: (Horizontal: 8, Vertical: 5);
                                            Label { Text: "Force Builtin Config"; Style: (TextColor: #d5e4f7, FontSize: 11, Wrap: true); FlexWeight: 1; }
                                            Label #CfgForceConfigValue { Text: "true"; Anchor: (Width: 46, Height: 20); Padding: (Horizontal: 4, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 10, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                            Group { Anchor: (Width: 4); }
                                            $C.@TextButton #CfgForceConfigToggle { Anchor: (Height: 22, Width: 60); Padding: (Horizontal: 4, Vertical: 2); Text: "Toggle"; Style: @CustomStyle; }
                                        }

                                        Group { Anchor: (Height: 2); }

                                        Group #CfgForceLevelingRow {
                                            LayoutMode: Left;
                                            Background: #0b141f(0.72);
                                            Padding: (Horizontal: 8, Vertical: 5);
                                            Label { Text: "Force Builtin Leveling"; Style: (TextColor: #d5e4f7, FontSize: 11, Wrap: true); FlexWeight: 1; }
                                            Label #CfgForceLevelingValue { Text: "true"; Anchor: (Width: 46, Height: 20); Padding: (Horizontal: 4, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 10, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                            Group { Anchor: (Width: 4); }
                                            $C.@TextButton #CfgForceLevelingToggle { Anchor: (Height: 22, Width: 60); Padding: (Horizontal: 4, Vertical: 2); Text: "Toggle"; Style: @CustomStyle; }
                                        }

                                        Group { Anchor: (Height: 2); }

                                        Group #CfgForceEventsRow {
                                            LayoutMode: Left;
                                            Background: #0b141f(0.72);
                                            Padding: (Horizontal: 8, Vertical: 5);
                                            Label { Text: "Force Builtin Events"; Style: (TextColor: #d5e4f7, FontSize: 11, Wrap: true); FlexWeight: 1; }
                                            Label #CfgForceEventsValue { Text: "false"; Anchor: (Width: 46, Height: 20); Padding: (Horizontal: 4, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 10, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                            Group { Anchor: (Width: 4); }
                                            $C.@TextButton #CfgForceEventsToggle { Anchor: (Height: 22, Width: 60); Padding: (Horizontal: 4, Vertical: 2); Text: "Toggle"; Style: @CustomStyle; }
                                        }

                                        Group { Anchor: (Height: 2); }

                                        Group #CfgForceRacesRow {
                                            LayoutMode: Left;
                                            Background: #0b141f(0.72);
                                            Padding: (Horizontal: 8, Vertical: 5);
                                            Label { Text: "Force Builtin Races"; Style: (TextColor: #d5e4f7, FontSize: 11, Wrap: true); FlexWeight: 1; }
                                            Label #CfgForceRacesValue { Text: "true"; Anchor: (Width: 46, Height: 20); Padding: (Horizontal: 4, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 10, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                            Group { Anchor: (Width: 4); }
                                            $C.@TextButton #CfgForceRacesToggle { Anchor: (Height: 22, Width: 60); Padding: (Horizontal: 4, Vertical: 2); Text: "Toggle"; Style: @CustomStyle; }
                                        }

                                        Group { Anchor: (Height: 2); }

                                        Group #CfgForceClassesRow {
                                            LayoutMode: Left;
                                            Background: #0b141f(0.72);
                                            Padding: (Horizontal: 8, Vertical: 5);
                                            Label { Text: "Force Builtin Classes"; Style: (TextColor: #d5e4f7, FontSize: 11, Wrap: true); FlexWeight: 1; }
                                            Label #CfgForceClassesValue { Text: "true"; Anchor: (Width: 46, Height: 20); Padding: (Horizontal: 4, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 10, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                            Group { Anchor: (Width: 4); }
                                            $C.@TextButton #CfgForceClassesToggle { Anchor: (Height: 22, Width: 60); Padding: (Horizontal: 4, Vertical: 2); Text: "Toggle"; Style: @CustomStyle; }
                                        }

                                        Group { Anchor: (Height: 2); }

                                        Group #CfgForceAugmentsRow {
                                            LayoutMode: Left;
                                            Background: #0b141f(0.72);
                                            Padding: (Horizontal: 8, Vertical: 5);
                                            Label { Text: "Force Builtin Augments"; Style: (TextColor: #d5e4f7, FontSize: 11, Wrap: true); FlexWeight: 1; }
                                            Label #CfgForceAugmentsValue { Text: "true"; Anchor: (Width: 46, Height: 20); Padding: (Horizontal: 4, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 10, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                            Group { Anchor: (Width: 4); }
                                            $C.@TextButton #CfgForceAugmentsToggle { Anchor: (Height: 22, Width: 60); Padding: (Horizontal: 4, Vertical: 2); Text: "Toggle"; Style: @CustomStyle; }
                                        }

                                        Group { Anchor: (Height: 2); }

                                        Group #CfgForceLanguagesRow {
                                            LayoutMode: Left;
                                            Background: #0b141f(0.72);
                                            Padding: (Horizontal: 8, Vertical: 5);
                                            Label { Text: "Force Builtin Languages"; Style: (TextColor: #d5e4f7, FontSize: 11, Wrap: true); FlexWeight: 1; }
                                            Label #CfgForceLanguagesValue { Text: "true"; Anchor: (Width: 46, Height: 20); Padding: (Horizontal: 4, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 10, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                            Group { Anchor: (Width: 4); }
                                            $C.@TextButton #CfgForceLanguagesToggle { Anchor: (Height: 22, Width: 60); Padding: (Horizontal: 4, Vertical: 2); Text: "Toggle"; Style: @CustomStyle; }
                                        }

                                        Group { Anchor: (Height: 2); }

                                        Group #CfgForceWorldSettingsRow {
                                            LayoutMode: Left;
                                            Background: #0b141f(0.72);
                                            Padding: (Horizontal: 8, Vertical: 5);
                                            Label { Text: "Force Builtin World Settings"; Style: (TextColor: #d5e4f7, FontSize: 11, Wrap: true); FlexWeight: 1; }
                                            Label #CfgForceWorldSettingsValue { Text: "true"; Anchor: (Width: 46, Height: 20); Padding: (Horizontal: 4, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 10, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                            Group { Anchor: (Width: 4); }
                                            $C.@TextButton #CfgForceWorldSettingsToggle { Anchor: (Height: 22, Width: 60); Padding: (Horizontal: 4, Vertical: 2); Text: "Toggle"; Style: @CustomStyle; }
                                        }
                                    }
                                }
                            }
                        }

                        Group { Anchor: (Width: 40); }

                        // ===========================================================
                        // CENTER PANEL (1000px) - MAIN CONTENT
                        // ===========================================================
                        $Nav.@ObjectiveContainer {
                            Anchor: (Width: 1000, Height: 700);

                            #Title {
                                Label #SettingsTitle {
                                    Text: "ENDLESS LEVELING";
                                    Style: $Nav.@PanelTitleStyle;
                                }
                            }

                            #Content {
                                LayoutMode: Left;
                                Padding: (Full: 0);

                                // ================= CONTENT AREA =================
                                Group #RightPanel {
                                    FlexWeight: 1;
                                    LayoutMode: Top;

                                    // =============================================
                                    // PLAYER SETTINGS VIEW
                                    // =============================================
                                    Group #PlayerSettingsPanel {
                                        LayoutMode: Top;
                                        FlexWeight: 1;

                                        // ---- Header ----
                                        Group #PlayerSettingsHeader {
                                            LayoutMode: Left;
                                            Anchor: (Height: 50);
                                            Padding: (Horizontal: 16, Vertical: 10);

                                            Label #SettingsTitleLabel {
                                                Text: "Player Settings";
                                                Style: (FontSize: 20, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                                            }

                                            Group { FlexWeight: 1; }

                                            Group {
                                                LayoutMode: Left;
                                                Background: #0b141f(0.92);
                                                Anchor: (Height: 32);
                                                Padding: (Horizontal: 10, Vertical: 6);

                                                Label #SettingsIntroText {
                                                    Style: (TextColor: #aaccff, FontSize: 12, VerticalAlignment: Center);
                                                    Text: "Personal HUD, notifications, and visual preferences.";
                                                }
                                            }
                                        }

                                        Group { Anchor: (Height: 1); Background: #2b3542; }

                                        // ---- Scrollable Settings ----
                                        Group #PlayerSettingsMain {
                                            LayoutMode: TopScrolling;
                                            ScrollbarStyle: $C.@DefaultScrollbarStyle;
                                            FlexWeight: 1;
                                            Padding: (Full: 16);

                                            Group #PlayerSettingsList {
                                                LayoutMode: Top;

                                                // ======== DISPLAY SECTION ========
                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 8);

                                                    Group { Anchor: (Width: 3, Height: 18); Background: #6fe3ff; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "DISPLAY"; Style: (TextColor: #6fe3ff, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                // -- Player HUD --
                                                Group #PlayerHudRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.84);
                                                    Padding: (Full: 0);

                                                    Group { Anchor: (Width: 3); Background: #6fe3ff(0.40); }

                                                    Group {
                                                        LayoutMode: Left;
                                                        FlexWeight: 1;
                                                        Padding: (Full: 12);

                                                        Group {
                                                            LayoutMode: Top;
                                                            FlexWeight: 1;

                                                            Group {
                                                                LayoutMode: Left;

                                                                Label #PlayerHudLabel { Style: (TextColor: #f4f9ff, FontSize: 15, RenderBold: true); FlexWeight: 1; Text: "Player HUD"; }

                                                                Label #PlayerHudValue {
                                                                    Text: "ON";
                                                                    Anchor: (Width: @SettingValueWidth, Height: 24);
                                                                    Padding: (Horizontal: 8, Vertical: 4);
                                                                    Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                                                    Background: #061420;
                                                                }
                                                            }

                                                            Group { Anchor: (Height: 4); }

                                                            Label #PlayerHudDescription {
                                                                Text: "Show or hide the Endless Leveling HUD overlay.";
                                                                Style: (TextColor: #c0cee5, FontSize: 12);
                                                            }
                                                        }

                                                        Group { Anchor: (Width: 12); }

                                                        $C.@TextButton #PlayerHudToggle {
                                                            Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                                            Padding: (Horizontal: 8, Vertical: 4);
                                                            Text: "Toggle";
                                                            Style: @CustomStyle;
                                                        }
                                                    }
                                                }

                                                Group { Anchor: (Height: 6); }

                                                // -- Race Model Visuals --
                                                Group #RaceModelRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.84);
                                                    Padding: (Full: 0);

                                                    Group { Anchor: (Width: 3); Background: #6fe3ff(0.40); }

                                                    Group {
                                                        LayoutMode: Left;
                                                        FlexWeight: 1;
                                                        Padding: (Full: 12);

                                                        Group {
                                                            LayoutMode: Top;
                                                            FlexWeight: 1;

                                                            Group {
                                                                LayoutMode: Left;

                                                                Label #RaceModelLabel { Style: (TextColor: #f4f9ff, FontSize: 15, RenderBold: true); FlexWeight: 1; Text: "Race Model Visuals"; }

                                                                Label #RaceModelValue {
                                                                    Text: "ON";
                                                                    Anchor: (Width: @SettingValueWidth, Height: 24);
                                                                    Padding: (Horizontal: 8, Vertical: 4);
                                                                    Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                                                    Background: #061420;
                                                                }
                                                            }

                                                            Group { Anchor: (Height: 4); }

                                                            Label #RaceModelDescription {
                                                                Text: "Enable race-specific character visuals when available.";
                                                                Style: (TextColor: #c0cee5, FontSize: 12);
                                                            }
                                                        }

                                                        Group { Anchor: (Width: 12); }

                                                        $C.@TextButton #RaceModelToggle {
                                                            Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                                            Padding: (Horizontal: 8, Vertical: 4);
                                                            Text: "Toggle";
                                                            Style: @CustomStyle;
                                                        }
                                                    }
                                                }

                                                Group { Anchor: (Height: 16); }

                                                // ======== NOTIFICATIONS SECTION ========
                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 8);

                                                    Group { Anchor: (Width: 3, Height: 18); Background: #f0cf78; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "NOTIFICATIONS"; Style: (TextColor: #f0cf78, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                // -- Critical Hit Notifications --
                                                Group #CriticalNotifRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.84);
                                                    Padding: (Full: 0);

                                                    Group { Anchor: (Width: 3); Background: #f0cf78(0.40); }

                                                    Group {
                                                        LayoutMode: Left;
                                                        FlexWeight: 1;
                                                        Padding: (Full: 12);

                                                        Group {
                                                            LayoutMode: Top;
                                                            FlexWeight: 1;

                                                            Group {
                                                                LayoutMode: Left;

                                                                Label #CriticalNotifLabel { Style: (TextColor: #f4f9ff, FontSize: 15, RenderBold: true); FlexWeight: 1; Text: "Critical Hit Notifications"; }

                                                                Label #CriticalNotifValue {
                                                                    Text: "ON";
                                                                    Anchor: (Width: @SettingValueWidth, Height: 24);
                                                                    Padding: (Horizontal: 8, Vertical: 4);
                                                                    Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                                                    Background: #061420;
                                                                }
                                                            }

                                                            Group { Anchor: (Height: 4); }

                                                            Label #CriticalNotifDescription {
                                                                Text: "Toggle floating alerts for critical strike events.";
                                                                Style: (TextColor: #c0cee5, FontSize: 12);
                                                            }
                                                        }

                                                        Group { Anchor: (Width: 12); }

                                                        $C.@TextButton #CriticalNotifToggle {
                                                            Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                                            Padding: (Horizontal: 8, Vertical: 4);
                                                            Text: "Toggle";
                                                            Style: @CustomStyle;
                                                        }
                                                    }
                                                }

                                                Group { Anchor: (Height: 6); }

                                                // -- XP Gain Notifications --
                                                Group #XpNotifRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.84);
                                                    Padding: (Full: 0);

                                                    Group { Anchor: (Width: 3); Background: #f0cf78(0.40); }

                                                    Group {
                                                        LayoutMode: Left;
                                                        FlexWeight: 1;
                                                        Padding: (Full: 12);

                                                        Group {
                                                            LayoutMode: Top;
                                                            FlexWeight: 1;

                                                            Group {
                                                                LayoutMode: Left;

                                                                Label #XpNotifLabel { Style: (TextColor: #f4f9ff, FontSize: 15, RenderBold: true); FlexWeight: 1; Text: "XP Gain Notifications"; }

                                                                Label #XpNotifValue {
                                                                    Text: "ON";
                                                                    Anchor: (Width: @SettingValueWidth, Height: 24);
                                                                    Padding: (Horizontal: 8, Vertical: 4);
                                                                    Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                                                    Background: #061420;
                                                                }
                                                            }

                                                            Group { Anchor: (Height: 4); }

                                                            Label #XpNotifDescription {
                                                                Text: "Show notifications whenever you gain experience.";
                                                                Style: (TextColor: #c0cee5, FontSize: 12);
                                                            }
                                                        }

                                                        Group { Anchor: (Width: 12); }

                                                        $C.@TextButton #XpNotifToggle {
                                                            Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                                            Padding: (Horizontal: 8, Vertical: 4);
                                                            Text: "Toggle";
                                                            Style: @CustomStyle;
                                                        }
                                                    }
                                                }

                                                Group { Anchor: (Height: 6); }

                                                // -- Passive Level-Up Notifications --
                                                Group #PassiveLevelUpNotifRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.84);
                                                    Padding: (Full: 0);

                                                    Group { Anchor: (Width: 3); Background: #f0cf78(0.40); }

                                                    Group {
                                                        LayoutMode: Left;
                                                        FlexWeight: 1;
                                                        Padding: (Full: 12);

                                                        Group {
                                                            LayoutMode: Top;
                                                            FlexWeight: 1;

                                                            Group {
                                                                LayoutMode: Left;

                                                                Label #PassiveLevelUpNotifLabel { Style: (TextColor: #f4f9ff, FontSize: 15, RenderBold: true); FlexWeight: 1; Text: "Passive Level-Up Notifications"; }

                                                                Label #PassiveLevelUpNotifValue {
                                                                    Text: "ON";
                                                                    Anchor: (Width: @SettingValueWidth, Height: 24);
                                                                    Padding: (Horizontal: 8, Vertical: 4);
                                                                    Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                                                    Background: #061420;
                                                                }
                                                            }

                                                            Group { Anchor: (Height: 4); }

                                                            Label #PassiveLevelUpNotifDescription {
                                                                Text: "Display updates when passives rank up during play.";
                                                                Style: (TextColor: #c0cee5, FontSize: 12);
                                                            }
                                                        }

                                                        Group { Anchor: (Width: 12); }

                                                        $C.@TextButton #PassiveLevelUpNotifToggle {
                                                            Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                                            Padding: (Horizontal: 8, Vertical: 4);
                                                            Text: "Toggle";
                                                            Style: @CustomStyle;
                                                        }
                                                    }
                                                }

                                                Group { Anchor: (Height: 6); }

                                                // -- Luck Double-Drop Notifications --
                                                Group #LuckDoubleDropsNotifRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.84);
                                                    Padding: (Full: 0);

                                                    Group { Anchor: (Width: 3); Background: #f0cf78(0.40); }

                                                    Group {
                                                        LayoutMode: Left;
                                                        FlexWeight: 1;
                                                        Padding: (Full: 12);

                                                        Group {
                                                            LayoutMode: Top;
                                                            FlexWeight: 1;

                                                            Group {
                                                                LayoutMode: Left;

                                                                Label #LuckDoubleDropsNotifLabel { Style: (TextColor: #f4f9ff, FontSize: 15, RenderBold: true); FlexWeight: 1; Text: "Luck Double-Drop Notifications"; }

                                                                Label #LuckDoubleDropsNotifValue {
                                                                    Text: "ON";
                                                                    Anchor: (Width: @SettingValueWidth, Height: 24);
                                                                    Padding: (Horizontal: 8, Vertical: 4);
                                                                    Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                                                    Background: #061420;
                                                                }
                                                            }

                                                            Group { Anchor: (Height: 4); }

                                                            Label #LuckDoubleDropsNotifDescription {
                                                                Text: "Toggle bonus drop proc notifications from luck effects.";
                                                                Style: (TextColor: #c0cee5, FontSize: 12);
                                                            }
                                                        }

                                                        Group { Anchor: (Width: 12); }

                                                        $C.@TextButton #LuckDoubleDropsNotifToggle {
                                                            Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                                            Padding: (Horizontal: 8, Vertical: 4);
                                                            Text: "Toggle";
                                                            Style: @CustomStyle;
                                                        }
                                                    }
                                                }

                                                Group { Anchor: (Height: 6); }

                                                // -- Health Regen Notifications --
                                                Group #HealthRegenNotifRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.84);
                                                    Padding: (Full: 0);

                                                    Group { Anchor: (Width: 3); Background: #f0cf78(0.40); }

                                                    Group {
                                                        LayoutMode: Left;
                                                        FlexWeight: 1;
                                                        Padding: (Full: 12);

                                                        Group {
                                                            LayoutMode: Top;
                                                            FlexWeight: 1;

                                                            Group {
                                                                LayoutMode: Left;

                                                                Label #HealthRegenNotifLabel { Style: (TextColor: #f4f9ff, FontSize: 15, RenderBold: true); FlexWeight: 1; Text: "Health Regen Notifications"; }

                                                                Label #HealthRegenNotifValue {
                                                                    Text: "ON";
                                                                    Anchor: (Width: @SettingValueWidth, Height: 24);
                                                                    Padding: (Horizontal: 8, Vertical: 4);
                                                                    Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                                                    Background: #061420;
                                                                }
                                                            }

                                                            Group { Anchor: (Height: 4); }

                                                            Label #HealthRegenNotifDescription {
                                                                Text: "Show notifications when health regeneration triggers.";
                                                                Style: (TextColor: #c0cee5, FontSize: 12);
                                                            }
                                                        }

                                                        Group { Anchor: (Width: 12); }

                                                        $C.@TextButton #HealthRegenNotifToggle {
                                                            Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                                            Padding: (Horizontal: 8, Vertical: 4);
                                                            Text: "Toggle";
                                                            Style: @CustomStyle;
                                                        }
                                                    }
                                                }

                                                Group { Anchor: (Height: 6); }

                                                // -- Augment Notifications --
                                                Group #AugmentNotifRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.84);
                                                    Padding: (Full: 0);

                                                    Group { Anchor: (Width: 3); Background: #f0cf78(0.40); }

                                                    Group {
                                                        LayoutMode: Left;
                                                        FlexWeight: 1;
                                                        Padding: (Full: 12);

                                                        Group {
                                                            LayoutMode: Top;
                                                            FlexWeight: 1;

                                                            Group {
                                                                LayoutMode: Left;

                                                                Label #AugmentNotifLabel { Style: (TextColor: #f4f9ff, FontSize: 15, RenderBold: true); FlexWeight: 1; Text: "Augment Notifications"; }

                                                                Label #AugmentNotifValue {
                                                                    Text: "ON";
                                                                    Anchor: (Width: @SettingValueWidth, Height: 24);
                                                                    Padding: (Horizontal: 8, Vertical: 4);
                                                                    Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                                                    Background: #061420;
                                                                }
                                                            }

                                                            Group { Anchor: (Height: 4); }

                                                            Label #AugmentNotifDescription {
                                                                Text: "Toggle chat notifications for augment status events.";
                                                                Style: (TextColor: #c0cee5, FontSize: 12);
                                                            }
                                                        }

                                                        Group { Anchor: (Width: 12); }

                                                        $C.@TextButton #AugmentNotifToggle {
                                                            Anchor: (Height: 32, Width: @ToggleButtonWidth);
                                                            Padding: (Horizontal: 8, Vertical: 4);
                                                            Text: "Toggle";
                                                            Style: @CustomStyle;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    // =============================================
                                    // CONFIG SETTINGS VIEW
                                    // =============================================
                                    Group #ConfigSettingsPanel {
                                        LayoutMode: Top;
                                        FlexWeight: 1;
                                        Visible: false;

                                        // ---- Header ----
                                        Group #ConfigSettingsHeader {
                                            LayoutMode: Left;
                                            Anchor: (Height: 50);
                                            Padding: (Horizontal: 16, Vertical: 10);

                                            Label {
                                                Text: "Config Settings";
                                                Style: (FontSize: 20, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                                            }

                                            Group { FlexWeight: 1; }

                                            Group {
                                                LayoutMode: Left;
                                                Background: #0b141f(0.92);
                                                Anchor: (Height: 32);
                                                Padding: (Horizontal: 10, Vertical: 6);

                                                Label {
                                                    Style: (TextColor: #f0cf78, FontSize: 12, VerticalAlignment: Center);
                                                    Text: "Admin-only server configuration.";
                                                }
                                            }
                                        }

                                        // ---- Tab Bar ----
                                        Group #ConfigTabBar {
                                            LayoutMode: Left;
                                            Background: #070b12;
                                            Padding: (Horizontal: 12, Vertical: 6);

                                            @ConfigTab #TabConfigYml { Text: "config.yml"; }
                                            Group { Anchor: (Width: 4); }
                                            @ConfigTab #TabLevelingYml { Text: "leveling.yml"; }
                                            Group { Anchor: (Width: 4); }
                                            @ConfigTab #TabWorldSettings { Text: "world-settings"; }
                                            Group { Anchor: (Width: 4); }
                                            @ConfigTab #TabEventsYml { Text: "events.yml"; }
                                            Group { Anchor: (Width: 4); }
                                            @ConfigTab #TabWeaponsJson { Text: "weapons.json"; }
                                        }

                                        Group { Anchor: (Height: 1); Background: #2b3542; }

                                        // ---- Tab Content ----
                                        Group #ConfigTabContent {
                                            LayoutMode: TopScrolling;
                                            ScrollbarStyle: $C.@DefaultScrollbarStyle;
                                            FlexWeight: 1;
                                            Padding: (Full: 16);

                                            // ================================================
                                            // CONFIG.YML TAB
                                            // ================================================
                                            Group #ConfigYmlPanel {
                                                LayoutMode: Top;

                                                // ---- RACE SYSTEM ----
                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 6, Top: 4);
                                                    Group { Anchor: (Width: 3, Height: 16); Background: #f0cf78; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "RACE SYSTEM"; Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                Group #CfgEnableRacesRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgEnableRacesLabel { Text: "Enable Races"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgEnableRacesValue { Text: "true"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #CfgEnableRacesToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgDefaultRaceRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgDefaultRaceLabel { Text: "Default Race"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgDefaultRaceValue { Text: "Human"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgRaceCooldownRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgRaceCooldownLabel { Text: "Race Cooldown (s)"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    NumberField #CfgRaceCooldownInput { Value: 3600; Anchor: (Width: @CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgRaceMaxSwitchesRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgRaceMaxSwitchesLabel { Text: "Max Race Switches"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    NumberField #CfgRaceMaxSwitchesInput { Value: 1; Anchor: (Width: @CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgGlobalRaceVisualsRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgGlobalRaceVisualsLabel { Text: "Global Race Visuals"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgGlobalRaceVisualsValue { Text: "off"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #CfgGlobalRaceVisualsCycle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Cycle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 12); }

                                                // ---- CLASS SYSTEM ----
                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 6, Top: 4);
                                                    Group { Anchor: (Width: 3, Height: 16); Background: #f0cf78; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "CLASS SYSTEM"; Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                Group #CfgEnableClassesRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgEnableClassesLabel { Text: "Enable Classes"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgEnableClassesValue { Text: "true"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #CfgEnableClassesToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgEnableSecondaryClassRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgEnableSecondaryClassLabel { Text: "Enable Secondary Class"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgEnableSecondaryClassValue { Text: "true"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #CfgEnableSecondaryClassToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgDefaultPrimaryClassRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgDefaultPrimaryClassLabel { Text: "Default Primary Class"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgDefaultPrimaryClassValue { Text: "Adventurer"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgOffClassPenaltyRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgOffClassPenaltyLabel { Text: "Off-Class Damage Penalty"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgOffClassPenaltyValue { Text: "-40%"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #ff7878, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgClassCooldownRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgClassCooldownLabel { Text: "Class Cooldown (s)"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    NumberField #CfgClassCooldownInput { Value: 1800; Anchor: (Width: @CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgClassMaxSwitchesRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgClassMaxSwitchesLabel { Text: "Max Class Switches"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    NumberField #CfgClassMaxSwitchesInput { Value: 1; Anchor: (Width: @CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
                                                }

                                                Group { Anchor: (Height: 12); }

                                                // ---- SWAP ANTI-EXPLOIT ----
                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 6, Top: 4);
                                                    Group { Anchor: (Width: 3, Height: 16); Background: #ff7878; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "SWAP ANTI-EXPLOIT"; Style: (TextColor: #ff7878, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                Group #CfgSwapConsumeEnabledRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgSwapConsumeEnabledLabel { Text: "Auto-Consume at Level"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgSwapConsumeEnabledValue { Text: "true"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #CfgSwapConsumeEnabledToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgSwapConsumeThresholdRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgSwapConsumeThresholdLabel { Text: "Consume Threshold Level"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    NumberField #CfgSwapConsumeThresholdInput { Value: 20; Anchor: (Width: @CompactValueWidth, Height: 22); Style: (FontSize: 12, TextColor: #cddcf0); Padding: (Left: 6); Background: $C.@InputBoxBackground; }
                                                }

                                                Group { Anchor: (Height: 12); }

                                                // ---- LANGUAGE ----
                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 6, Top: 4);
                                                    Group { Anchor: (Width: 3, Height: 16); Background: #b0c4de; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "LANGUAGE"; Style: (TextColor: #b0c4de, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                Group #CfgLocaleRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgLocaleLabel { Text: "Locale"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgLocaleValue { Text: "en_US"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgFallbackLocaleRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label #CfgFallbackLocaleLabel { Text: "Fallback Locale"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgFallbackLocaleValue { Text: "en_US"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #f0cf78, FontSize: 12, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                }

                                                Group { Anchor: (Height: 12); }

                                                // ---- BUILTIN CONTENT ----
                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 6, Top: 4);
                                                    Group { Anchor: (Width: 3, Height: 16); Background: #6fe3ff; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "BUILTIN CONTENT"; Style: (TextColor: #6fe3ff, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                Group #CfgEnableBuiltinRacesRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label { Text: "Enable Builtin Races"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgEnableBuiltinRacesValue { Text: "true"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #CfgEnableBuiltinRacesToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgEnableBuiltinClassesRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label { Text: "Enable Builtin Classes"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgEnableBuiltinClassesValue { Text: "true"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #CfgEnableBuiltinClassesToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 3); }

                                                Group #CfgEnableBuiltinAugmentsRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label { Text: "Enable Builtin Augments"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgEnableBuiltinAugmentsValue { Text: "true"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
                                                    $C.@TextButton #CfgEnableBuiltinAugmentsToggle { Anchor: (Height: 26, Width: @CompactToggleWidth); Padding: (Horizontal: 6, Vertical: 3); Text: "Toggle"; Style: @CustomStyle; }
                                                }

                                                Group { Anchor: (Height: 12); }

                                                // ---- DEBUG ----
                                                Group {
                                                    LayoutMode: Left;
                                                    Padding: (Bottom: 6, Top: 4);
                                                    Group { Anchor: (Width: 3, Height: 16); Background: #7a8a9e; }
                                                    Group { Anchor: (Width: 8); }
                                                    Label { Text: "DEBUG"; Style: (TextColor: #7a8a9e, FontSize: 12, RenderBold: true, RenderUppercase: true, LetterSpacing: 1); }
                                                }

                                                Group #CfgEnableLoggingRow {
                                                    LayoutMode: Left;
                                                    Background: #0b141f(0.72);
                                                    Padding: (Horizontal: 10, Vertical: 7);
                                                    Label { Text: "Enable Logging"; Style: (TextColor: #d5e4f7, FontSize: 13); FlexWeight: 1; }
                                                    Label #CfgEnableLoggingValue { Text: "false"; Anchor: (Width: @CompactValueWidth, Height: 22); Padding: (Horizontal: 6, Vertical: 2); Style: (TextColor: #6fe3ff, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Background: #061420; }
                                                    Group { Anchor: (Width: 6); }
