Group {
    LayoutMode: Top;
    Anchor: (Bottom: 4);

    Group {
        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
        Background: (TexturePath: "../../Tiles/TileDefault2x.png", Border: 16, Color: #1a2538);
    }

    Group {
        LayoutMode: Top;
        Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);

        Label #PassiveName {
            Style: (FontSize: 11, TextColor: #e5c68a, RenderBold: true, Wrap: true);
            Text: "Race Passive";
        }

        Group { Anchor: (Height: 2); }

        Label #PassiveValue {
            Style: (FontSize: 10, TextColor: #ffc300, RenderBold: true, Wrap: true);
            Text: "+0";
        }
    }
}
