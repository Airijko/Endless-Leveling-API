Group {
    LayoutMode: Top;
    Group {
        LayoutMode: Top;
        Background: (TexturePath: "../../Tiles/TileDefault2x.png");
        Padding: (Left: 10, Right: 10, Top: 5, Bottom: 5);

        Label #PassiveName {
            Style: (FontSize: 12, TextColor: #e5c68a, RenderBold: true, Wrap: true);
            Text: "Race Passive";
        }

        Group { Anchor: (Height: 4); }

        Label #PassiveValue {
            Style: (FontSize: 11, TextColor: #ffc300, RenderBold: true, Wrap: true);
            Text: "+0";
        }
    }

    Group { Anchor: (Height: 6); }
}
