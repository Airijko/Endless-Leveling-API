$C = "../../Common.ui";
$Nav = "../Nav/TopNavBar.ui";

$C.@PageOverlay {
    Group {
        // Middle stacks children top-to-bottom but centers the GROUP vertically,
        // so the top navbar / main panels / footer navbar all sit centered on
        // screen instead of pinned to the top.
        LayoutMode: Middle;
        Padding: (Vertical: 12);

        // ====================== TOP NAVBAR (root, disconnected) ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Width: 1280, Height: 92);
                $Nav.@TopNavBar {}
            }
        }

        Group { Anchor: (Height: 14); }

        // ====================== MAIN CONTENT ROW ======================
        Group {
            LayoutMode: Middle;

            Group {
                LayoutMode: Left;
                Anchor: (Width: 1680, Height: 700);

                Group {
                    LayoutMode: Top;
                    Anchor: (Width: 1680, Height: 700);

                    Group {
                        LayoutMode: Middle;
                        Anchor: (Width: 1680);

                        Group {
                            LayoutMode: Left;

                            Group { Anchor: (Width: 340); }

                            $Nav.@ObjectiveContainer {
                            Anchor: (Width: 1000, Height: 700);
                            #Title {
                                Label #ProfileTitle {
                                    Text: "ENDLESS LEVELING";
                                    Style: $Nav.@PanelTitleStyle;
                                }
                            }

                            #Content {
                                LayoutMode: Left;
                                Padding: (Full: 0);

                                // ---------------- MAIN PANEL ----------------
                                Group #RightPanel {
                                    FlexWeight: 1;
                                    LayoutMode: Top;

                                    Group #ProfileContent {
                                        LayoutMode: Left;
                                        FlexWeight: 1;
                                        Padding: (Full: 12);

                                        Group #ProfileDetailPanel {
                                            LayoutMode: Top;
                                            FlexWeight: 1;

                                            // ===== XP EXPERIENCE HEADER =====
                                            Group {
                                                LayoutMode: Middle;
                                                Anchor: (Height: 60);
                                                Background: #050910(0.85);
                                                Padding: (Full: 16);

                                                Group #DetailXpBar {
                                                    FlexWeight: 1;
                                                    Background: "Partner_XPBackground.png";

                                                    ProgressBar #DetailProgressBar {
                                                        FlexWeight: 1;
                                                        BarTexturePath: "Partner_XPFill.png";
                                                    }
                                                }
                                            }

                                            Group { Anchor: (Height: 8); }

                                            // ===== STATS SUMMARY =====
                                            Group #DetailSummary {
                                                LayoutMode: Left;
                                                Background: #060d19(0.92);
                                                Padding: (Horizontal: 14, Vertical: 12);

                                                // Prestige accent strip
                                                Group {
                                                    Anchor: (Width: 3, Top: 0, Bottom: 0);
                                                    Background: #b084e0;
                                                }
                                                Group { Anchor: (Width: 10); }

                                                Group {
                                                    LayoutMode: Top;
                                                    Anchor: (Width: 82);

                                                    Label {
                                                        Text: "PRESTIGE";
                                                        Style: (FontSize: 10, TextColor: #6a5a8a, RenderBold: true, LetterSpacing: 1);
                                                        Anchor: (Height: 12);
                                                    }
                                                    Label #DetailPrestigeValue {
                                                        Text: "--";
                                                        Style: (FontSize: 18, TextColor: #b084e0, RenderBold: true);
                                                        Anchor: (Height: 22);
                                                    }
                                                }

                                                Group { Anchor: (Width: 1, Top: 6, Bottom: 6); Background: #ffffff(0.07); }
                                                Group { Anchor: (Width: 12); }

                                                Group {
                                                    LayoutMode: Top;
                                                    Anchor: (Width: 70);

                                                    Label {
                                                        Text: "LEVEL";
                                                        Style: (FontSize: 10, TextColor: #4a7090, RenderBold: true, LetterSpacing: 1);
                                                        Anchor: (Height: 12);
                                                    }
                                                    Label #DetailLevelValue {
                                                        Text: "--";
                                                        Style: (FontSize: 18, TextColor: #7ec8f5, RenderBold: true);
                                                        Anchor: (Height: 22);
                                                    }
                                                }

                                                Group { Anchor: (Width: 1, Top: 6, Bottom: 6); Background: #ffffff(0.07); }
                                                Group { Anchor: (Width: 12); }

                                                Group {
                                                    LayoutMode: Top;
                                                    Anchor: (Width: 120);

                                                    Label {
                                                        Text: "CURRENT XP";
                                                        Style: (FontSize: 10, TextColor: #4a7090, RenderBold: true, LetterSpacing: 1);
                                                        Anchor: (Height: 12);
                                                    }
                                                    Label #DetailXpValue {
                                                        Text: "--";
                                                        Style: (FontSize: 18, TextColor: #9ad4ff, RenderBold: true);
                                                        Anchor: (Height: 22);
                                                    }
                                                }

                                                Group { Anchor: (Width: 1, Top: 6, Bottom: 6); Background: #ffffff(0.07); }
                                                Group { Anchor: (Width: 12); }

                                                Group {
                                                    LayoutMode: Top;
                                                    Anchor: (Width: 100);

                                                    Label {
                                                        Text: "RACE";
                                                        Style: (FontSize: 10, TextColor: #4a7090, RenderBold: true, LetterSpacing: 1);
                                                        Anchor: (Height: 12);
                                                    }
                                                    Label #DetailRaceValue {
                                                        Text: "--";
                                                        Style: (FontSize: 18, TextColor: #e5c68a, RenderBold: true);
                                                        Anchor: (Height: 22);
                                                    }
                                                }

                                                Group { Anchor: (Width: 1, Top: 6, Bottom: 6); Background: #ffffff(0.07); }
                                                Group { Anchor: (Width: 12); }

                                                Group {
                                                    LayoutMode: Top;
                                                    Anchor: (Width: 120);

                                                    Label {
                                                        Text: "PRIMARY CLASS";
                                                        Style: (FontSize: 10, TextColor: #4a7090, RenderBold: true, LetterSpacing: 1);
                                                        Anchor: (Height: 12);
                                                    }
                                                    Label #DetailPrimaryClassValue {
                                                        Text: "--";
                                                        Style: (FontSize: 18, TextColor: #f0c15a, RenderBold: true);
                                                        Anchor: (Height: 22);
                                                    }
                                                }

                                                Group { Anchor: (Width: 1, Top: 6, Bottom: 6); Background: #ffffff(0.07); }
                                                Group { Anchor: (Width: 12); }

                                                Group {
                                                    LayoutMode: Top;
                                                    FlexWeight: 1;

                                                    Label {
                                                        Text: "SECONDARY CLASS";
                                                        Style: (FontSize: 10, TextColor: #4a7090, RenderBold: true, LetterSpacing: 1);
                                                        Anchor: (Height: 12);
                                                    }
                                                    Label #DetailSecondaryClassValue {
                                                        Text: "--";
                                                        Style: (FontSize: 18, TextColor: #9fb6d3, RenderBold: true);
                                                        Anchor: (Height: 22);
                                                    }
                                                }
                                            }

                                            Group { Anchor: (Height: 8); }

                                            // ===== TWO-COLUMN SCROLL BODY =====
                                            Group #DetailScrollArea {
                                                FlexWeight: 1;

                                                Group #DetailScrollContent {
                                                    LayoutMode: Left;

                                                    // ====== LEFT COLUMN: ATTRIBUTES ======
                                                    Group #DetailColumnLeft {
                                                        FlexWeight: 1;
                                                        LayoutMode: TopScrolling;
                                                        ScrollbarStyle: $C.@DefaultScrollbarStyle;
                                                        Background: #040c17(0.90);
                                                        Padding: (Left: 14, Right: 14, Top: 14, Bottom: 14);

                                                        Group #DetailColumnLeftContent {
                                                            LayoutMode: Top;

                                                            // ---- TOTAL ATTRIBUTES ----
                                                            Group {
                                                                LayoutMode: Left;
                                                                Anchor: (Height: 22, Bottom: 6);

                                                                Label {
                                                                    Text: "TOTAL ATTRIBUTES";
                                                                    Style: (FontSize: 11, TextColor: #7a9abf, RenderBold: true, LetterSpacing: 1);
                                                                }
                                                            }
                                                            Group {
                                                                Anchor: (Height: 1, Bottom: 8);
                                                                Background: #ffffff(0.08);
                                                            }

                                                            Group #AttributeList {
                                                                LayoutMode: Top;

                                                                Group {
                                                                    LayoutMode: Left;
                                                                    Anchor: (Height: 24);
                                                                    Background: #071018(0.55);
                                                                    Padding: (Horizontal: 8);
                                                                    Label #AttributeLifeForceLabel { Text: "Life Force"; Style: (FontSize: 12, TextColor: #7be0ff); FlexWeight: 1; }
                                                                    Label #AttributeLifeForceValue { Text: "--"; Style: (FontSize: 12, TextColor: #4fd7f7, RenderBold: true); }
                                                                    Group { Anchor: (Width: 6); }
                                                                    Label #AttributeLifeForceLevel { Text: "Lv --"; Style: (FontSize: 11, TextColor: #3a6a80); }
                                                                }
                                                                Group { Anchor: (Height: 2); }
                                                                Group {
                                                                    LayoutMode: Left;
                                                                    Anchor: (Height: 24);
                                                                    Padding: (Horizontal: 8);
                                                                    Label #AttributeStrengthLabel { Text: "Strength"; Style: (FontSize: 12, TextColor: #ffb347); FlexWeight: 1; }
                                                                    Label #AttributeStrengthValue { Text: "--"; Style: (FontSize: 12, TextColor: #ffdf8f, RenderBold: true); }
                                                                    Group { Anchor: (Width: 6); }
                                                                    Label #AttributeStrengthLevel { Text: "Lv --"; Style: (FontSize: 11, TextColor: #7a5020); }
                                                                }
                                                                Group { Anchor: (Height: 2); }
                                                                Group {
                                                                    LayoutMode: Left;
                                                                    Anchor: (Height: 24);
                                                                    Background: #071018(0.55);
                                                                    Padding: (Horizontal: 8);
                                                                    Label #AttributeSorceryLabel { Text: "Sorcery"; Style: (FontSize: 12, TextColor: #d7baff); FlexWeight: 1; }
                                                                    Label #AttributeSorceryValue { Text: "--"; Style: (FontSize: 12, TextColor: #e8d5ff, RenderBold: true); }
                                                                    Group { Anchor: (Width: 6); }
                                                                    Label #AttributeSorceryLevel { Text: "Lv --"; Style: (FontSize: 11, TextColor: #6a4a8a); }
                                                                }
                                                                Group { Anchor: (Height: 2); }
                                                                Group {
                                                                    LayoutMode: Left;
                                                                    Anchor: (Height: 24);
                                                                    Padding: (Horizontal: 8);
                                                                    Label #AttributeDefenseLabel { Text: "Defense"; Style: (FontSize: 12, TextColor: #8be0b2); FlexWeight: 1; }
                                                                    Label #AttributeDefenseValue { Text: "--"; Style: (FontSize: 12, TextColor: #6ee7b7, RenderBold: true); }
                                                                    Group { Anchor: (Width: 6); }
                                                                    Label #AttributeDefenseLevel { Text: "Lv --"; Style: (FontSize: 11, TextColor: #2a6a4a); }
                                                                }
                                                                Group { Anchor: (Height: 2); }
                                                                Group {
                                                                    LayoutMode: Left;
                                                                    Anchor: (Height: 24);
                                                                    Background: #071018(0.55);
                                                                    Padding: (Horizontal: 8);
                                                                    Label #AttributeHasteLabel { Text: "Haste"; Style: (FontSize: 12, TextColor: #f2a2e8); FlexWeight: 1; }
                                                                    Label #AttributeHasteValue { Text: "--"; Style: (FontSize: 12, TextColor: #f78bd9, RenderBold: true); }
                                                                    Group { Anchor: (Width: 6); }
                                                                    Label #AttributeHasteLevel { Text: "Lv --"; Style: (FontSize: 11, TextColor: #7a2a6a); }
                                                                }
                                                                Group { Anchor: (Height: 2); }
                                                                Group {
                                                                    LayoutMode: Left;
                                                                    Anchor: (Height: 24);
                                                                    Padding: (Horizontal: 8);
                                                                    Label #AttributePrecisionLabel { Text: "Precision"; Style: (FontSize: 12, TextColor: #9ad4ff); FlexWeight: 1; }
                                                                    Label #AttributePrecisionValue { Text: "--"; Style: (FontSize: 12, TextColor: #7cb8ff, RenderBold: true); }
                                                                    Group { Anchor: (Width: 6); }
                                                                    Label #AttributePrecisionLevel { Text: "Lv --"; Style: (FontSize: 11, TextColor: #2a4a7a); }
                                                                }
                                                                Group { Anchor: (Height: 2); }
                                                                Group {
                                                                    LayoutMode: Left;
                                                                    Anchor: (Height: 24);
                                                                    Background: #071018(0.55);
                                                                    Padding: (Horizontal: 8);
                                                                    Label #AttributeFerocityLabel { Text: "Ferocity"; Style: (FontSize: 12, TextColor: #ff7b7b); FlexWeight: 1; }
                                                                    Label #AttributeFerocityValue { Text: "--"; Style: (FontSize: 12, TextColor: #ff5555, RenderBold: true); }
                                                                    Group { Anchor: (Width: 6); }
                                                                    Label #AttributeFerocityLevel { Text: "Lv --"; Style: (FontSize: 11, TextColor: #7a2020); }
                                                                }
                                                                Group { Anchor: (Height: 2); }
                                                                Group {
                                                                    LayoutMode: Left;
                                                                    Anchor: (Height: 24);
                                                                    Padding: (Horizontal: 8);
                                                                    Label #AttributeStaminaLabel { Text: "Stamina"; Style: (FontSize: 12, TextColor: #ffc56f); FlexWeight: 1; }
                                                                    Label #AttributeStaminaValue { Text: "--"; Style: (FontSize: 12, TextColor: #ffad42, RenderBold: true); }
                                                                    Group { Anchor: (Width: 6); }
                                                                    Label #AttributeStaminaLevel { Text: "Lv --"; Style: (FontSize: 11, TextColor: #7a4a10); }
                                                                }
                                                                Group { Anchor: (Height: 2); }
                                                                Group {
                                                                    LayoutMode: Left;
                                                                    Anchor: (Height: 24);
                                                                    Background: #071018(0.55);
                                                                    Padding: (Horizontal: 8);
                                                                    Label #AttributeFlowLabel { Text: "Flow"; Style: (FontSize: 12, TextColor: #9be3ff); FlexWeight: 1; }
                                                                    Label #AttributeFlowValue { Text: "--"; Style: (FontSize: 12, TextColor: #7dd6ff, RenderBold: true); }
                                                                    Group { Anchor: (Width: 6); }
                                                                    Label #AttributeFlowLevel { Text: "Lv --"; Style: (FontSize: 11, TextColor: #2a5a7a); }
                                                                }
                                                                Group { Anchor: (Height: 2); }
                                                                Group {
                                                                    LayoutMode: Left;
                                                                    Anchor: (Height: 24);
                                                                    Padding: (Horizontal: 8);
                                                                    Label #AttributeDisciplineLabel { Text: "Discipline"; Style: (FontSize: 12, TextColor: #d5dfff); FlexWeight: 1; }
                                                                    Label #AttributeDisciplineValue { Text: "--"; Style: (FontSize: 12, TextColor: #9fe0ff, RenderBold: true); }
                                                                    Group { Anchor: (Width: 6); }
                                                                    Label #AttributeDisciplineLevel { Text: "Lv --"; Style: (FontSize: 11, TextColor: #3a4a7a); }
                                                                }
                                                            }

                                                            Group { Anchor: (Height: 16); }

                                                            // ---- INNATE BONUSES ----
                                                            Group {
                                                                LayoutMode: Left;
                                                                Anchor: (Height: 22, Bottom: 6);

                                                                Label {
                                                                    Text: "INNATE BONUSES";
                                                                    Style: (FontSize: 11, TextColor: #7a9abf, RenderBold: true, LetterSpacing: 1);
                                                                }
                                                            }
                                                            Group {
                                                                Anchor: (Height: 1, Bottom: 8);
                                                                Background: #ffffff(0.08);
                                                            }

                                                            Group #InnateAttributeList {
                                                                LayoutMode: Top;

                                                                Label #InnateAttributeSummary {
                                                                    Text: "No innate attribute bonuses";
                                                                    Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true);
                                                                    Anchor: (Height: 18);
                                                                }

                                                                Group #InnateAttributeEntries {
                                                                    LayoutMode: Top;
                                                                }
                                                            }
                                                        }
                                                    }

                                                    Group { Anchor: (Width: 10); }

                                                    // ====== RIGHT COLUMN: BONUSES ======
                                                    Group #DetailColumnRight {
                                                        FlexWeight: 1;
                                                        LayoutMode: TopScrolling;
                                                        ScrollbarStyle: $C.@DefaultScrollbarStyle;
                                                        Background: #040c17(0.90);
                                                        Padding: (Left: 14, Right: 14, Top: 14, Bottom: 14);

                                                        // ---- WEAPON BONUSES ----
                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 22, Bottom: 6);

                                                            Label {
                                                                Text: "WEAPON BONUSES";
                                                                Style: (FontSize: 11, TextColor: #7a9abf, RenderBold: true, LetterSpacing: 1);
                                                            }
                                                        }
                                                        Group {
                                                            Anchor: (Height: 1, Bottom: 8);
                                                            Background: #ffffff(0.08);
                                                        }

                                                        Group #PrimaryWeaponList {
                                                            LayoutMode: Top;

                                                            Label #PrimaryWeaponSummary {
                                                                Text: "No primary class weapon bonuses";
                                                                Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true);
                                                                Anchor: (Height: 18);
                                                            }

                                                            Group #PrimaryWeaponEntries {
                                                                LayoutMode: Top;
                                                            }
                                                        }

                                                        Group { Anchor: (Height: 16); }

                                                        // ---- AUGMENTS ----
                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 22, Bottom: 6);

                                                            Label {
                                                                Text: "AUGMENTS";
                                                                Style: (FontSize: 11, TextColor: #7a9abf, RenderBold: true, LetterSpacing: 1);
                                                            }
                                                        }
                                                        Group {
                                                            Anchor: (Height: 1, Bottom: 8);
                                                            Background: #ffffff(0.08);
                                                        }

                                                        Group #AugmentList {
                                                            LayoutMode: Top;

                                                            Label #AugmentSummary {
                                                                Text: "No augments active";
                                                                Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true);
                                                                Anchor: (Height: 18);
                                                            }

                                                            Group #AugmentEntries {
                                                                LayoutMode: Top;
                                                            }
                                                        }

                                                        Group { Anchor: (Height: 16); }

                                                        // ---- PASSIVES ----
                                                        Group {
                                                            LayoutMode: Left;
                                                            Anchor: (Height: 22, Bottom: 6);

                                                            Label {
                                                                Text: "PASSIVES";
                                                                Style: (FontSize: 11, TextColor: #7a9abf, RenderBold: true, LetterSpacing: 1);
                                                            }
                                                        }
                                                        Group {
                                                            Anchor: (Height: 1, Bottom: 8);
                                                            Background: #ffffff(0.08);
                                                        }

                                                        Group #PassiveList {
                                                            LayoutMode: Top;

                                                            Label #PassiveSummary {
                                                                Text: "Select a profile to view passive bonuses";
                                                                Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true);
                                                                Anchor: (Height: 18);
                                                            }

                                                            Group #PassiveEntries {
                                                                LayoutMode: Top;
                                                            }
                                                        }

                                                        Group { Anchor: (Height: 8); }

                                                        Group #InnatePassiveList {
                                                            LayoutMode: Top;

                                                            Label #InnatePassiveSummary {
                                                                Text: "No innate passives active";
                                                                Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true);
                                                                Anchor: (Height: 18);
                                                            }

                                                            Group #InnatePassiveEntries {
                                                                LayoutMode: Top;
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Group { Anchor: (Width: 40); }

                        $Nav.@ObjectiveContainer {
                            Anchor: (Width: 300, Height: 700);

                            #Title {
                                Label #AugmentInfoPanel {
                                    Text: "PROFILES";
                                    Style: $Nav.@PanelTitleStyle;
                                }
                            }

                            #Content {
                                LayoutMode: Top;
                                Padding: (Horizontal: 12, Bottom: 12);

                                Group {
                                    LayoutMode: Top;
                                    Padding: (Vertical: 12);

                                    Label #ProfileTitleLabel {
                                        FlexWeight: 1;
                                        Text: "Profiles 0/5";
                                        Style: (FontSize: 22, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: Center);
                                    }

                                    $C.@TextButton #NewProfileButton {
                                        Text: "NEW PROFILE";
                                        Anchor: (Height: 32, Width: 170);
                                    }
                                }

                                Group {
                                    Anchor: (Height: 1, Bottom: 4);
                                    Background: #ffffff(0.08);
                                }

                                Label {
                                    Text: "Select a profile to load it and view your stats.";
                                    Style: (FontSize: 11, TextColor: #5a7a9a, Wrap: true, HorizontalAlignment: Center);
                                    Anchor: (Bottom: 10);
                                    Padding: (Horizontal: 12);
                                }

                                Group #ProfileListColumn {
                                    FlexWeight: 1;
                                    LayoutMode: TopScrolling;
                                    ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                    Group #ProfileListSection {
                                        LayoutMode: Top;
                                        FlexWeight: 1;

                                        Group #ProfileRows {
                                            FlexWeight: 1;

                                            Group #ProfileCards {
                                                LayoutMode: Top;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        }

        Group { Anchor: (Height: 14); }

        // ====================== FOOTER NAVBAR (root, disconnected) ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Width: 480, Height: 92);
                $Nav.@BottomNavBar {}
            }
        }
    }
}

$C.@BackButton {}
