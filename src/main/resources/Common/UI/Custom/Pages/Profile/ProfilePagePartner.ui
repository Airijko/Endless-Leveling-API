$C = "../../Common.ui";
$Nav = "../Nav/TopNavBar.ui";

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;
        Padding: (Vertical: 12);

        // ====================== TOP NAVBAR ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Height: 92);
                $Nav.@TopNavBar {}
            }
        }

        Group { Anchor: (Height: 14); }

        // ====================== MAIN CONTENT ======================
        Group {
            LayoutMode: Middle;

            Group {
                LayoutMode: Left;
                Anchor: (Width: 1680, Height: 700);

                Group {
                    LayoutMode: Top;
                    Anchor: (Width: 1680, Height: 700);

                    Group {
                        LayoutMode: Middle;
                        Anchor: (Width: 1680);

                        Group {
                            LayoutMode: Left;

                            // ============================================================
                            //  LEFT: MAIN PROFILE PANEL (1300px)
                            // ============================================================
                            Group {
                                Anchor: (Width: 1320, Height: 700);
                                LayoutMode: Top;

                                // ===== HEADER: XP bar + identity stats =====
                                Group {
                                    LayoutMode: Top;
                                    Background: (TexturePath: "../../Hud/ObjectivePanelContainer.png", Border: 15);
                                    Padding: (Left: 18, Right: 18, Top: 14, Bottom: 14);

                                    // Title row
                                    Group {
                                        LayoutMode: Left;
                                        Anchor: (Height: 22);

                                        Label #ProfileTitle {
                                            Text: "ENDLESS LEVELING";
                                            Style: (FontSize: 14, TextColor: #f0c040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                                        }

                                        Group { FlexWeight: 1; }

                                        Label #ProfilesSummary {
                                            Text: "";
                                            Style: (FontSize: 10, TextColor: #ff6666, VerticalAlignment: Center);
                                        }
                                    }

                                    Group { Anchor: (Height: 8); }

                                    // XP Progress bar
                                    Group #DetailXpBar {
                                        Anchor: (Height: 40);
                                        Background: "Partner_XPBackground.png";

                                        ProgressBar #DetailProgressBar {
                                            FlexWeight: 1;
                                            BarTexturePath: "Partner_XPFill.png";
                                        }
                                    }

                                    Group { Anchor: (Height: 10); }

                                    // Identity stats row
                                    Group #DetailSummary {
                                        LayoutMode: Left;
                                        Anchor: (Height: 70);

                                        // Prestige
                                        Group {
                                            LayoutMode: Top;
                                            FlexWeight: 0.5;

                                            Label {
                                                Text: "PRESTIGE";
                                                Style: (FontSize: 9, TextColor: #6a5a8a, RenderBold: true, LetterSpacing: 1);
                                                Anchor: (Height: 12);
                                            }
                                            Label #DetailPrestigeValue {
                                                Text: "--";
                                                Style: (FontSize: 18, TextColor: #b084e0, RenderBold: true);
                                                Anchor: (Height: 22);
                                            }
                                            Group { Anchor: (Height: 4); }
                                            $C.@TextButton #PrestigeButton {
                                                Text: "PRESTIGE UP";
                                                Anchor: (Height: 26);
                                                Padding: (Horizontal: 6);
                                            }
                                        }

                                        Group { Anchor: (Width: 1, Top: 4, Bottom: 4); Background: #ffffff(0.06); }
                                        Group { Anchor: (Width: 10); }

                                        // Level
                                        Group {
                                            LayoutMode: Top;
                                            FlexWeight: 0.5;

                                            Label {
                                                Text: "LEVEL";
                                                Style: (FontSize: 9, TextColor: #4a7090, RenderBold: true, LetterSpacing: 1);
                                                Anchor: (Height: 12);
                                            }
                                            Label #DetailLevelValue {
                                                Text: "--";
                                                Style: (FontSize: 18, TextColor: #7ec8f5, RenderBold: true);
                                                Anchor: (Height: 22);
                                            }
                                        }

                                        Group { Anchor: (Width: 1, Top: 4, Bottom: 4); Background: #ffffff(0.06); }
                                        Group { Anchor: (Width: 10); }

                                        // XP
                                        Group {
                                            LayoutMode: Top;
                                            FlexWeight: 1;

                                            Label {
                                                Text: "CURRENT XP";
                                                Style: (FontSize: 9, TextColor: #4a7090, RenderBold: true, LetterSpacing: 1);
                                                Anchor: (Height: 12);
                                            }
                                            Label #DetailXpValue {
                                                Text: "--";
                                                Style: (FontSize: 18, TextColor: #9ad4ff, RenderBold: true);
                                                Anchor: (Height: 22);
                                            }
                                        }

                                        Group { Anchor: (Width: 1, Top: 4, Bottom: 4); Background: #ffffff(0.06); }
                                        Group { Anchor: (Width: 10); }

                                        // Race
                                        Group {
                                            LayoutMode: Top;
                                            FlexWeight: 1.2;

                                            Label {
                                                Text: "RACE";
                                                Style: (FontSize: 9, TextColor: #4a7090, RenderBold: true, LetterSpacing: 1);
                                                Anchor: (Height: 12);
                                            }
                                            Label #DetailRaceValue {
                                                Text: "--";
                                                Style: (FontSize: 16, TextColor: #e5c68a, RenderBold: true);
                                                Anchor: (Height: 22);
                                            }
                                            Group { Anchor: (Height: 4); }
                                            $C.@TextButton #ViewRaceButton {
                                                Text: "VIEW RACE";
                                                Anchor: (Height: 26);
                                                Padding: (Horizontal: 6);
                                            }
                                        }

                                        Group { Anchor: (Width: 1, Top: 4, Bottom: 4); Background: #ffffff(0.06); }
                                        Group { Anchor: (Width: 10); }

                                        // Primary
                                        Group {
                                            LayoutMode: Top;
                                            FlexWeight: 1.2;

                                            Label {
                                                Text: "PRIMARY CLASS";
                                                Style: (FontSize: 9, TextColor: #4a7090, RenderBold: true, LetterSpacing: 1);
                                                Anchor: (Height: 12);
                                            }
                                            Label #DetailPrimaryClassValue {
                                                Text: "--";
                                                Style: (FontSize: 16, TextColor: #f0c15a, RenderBold: true);
                                                Anchor: (Height: 22);
                                            }
                                            Group { Anchor: (Height: 4); }
                                            $C.@TextButton #ViewPrimaryClassButton {
                                                Text: "VIEW CLASS";
                                                Anchor: (Height: 26);
                                                Padding: (Horizontal: 6);
                                            }
                                        }

                                        Group { Anchor: (Width: 1, Top: 4, Bottom: 4); Background: #ffffff(0.06); }
                                        Group { Anchor: (Width: 10); }

                                        // Secondary
                                        Group {
                                            LayoutMode: Top;
                                            FlexWeight: 1.2;

                                            Label {
                                                Text: "SECONDARY";
                                                Style: (FontSize: 9, TextColor: #4a7090, RenderBold: true, LetterSpacing: 1);
                                                Anchor: (Height: 12);
                                            }
                                            Label #DetailSecondaryClassValue {
                                                Text: "--";
                                                Style: (FontSize: 16, TextColor: #9fb6d3, RenderBold: true);
                                                Anchor: (Height: 22);
                                            }
                                            Group { Anchor: (Height: 4); }
                                            $C.@TextButton #ViewSecondaryClassButton {
                                                Text: "VIEW CLASS";
                                                Anchor: (Height: 26);
                                                Padding: (Horizontal: 6);
                                            }
                                        }
                                    }
                                }

                                Group { Anchor: (Height: 8); }

                                // ===== FOUR-COLUMN BODY =====
                                Group #DetailScrollArea {
                                    FlexWeight: 1;
                                    LayoutMode: Left;

                                    Group #DetailScrollContent {
                                        LayoutMode: Left;
                                        FlexWeight: 1;

                                        // ---- Col 1: Attributes ----
                                        $Nav.@ObjectiveContainer {
                                            FlexWeight: 1;

                                            #Title {
                                                Label {
                                                    Text: "TOTAL ATTRIBUTES";
                                                    Style: $Nav.@PanelTitleStyle;
                                                }
                                            }

                                            #Content {
                                                LayoutMode: Top;
                                                Padding: (Horizontal: 10, Top: 4, Bottom: 6);

                                                Group #AttributeList {
                                                    LayoutMode: Top;

                                                    Group {
                                                        LayoutMode: Left;
                                                        Anchor: (Height: 24);
                                                        Padding: (Horizontal: 6);
                                                        Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                                                        Label #AttributeLifeForceLabel { Text: "Life Force"; Style: (FontSize: 11, TextColor: #7be0ff, VerticalAlignment: Center); FlexWeight: 1; }
                                                        Label #AttributeLifeForceValue { Text: "--"; Style: (FontSize: 11, TextColor: #4fd7f7, RenderBold: true, VerticalAlignment: Center); }
                                                        Group { Anchor: (Width: 6); }
                                                        Label #AttributeLifeForceLevel { Text: "Lv --"; Style: (FontSize: 10, TextColor: #3a6a80, VerticalAlignment: Center); }
                                                    }
                                                    Group { Anchor: (Height: 1); }
                                                    Group {
                                                        LayoutMode: Left;
                                                        Anchor: (Height: 24);
                                                        Padding: (Horizontal: 6);
                                                        Label #AttributeStrengthLabel { Text: "Strength"; Style: (FontSize: 11, TextColor: #ffb347, VerticalAlignment: Center); FlexWeight: 1; }
                                                        Label #AttributeStrengthValue { Text: "--"; Style: (FontSize: 11, TextColor: #ffdf8f, RenderBold: true, VerticalAlignment: Center); }
                                                        Group { Anchor: (Width: 6); }
                                                        Label #AttributeStrengthLevel { Text: "Lv --"; Style: (FontSize: 10, TextColor: #7a5020, VerticalAlignment: Center); }
                                                    }
                                                    Group { Anchor: (Height: 1); }
                                                    Group {
                                                        LayoutMode: Left;
                                                        Anchor: (Height: 24);
                                                        Padding: (Horizontal: 6);
                                                        Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                                                        Label #AttributeSorceryLabel { Text: "Sorcery"; Style: (FontSize: 11, TextColor: #d7baff, VerticalAlignment: Center); FlexWeight: 1; }
                                                        Label #AttributeSorceryValue { Text: "--"; Style: (FontSize: 11, TextColor: #e8d5ff, RenderBold: true, VerticalAlignment: Center); }
                                                        Group { Anchor: (Width: 6); }
                                                        Label #AttributeSorceryLevel { Text: "Lv --"; Style: (FontSize: 10, TextColor: #6a4a8a, VerticalAlignment: Center); }
                                                    }
                                                    Group { Anchor: (Height: 1); }
                                                    Group {
                                                        LayoutMode: Left;
                                                        Anchor: (Height: 24);
                                                        Padding: (Horizontal: 6);
                                                        Label #AttributeDefenseLabel { Text: "Defense"; Style: (FontSize: 11, TextColor: #8be0b2, VerticalAlignment: Center); FlexWeight: 1; }
                                                        Label #AttributeDefenseValue { Text: "--"; Style: (FontSize: 11, TextColor: #6ee7b7, RenderBold: true, VerticalAlignment: Center); }
                                                        Group { Anchor: (Width: 6); }
                                                        Label #AttributeDefenseLevel { Text: "Lv --"; Style: (FontSize: 10, TextColor: #2a6a4a, VerticalAlignment: Center); }
                                                    }
                                                    Group { Anchor: (Height: 1); }
                                                    Group {
                                                        LayoutMode: Left;
                                                        Anchor: (Height: 24);
                                                        Padding: (Horizontal: 6);
                                                        Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                                                        Label #AttributeHasteLabel { Text: "Haste"; Style: (FontSize: 11, TextColor: #f2a2e8, VerticalAlignment: Center); FlexWeight: 1; }
                                                        Label #AttributeHasteValue { Text: "--"; Style: (FontSize: 11, TextColor: #f78bd9, RenderBold: true, VerticalAlignment: Center); }
                                                        Group { Anchor: (Width: 6); }
                                                        Label #AttributeHasteLevel { Text: "Lv --"; Style: (FontSize: 10, TextColor: #7a2a6a, VerticalAlignment: Center); }
                                                    }
                                                    Group { Anchor: (Height: 1); }
                                                    Group {
                                                        LayoutMode: Left;
                                                        Anchor: (Height: 24);
                                                        Padding: (Horizontal: 6);
                                                        Label #AttributePrecisionLabel { Text: "Precision"; Style: (FontSize: 11, TextColor: #9ad4ff, VerticalAlignment: Center); FlexWeight: 1; }
                                                        Label #AttributePrecisionValue { Text: "--"; Style: (FontSize: 11, TextColor: #7cb8ff, RenderBold: true, VerticalAlignment: Center); }
                                                        Group { Anchor: (Width: 6); }
                                                        Label #AttributePrecisionLevel { Text: "Lv --"; Style: (FontSize: 10, TextColor: #2a4a7a, VerticalAlignment: Center); }
                                                    }
                                                    Group { Anchor: (Height: 1); }
                                                    Group {
                                                        LayoutMode: Left;
                                                        Anchor: (Height: 24);
                                                        Padding: (Horizontal: 6);
                                                        Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                                                        Label #AttributeFerocityLabel { Text: "Ferocity"; Style: (FontSize: 11, TextColor: #ff7b7b, VerticalAlignment: Center); FlexWeight: 1; }
                                                        Label #AttributeFerocityValue { Text: "--"; Style: (FontSize: 11, TextColor: #ff5555, RenderBold: true, VerticalAlignment: Center); }
                                                        Group { Anchor: (Width: 6); }
                                                        Label #AttributeFerocityLevel { Text: "Lv --"; Style: (FontSize: 10, TextColor: #7a2020, VerticalAlignment: Center); }
                                                    }
                                                    Group { Anchor: (Height: 1); }
                                                    Group {
                                                        LayoutMode: Left;
                                                        Anchor: (Height: 24);
                                                        Padding: (Horizontal: 6);
                                                        Label #AttributeStaminaLabel { Text: "Stamina"; Style: (FontSize: 11, TextColor: #ffc56f, VerticalAlignment: Center); FlexWeight: 1; }
                                                        Label #AttributeStaminaValue { Text: "--"; Style: (FontSize: 11, TextColor: #ffad42, RenderBold: true, VerticalAlignment: Center); }
                                                        Group { Anchor: (Width: 6); }
                                                        Label #AttributeStaminaLevel { Text: "Lv --"; Style: (FontSize: 10, TextColor: #7a4a10, VerticalAlignment: Center); }
                                                    }
                                                    Group { Anchor: (Height: 1); }
                                                    Group {
                                                        LayoutMode: Left;
                                                        Anchor: (Height: 24);
                                                        Padding: (Horizontal: 6);
                                                        Background: (TexturePath: "../../Tiles/TileRowBackground.png");
                                                        Label #AttributeFlowLabel { Text: "Flow"; Style: (FontSize: 11, TextColor: #9be3ff, VerticalAlignment: Center); FlexWeight: 1; }
                                                        Label #AttributeFlowValue { Text: "--"; Style: (FontSize: 11, TextColor: #7dd6ff, RenderBold: true, VerticalAlignment: Center); }
                                                        Group { Anchor: (Width: 6); }
                                                        Label #AttributeFlowLevel { Text: "Lv --"; Style: (FontSize: 10, TextColor: #2a5a7a, VerticalAlignment: Center); }
                                                    }
                                                    Group { Anchor: (Height: 1); }
                                                    Group {
                                                        LayoutMode: Left;
                                                        Anchor: (Height: 24);
                                                        Padding: (Horizontal: 6);
                                                        Label #AttributeDisciplineLabel { Text: "Discipline"; Style: (FontSize: 11, TextColor: #d5dfff, VerticalAlignment: Center); FlexWeight: 1; }
                                                        Label #AttributeDisciplineValue { Text: "--"; Style: (FontSize: 11, TextColor: #9fe0ff, RenderBold: true, VerticalAlignment: Center); }
                                                        Group { Anchor: (Width: 6); }
                                                        Label #AttributeDisciplineLevel { Text: "Lv --"; Style: (FontSize: 10, TextColor: #3a4a7a, VerticalAlignment: Center); }
                                                    }
                                                }

                                                Group { Anchor: (Height: 10); }

                                                // Innate bonuses sub-section
                                                Label {
                                                    Text: "Innate Bonuses";
                                                    Style: (FontSize: 11, TextColor: #f0c040, RenderBold: true, LetterSpacing: 1);
                                                    Anchor: (Height: 16);
                                                }
                                                Group { Anchor: (Height: 1); Background: #ffffff(0.06); }
                                                Group { Anchor: (Height: 4); }

                                                Group #InnateAttributeList {
                                                    LayoutMode: Top;

                                                    Label #InnateAttributeSummary {
                                                        Text: "No innate attribute bonuses";
                                                        Style: (FontSize: 11, TextColor: #9fb6d3);
                                                        Anchor: (Height: 16);
                                                    }

                                                    Group #InnateAttributeEntries {
                                                        LayoutMode: Top;
                                                    }
                                                }
                                            }
                                        }

                                        Group { Anchor: (Width: 8); }

                                        // ---- Col 2: Weapons + Augments ----
                                        $Nav.@ObjectiveContainer {
                                            FlexWeight: 1;

                                            #Title {
                                                Label {
                                                    Text: "WEAPONS & AUGMENTS";
                                                    Style: $Nav.@PanelTitleStyle;
                                                }
                                            }

                                            #Content {
                                                LayoutMode: TopScrolling;
                                                ScrollbarStyle: $C.@DefaultScrollbarStyle;
                                                Padding: (Horizontal: 10, Top: 4, Bottom: 6);

                                                Group #DetailColumnRight {
                                                    LayoutMode: Top;

                                                    // Weapons
                                                    Group #PrimaryWeaponList {
                                                        LayoutMode: Top;

                                                        Label #PrimaryWeaponSummary {
                                                            Text: "No primary class weapon bonuses";
                                                            Style: (FontSize: 11, TextColor: #9fb6d3);
                                                            Anchor: (Height: 16);
                                                        }

                                                        Group #PrimaryWeaponEntries {
                                                            LayoutMode: Top;
                                                        }
                                                    }

                                                    Group { Anchor: (Height: 10); }

                                                    // Augments
                                                    Label {
                                                        Text: "Augments";
                                                        Style: (FontSize: 11, TextColor: #f0c040, RenderBold: true, LetterSpacing: 1);
                                                        Anchor: (Height: 16);
                                                    }
                                                    Group { Anchor: (Height: 1); Background: #ffffff(0.06); }
                                                    Group { Anchor: (Height: 4); }

                                                    Group #AugmentList {
                                                        LayoutMode: Top;

                                                        Label #AugmentSummary {
                                                            Text: "No augments active";
                                                            Style: (FontSize: 11, TextColor: #9fb6d3);
                                                            Anchor: (Height: 16);
                                                        }

                                                        Group #AugmentEntries {
                                                            LayoutMode: Top;
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        Group { Anchor: (Width: 8); }

                                        // ---- Col 3: Passives ----
                                        $Nav.@ObjectiveContainer {
                                            FlexWeight: 1;

                                            #Title {
                                                Label {
                                                    Text: "PASSIVES";
                                                    Style: $Nav.@PanelTitleStyle;
                                                }
                                            }

                                            #Content {
                                                LayoutMode: TopScrolling;
                                                ScrollbarStyle: $C.@DefaultScrollbarStyle;
                                                Padding: (Horizontal: 10, Top: 4, Bottom: 6);

                                                Group {
                                                    LayoutMode: Top;

                                                    Group #PassiveList {
                                                        LayoutMode: Top;

                                                        Label #PassiveSummary {
                                                            Text: "No passive bonuses active";
                                                            Style: (FontSize: 11, TextColor: #9fb6d3);
                                                            Anchor: (Height: 16);
                                                        }

                                                        Group #PassiveEntries {
                                                            LayoutMode: Top;
                                                        }
                                                    }

                                                    Group { Anchor: (Height: 10); }

                                                    // Innate passives
                                                    Label {
                                                        Text: "Innate Passives";
                                                        Style: (FontSize: 11, TextColor: #f0c040, RenderBold: true, LetterSpacing: 1);
                                                        Anchor: (Height: 16);
                                                    }
                                                    Group { Anchor: (Height: 1); Background: #ffffff(0.06); }
                                                    Group { Anchor: (Height: 4); }

                                                    Group #InnatePassiveList {
                                                        LayoutMode: Top;

                                                        Label #InnatePassiveSummary {
                                                            Text: "No innate passives active";
                                                            Style: (FontSize: 11, TextColor: #9fb6d3);
                                                            Anchor: (Height: 16);
                                                        }

                                                        Group #InnatePassiveEntries {
                                                            LayoutMode: Top;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            Group { Anchor: (Width: 10); }

                            // ============================================================
                            //  RIGHT: PROFILE SIDEBAR (350px)
                            // ============================================================
                            $Nav.@ObjectiveContainer {
                                Anchor: (Width: 350, Height: 700);

                                #Title {
                                    Label #AugmentInfoPanel {
                                        Text: "PROFILES";
                                        Style: $Nav.@PanelTitleStyle;
                                    }
                                }

                                #Content {
                                    LayoutMode: Top;
                                    Padding: (Horizontal: 12, Top: 8, Bottom: 12);

                                    Group {
                                        LayoutMode: Left;
                                        Anchor: (Height: 36);
                                        Padding: (Horizontal: 4);

                                        Label #ProfileTitleLabel {
                                            FlexWeight: 1;
                                            Text: "Profiles 0/5";
                                            Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                                        }

                                        $C.@TextButton #NewProfileButton {
                                            Text: "NEW PROFILE";
                                            Anchor: (Height: 30, Width: 140);
                                        }
                                    }

                                    Group { Anchor: (Height: 6); }

                                    Group #ProfileListColumn {
                                        FlexWeight: 1;
                                        LayoutMode: TopScrolling;
                                        ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                        Group #ProfileListSection {
                                            LayoutMode: Top;
                                            FlexWeight: 1;

                                            Group #ProfileRows {
                                                FlexWeight: 1;

                                                Group #ProfileCards {
                                                    LayoutMode: Top;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Group { Anchor: (Height: 14); }

        // ====================== FOOTER NAVBAR ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Height: 92);
                $Nav.@BottomNavBar {}
            }
        }
    }
}

$C.@BackButton {}
