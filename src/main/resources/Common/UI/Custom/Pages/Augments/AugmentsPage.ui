$C = "../../Common.ui";
$Nav = "../Nav/TopNavBar.ui";

// Searchable augment browser inspired by the Advanced-Item-Info grid pattern.

$C.@PageOverlay {
    Group {
        // Middle stacks children top-to-bottom but centers the GROUP vertically,
        // so the top navbar / main panels / footer navbar all sit centered on
        // screen instead of pinned to the top.
        LayoutMode: Middle;
        Padding: (Vertical: 12);

        // ====================== TOP NAVBAR (root, disconnected) ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Width: 1280, Height: 92);
                $Nav.@TopNavBar {}
            }
        }

        Group { Anchor: (Height: 14); }

        // ====================== MAIN CONTENT ROW ======================
        Group {
            LayoutMode: Middle;

            Group {
                LayoutMode: Left;
                Anchor: (Width: 1680, Height: 700);

                Group {
                    LayoutMode: Top;
                    Anchor: (Width: 1680, Height: 700);

                    Group {
                        LayoutMode: Middle;
                        Anchor: (Width: 1680);

                        Group {
                            LayoutMode: Left;

                        $Nav.@ObjectiveContainer {
                            Anchor: (Width: 300, Height: 700);

                            #Title {
                                Label #AugmentActionInfo {
                                    Text: "AUGMENTS";
                                    Style: $Nav.@PanelTitleStyle;
                                }
                            }

                            #Content {
                                LayoutMode: Top;
                                Padding: (Full: 12);

                                $C.@TextButton #OpenAugmentsChooseButton {
                                    Text: "CHOOSE AUGMENTS";
                                    Anchor: (Width: 210, Height: 34);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentsChooseAvailabilityLabel {
                                    Text: "No augments available to choose.";
                                    Style: (FontSize: 14, TextColor: #ff9f9f, RenderBold: true, Wrap: true, VerticalAlignment: Center);
                                    Anchor: (Height: 34);
                                    Padding: (Horizontal: 12);
                                }

                                Group { Anchor: (Height: 10); }

                                Label #AugmentsOverviewDescription {
                                    Text: "Augments are powerful passive enhancements that permanently strengthen your character. Earn them by reaching level milestones and through prestige.";
                                    Style: (FontSize: 12, TextColor: #7a9abf, Wrap: true);
                                    Anchor: (Bottom: 10);
                                    Padding: (Horizontal: 12);
                                }

                                Group {
                                    Anchor: (Height: 1, Bottom: 10);
                                    Background: #ffffff(0.08);
                                }

                                Label #AugmentsCollectionTitle {
                                    Text: "YOUR COLLECTION";
                                    Style: (FontSize: 11, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                    Anchor: (Height: 16, Bottom: 8);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentStatTotal {
                                    Text: "Total: 0 / 0";
                                    Style: (FontSize: 13, TextColor: #c5d4e8);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentStatMythic {
                                    Text: "Mythic: 0 / 0";
                                    Style: (FontSize: 13, TextColor: #b084e0);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentStatLegendary {
                                    Text: "Legendary: 0 / 0";
                                    Style: (FontSize: 13, TextColor: #f0c15a);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentStatElite {
                                    Text: "Elite: 0 / 0";
                                    Style: (FontSize: 13, TextColor: #7ec8f5);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentStatCommon {
                                    Text: "Common: 0 / 0";
                                    Style: (FontSize: 13, TextColor: #e6c168);
                                    Anchor: (Height: 20, Bottom: 10);
                                    Padding: (Horizontal: 12);
                                }

                                Group {
                                    Anchor: (Height: 1, Bottom: 10);
                                    Background: #ffffff(0.08);
                                }

                                Label #AugmentsRerollsTitle {
                                    Text: "REROLLS AVAILABLE";
                                    Style: (FontSize: 11, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                    Anchor: (Height: 16, Bottom: 8);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentRerollTotal {
                                    Text: "Total: 0";
                                    Style: (FontSize: 13, TextColor: #c5d4e8);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentRerollMythic {
                                    Text: "Mythic: 0";
                                    Style: (FontSize: 13, TextColor: #b084e0);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentRerollLegendary {
                                    Text: "Legendary: 0";
                                    Style: (FontSize: 13, TextColor: #f0c15a);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentRerollElite {
                                    Text: "Elite: 0";
                                    Style: (FontSize: 13, TextColor: #7ec8f5);
                                    Anchor: (Height: 20, Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }

                                Label #AugmentRerollCommon {
                                    Text: "Common: 0";
                                    Style: (FontSize: 13, TextColor: #e6c168);
                                    Anchor: (Height: 20, Bottom: 10);
                                    Padding: (Horizontal: 12);
                                }

                                Group { FlexWeight: 1; }

                                Label #AugmentsInfoText {
                                    Text: "Hover over an augment to preview it.";
                                    Style: (FontSize: 12, TextColor: #5a7a9a, Wrap: true, HorizontalAlignment: Center);
                                    Anchor: (Bottom: 4);
                                    Padding: (Horizontal: 12);
                                }
                            }
                        }

                        Group { Anchor: (Width: 40); }

                        $Nav.@ObjectiveContainer {
                            Anchor: (Width: 1000, Height: 700);

                            #Title {
                                Label #AugmentsPageTitle {
                                    Text: "ENDLESS LEVELING";
                                    Style: $Nav.@PanelTitleStyle;
                                }
                            }

                            #Content {
                                LayoutMode: Top;
                                Padding: (Full: 0);

                                // Search row sits above the result list
                                Group {
                                    Anchor: (Height: 36);
                                    LayoutMode: Right;
                                    Padding: (Horizontal: 12);

                                    CompactTextField #SearchInput {
                                        Anchor: (Width: 280, Height: 32);
                                        ExpandedWidth: 280;
                                        CollapsedWidth: 280;
                                        PlaceholderText: "Search augments...";
                                        Padding: (Horizontal: 10);
                                        Style: (FontSize: 14);
                                    }
                                }

                                Group #AugmentsResultsArea {
                                    FlexWeight: 1;
                                    LayoutMode: Left;

                                Group #CommandInfo {
                                    FlexWeight: 1;
                                    LayoutMode: TopScrolling;
                                    Padding: (Full: 16);
                                    ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                    Label #AugmentsResultLabel {
                                        Text: "Results: 0";
                                        Style: (FontSize: 14, TextColor: #9fb6d3, RenderBold: true);
                                        Anchor: (Height: 24);
                                    }

                                    Group { Anchor: (Height: 1); }

                                    // UNLOCKED SECTION
                                    Group #UnlockedSection {
                                        Anchor: (Bottom: 10);
                                        LayoutMode: Top;
                                        Visible: false;

                                        Label #UnlockedHeader {
                                            Text: "UNLOCKED";
                                            Style: (FontSize: 16, TextColor: #ffd700, RenderBold: true);
                                            Anchor: (Height: 28);
                                        }

                                        Group #UnlockedCards {
                                            LayoutMode: Top;
                                        }
                                    }

                                    // MYTHIC SECTION
                                    Group #MythicSection {
                                        Anchor: (Bottom: 10);
                                        LayoutMode: Top;
                                        Visible: false;

                                        Label #MythicHeader {
                                            Text: "MYTHIC";
                                            Style: (FontSize: 16, TextColor: #b084e0, RenderBold: true);
                                            Anchor: (Height: 28);
                                        }

                                        Group #MythicCards {
                                            LayoutMode: Top;
                                        }
                                    }

                                    // LEGENDARY SECTION
                                    Group #LegendarySection {
                                        Anchor: (Bottom: 10);
                                        LayoutMode: Top;
                                        Visible: false;

                                        Label #LegendaryHeader {
                                            Text: "LEGENDARY";
                                            Style: (FontSize: 16, TextColor: #f0c15a, RenderBold: true);
                                            Anchor: (Height: 28);
                                        }

                                        Group #LegendaryCards {
                                            LayoutMode: Top;
                                        }
                                    }

                                    // ELITE SECTION
                                    Group #EliteSection {
                                        Anchor: (Bottom: 10);
                                        LayoutMode: Top;
                                        Visible: false;

                                        Label #EliteHeader {
                                            Text: "ELITE";
                                            Style: (FontSize: 16, TextColor: #7ec8f5, RenderBold: true);
                                            Anchor: (Height: 28);
                                        }

                                        Group #EliteCards {
                                            LayoutMode: Top;
                                        }
                                    }

                                    // COMMON SECTION
                                    Group #CommonSection {
                                        Anchor: (Bottom: 10);
                                        LayoutMode: Top;
                                        Visible: false;

                                        Label #CommonHeader {
                                            Text: "COMMON";
                                            Style: (FontSize: 16, TextColor: #e6c168, RenderBold: true);
                                            Anchor: (Height: 28);
                                        }

                                        Group #CommonCards {
                                            LayoutMode: Top;
                                        }
                                    }
                                }
                                }
                            }
                        }

                        Group { Anchor: (Width: 40); }

                        Group #AugmentInfoPanelRoot {
                            Anchor: (Width: 300, Height: 700);

                            Group #AugmentInfoBgCommon {
                                Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                                Background: (TexturePath: "../../Tiles/TileCommon.png", Border: 20);
                                Visible: true;
                            }

                            Group #AugmentInfoBgElite {
                                Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                                Background: (TexturePath: "../../Tiles/TileElite.png", Border: 20);
                                Visible: false;
                            }

                            Group #AugmentInfoBgLegendary {
                                Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                                Background: (TexturePath: "../../Tiles/TileLegendary.png", Border: 20);
                                Visible: false;
                            }

                            Group #AugmentInfoBgMythic {
                                Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                                Background: (TexturePath: "../../Tiles/TileMythic.png", Border: 20);
                                Visible: false;
                            }

                            Group #AugmentInfoPanelContent {
                                LayoutMode: Top;
                                Anchor: (Top: 8, Left: 0, Right: 0, Bottom: 16);
                                Padding: (Full: 12);

                                Group {
                                    LayoutMode: Middle;
                                    Anchor: (Height: 40, Bottom: 8);

                                    Label #AugmentInfoPanel {
                                        Text: "AUGMENT INFO";
                                        Style: (FontSize: 20, TextColor: #e6edf5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                    }
                                }

                                Group #AugmentInfoScrollArea {
                                    FlexWeight: 1;
                                    LayoutMode: TopScrolling;
                                    ScrollbarStyle: $C.@DefaultScrollbarStyle;

                                    Group #AugmentInfoScrollContent {
                                        LayoutMode: Top;

                                        // Icon + name row
                                        Group #AugmentInfoHeader {
                                            LayoutMode: Top;
                                            Anchor: (Bottom: 10);

                                            Group {
                                                LayoutMode: Middle;

                                                ItemIcon #AugmentInfoIcon {
                                                    Anchor: (Width: 72, Height: 72, Bottom: 8);
                                                    Visible: false;
                                                }
                                            }

                                            Label #AugmentInfoName {
                                                Text: "Select an augment";
                                                Style: (FontSize: 16, TextColor: #e6edf5, RenderBold: true, Wrap: true, HorizontalAlignment: Center);
                                                Anchor: (Bottom: 4);
                                            }

                                            Label #AugmentInfoTier {
                                                Text: "";
                                                Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, HorizontalAlignment: Center);
                                                Anchor: (Height: 18, Bottom: 4);
                                                Visible: false;
                                            }
                                        }

                                        // Divider
                                        Group #AugmentInfoDivider {
                                            Anchor: (Height: 1, Bottom: 10);
                                            Background: #ffffff(0.08);
                                            Visible: false;
                                        }

                                        // Description
                                        Label #AugmentInfoDescription {
                                            Text: "";
                                            Style: (FontSize: 13, TextColor: #c5d4e8, Wrap: true);
                                            Anchor: (Bottom: 10);
                                            Padding: (Horizontal: 12);
                                            Visible: false;
                                        }

                                        // Second divider
                                        Group #AugmentInfoDivider2 {
                                            Anchor: (Height: 1, Bottom: 10);
                                            Background: #ffffff(0.08);
                                            Padding: (Horizontal: 12);
                                            Visible: false;
                                        }

                                        // Values
                                        Group #AugmentInfoValues {
                                            LayoutMode: Top;
                                            Padding: (Horizontal: 12);
                                            Visible: false;

                                            Group #AugmentInfoSection1 {
                                                LayoutMode: Top;
                                                Anchor: (Bottom: 8);
                                                Visible: false;

                                                Label #AugmentInfoSection1Title {
                                                    Text: "";
                                                    Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, Wrap: true);
                                                    Anchor: (Bottom: 2);
                                                    Visible: false;
                                                }

                                                Label #AugmentInfoSection1Body {
                                                    Text: "";
                                                    Style: (FontSize: 12, TextColor: #c5d4e8, Wrap: true);
                                                    Visible: false;
                                                }
                                            }

                                            Group #AugmentInfoSection2 {
                                                LayoutMode: Top;
                                                Anchor: (Bottom: 8);
                                                Visible: false;

                                                Label #AugmentInfoSection2Title {
                                                    Text: "";
                                                    Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, Wrap: true);
                                                    Anchor: (Bottom: 2);
                                                    Visible: false;
                                                }

                                                Label #AugmentInfoSection2Body {
                                                    Text: "";
                                                    Style: (FontSize: 12, TextColor: #c5d4e8, Wrap: true);
                                                    Visible: false;
                                                }
                                            }

                                            Group #AugmentInfoSection3 {
                                                LayoutMode: Top;
                                                Anchor: (Bottom: 8);
                                                Visible: false;

                                                Label #AugmentInfoSection3Title {
                                                    Text: "";
                                                    Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, Wrap: true);
                                                    Anchor: (Bottom: 2);
                                                    Visible: false;
                                                }

                                                Label #AugmentInfoSection3Body {
                                                    Text: "";
                                                    Style: (FontSize: 12, TextColor: #c5d4e8, Wrap: true);
                                                    Visible: false;
                                                }
                                            }

                                            Group #AugmentInfoSection4 {
                                                LayoutMode: Top;
                                                Anchor: (Bottom: 8);
                                                Visible: false;

                                                Label #AugmentInfoSection4Title {
                                                    Text: "";
                                                    Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, Wrap: true);
                                                    Anchor: (Bottom: 2);
                                                    Visible: false;
                                                }

                                                Label #AugmentInfoSection4Body {
                                                    Text: "";
                                                    Style: (FontSize: 12, TextColor: #c5d4e8, Wrap: true);
                                                    Visible: false;
                                                }
                                            }

                                            Group #AugmentInfoSection5 {
                                                LayoutMode: Top;
                                                Visible: false;

                                                Label #AugmentInfoSection5Title {
                                                    Text: "";
                                                    Style: (FontSize: 12, TextColor: #9fb6d3, RenderBold: true, Wrap: true);
                                                    Anchor: (Bottom: 2);
                                                    Visible: false;
                                                }

                                                Label #AugmentInfoSection5Body {
                                                    Text: "";
                                                    Style: (FontSize: 12, TextColor: #c5d4e8, Wrap: true);
                                                    Visible: false;
                                                }
                                            }
                                        }
                                    }
                                }

                                Group { Anchor: (Height: 8); }

                                $C.@TextButton #AugmentInfoRerollButton {
                                    Text: "REROLL";
                                    Anchor: (Width: 220, Height: 34);
                                    Padding: (Horizontal: 14, Vertical: 6);
                                    Visible: false;
                                }
                            }
                        }
                    }
                }
            }
        }
        }

        Group { Anchor: (Height: 14); }

        // ====================== FOOTER NAVBAR (root, disconnected) ======================
        Group {
            LayoutMode: Middle;
            Anchor: (Height: 92);

            Group {
                Anchor: (Width: 480, Height: 92);
                $Nav.@BottomNavBar {}
            }
        }
    }
}