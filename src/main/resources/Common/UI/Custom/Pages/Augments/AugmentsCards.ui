$C = "../../Common.ui";

// Augments page showing three randomly selected augment cards. Title/description
// are filled in by AugmentsUIPage at runtime.
@ChooseButtonStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

@ButtonClusterWidth = 180;

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;

        Group {
            LayoutMode: Top;
            Anchor: (Width: 980);
            Padding: (Full: 12);

            // Single tier title row (ELITE / MYTHIC)
            Group {
                LayoutMode: Middle;
                Anchor: (Width: 980);

                $C.@Title #AugmentsTierTitle {
                    @Text = "AUGMENTS";
                    Style: (FontSize: 24, TextColor: #e6edf5, RenderBold: true, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                }
            }

            Group { Anchor: (Height: 12); }

            // Cards row (centered)
            Group {
                LayoutMode: Middle;
                Anchor: (Width: 980);

                Group {
                    LayoutMode: Left;

                    // Card 1
                    Group #AugmentCard1 {
                        Anchor: (Width: 300, Height: 480);

                        Group #AugmentCard1BgCommon {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: (TexturePath: "../../Tiles/TileCommon.png");
                            Visible: true;
                        }

                        Group #AugmentCard1BgElite {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: (TexturePath: "../../Tiles/TileElite.png");
                            Visible: false;
                        }

                        Group #AugmentCard1BgLegendary {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: (TexturePath: "../../Tiles/TileLegendary.png");
                            Visible: false;
                        }

                        Group #AugmentCard1BgMythic {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: (TexturePath: "../../Tiles/TileMythic.png");
                            Visible: false;
                        }

                        Group #AugmentCard1Content {
                            LayoutMode: Top;
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);

                            Group {
                                LayoutMode: Middle;
                                Anchor: (Width: 300, Height: 44);

                                Label #AugmentCard1Title {
                                    Text: "AUGMENT";
                                    Style: (FontSize: 17, TextColor: #e6edf5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                }
                            }

                            Group {
                                LayoutMode: Top;
                                Padding: (Full: 14);

                                Group {
                                    LayoutMode: Top;
                                    Anchor: (Width: 240);

                                    Group {
                                        Anchor: (Width: 100, Height: 100);
                                        LayoutMode: Middle;
                                        Background: #050b16(0.65);

                                        ItemIcon #AugmentCard1Icon {
                                            Anchor: (Width: 90, Height: 90);
                                            Visible: false;
                                        }
                                    }

                                    Group { Anchor: (Height: 10); }

                                    Label #AugmentCard1Description {
                                        Text: "Loading augment...";
                                        Style: (FontSize: 16, TextColor: #e6edf5, RenderBold: true, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                    }

                                    Group { Anchor: (Height: 8); }

                                    Label #AugmentCard1Buffs {
                                        Text: "Buffs: -";
                                        Style: (FontSize: 14, TextColor: #cdd9ec, Wrap: true, HorizontalAlignment: Center);
                                        Visible: false;
                                    }

                                    Label #AugmentCard1Debuffs {
                                        Text: "Debuffs: -";
                                        Style: (FontSize: 14, TextColor: #ffb3b3, Wrap: true, HorizontalAlignment: Center);
                                        Visible: false;
                                    }

                                    Label #AugmentCard1SelfDamage {
                                        Text: "";
                                        Style: (FontSize: 14, TextColor: #ffb86b, Wrap: true, HorizontalAlignment: Center);
                                        Visible: false;
                                    }

                                    Label #AugmentCard1Neutral {
                                        Text: "";
                                        Style: (FontSize: 14, TextColor: #e6edf5, Wrap: true, HorizontalAlignment: Center);
                                        Visible: false;
                                    }

                                    Label #AugmentCard1Notes {
                                        Text: "";
                                        Style: (FontSize: 13, TextColor: #c9d2de, Wrap: true, HorizontalAlignment: Center);
                                        Visible: false;
                                    }

                                    Group { Anchor: (Height: 6); }

                                    Label #AugmentCard1Duration {
                                        Text: "Duration: -";
                                        Style: (FontSize: 14, TextColor: #b7c6d9, Wrap: true, HorizontalAlignment: Center);
                                        Visible: false;
                                    }

                                    Label #AugmentCard1Cooldown {
                                        Text: "Cooldown: -";
                                        Style: (FontSize: 14, TextColor: #b7c6d9, Wrap: true, HorizontalAlignment: Center);
                                        Visible: false;
                                    }

                                    Group { Anchor: (Height: 14); }
                                }
                            }
                        }

                        Button #AugmentCard1HitButton {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Style: (
                                Default: (Background: #000000(0)),
                                Hovered: (Background: #ffffff(0.16)),
                                Pressed: (Background: #ffffff(0.24))
                            );
                        }
                    }

                    Group { Anchor: (Width: 40); }

                    // Card 2
                    Group #AugmentCard2 {
                        Anchor: (Width: 300, Height: 480);

                        Group #AugmentCard2BgCommon {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: (TexturePath: "../../Tiles/TileCommon.png");
                            Visible: true;
                        }

                        Group #AugmentCard2BgElite {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: (TexturePath: "../../Tiles/TileElite.png");
                            Visible: false;
                        }

                        Group #AugmentCard2BgLegendary {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: (TexturePath: "../../Tiles/TileLegendary.png");
                            Visible: false;
                        }

                        Group #AugmentCard2BgMythic {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: (TexturePath: "../../Tiles/TileMythic.png");
                            Visible: false;
                        }

                        Group #AugmentCard2Content {
                            LayoutMode: Top;
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);

                        Group {
                            LayoutMode: Middle;
                            Anchor: (Width: 300, Height: 44);

                            Label #AugmentCard2Title {
                                Text: "AUGMENT";
                                Style: (FontSize: 17, TextColor: #e6edf5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                            }
                        }

                        Group {
                            LayoutMode: Top;
                            Padding: (Full: 14);

                            Group {
                                LayoutMode: Top;
                                Anchor: (Width: 240);

                                Group {
                                    Anchor: (Width: 100, Height: 100);
                                    LayoutMode: Middle;
                                    Background: #050b16(0.65);

                                    ItemIcon #AugmentCard2Icon {
                                        Anchor: (Width: 90, Height: 90);
                                        Visible: false;
                                    }
                                    
                                }

                                Group { Anchor: (Height: 10); }

                                Label #AugmentCard2Description {
                                    Text: "Loading augment...";
                                    Style: (FontSize: 16, TextColor: #e6edf5, RenderBold: true, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                }

                                Group { Anchor: (Height: 8); }

                                Label #AugmentCard2Buffs {
                                    Text: "Buffs: -";
                                    Style: (FontSize: 14, TextColor: #cdd9ec, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }

                                Label #AugmentCard2Debuffs {
                                    Text: "Debuffs: -";
                                    Style: (FontSize: 14, TextColor: #ffb3b3, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }

                                Label #AugmentCard2SelfDamage {
                                    Text: "";
                                    Style: (FontSize: 14, TextColor: #ffb86b, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }

                                Label #AugmentCard2Neutral {
                                    Text: "";
                                    Style: (FontSize: 14, TextColor: #e6edf5, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }

                                Label #AugmentCard2Notes {
                                    Text: "";
                                    Style: (FontSize: 13, TextColor: #c9d2de, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }

                                Group { Anchor: (Height: 6); }

                                Label #AugmentCard2Duration {
                                    Text: "Duration: -";
                                    Style: (FontSize: 14, TextColor: #b7c6d9, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }

                                Label #AugmentCard2Cooldown {
                                    Text: "Cooldown: -";
                                    Style: (FontSize: 14, TextColor: #b7c6d9, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }
                                Group { Anchor: (Height: 14); }
                            }
                        }
                        }

                        Button #AugmentCard2HitButton {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Style: (
                                Default: (Background: #000000(0)),
                                Hovered: (Background: #ffffff(0.16)),
                                Pressed: (Background: #ffffff(0.24))
                            );
                        }
                    }

                    Group { Anchor: (Width: 40); }

                    // Card 3
                    Group #AugmentCard3 {
                        Anchor: (Width: 300, Height: 480);

                        Group #AugmentCard3BgCommon {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: (TexturePath: "../../Tiles/TileCommon.png");
                            Visible: true;
                        }

                        Group #AugmentCard3BgElite {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: (TexturePath: "../../Tiles/TileElite.png");
                            Visible: false;
                        }

                        Group #AugmentCard3BgLegendary {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: (TexturePath: "../../Tiles/TileLegendary.png");
                            Visible: false;
                        }

                        Group #AugmentCard3BgMythic {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Background: (TexturePath: "../../Tiles/TileMythic.png");
                            Visible: false;
                        }

                        Group #AugmentCard3Content {
                            LayoutMode: Top;
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);

                        Group {
                            LayoutMode: Middle;
                            Anchor: (Width: 300, Height: 44);

                            Label #AugmentCard3Title {
                                Text: "AUGMENT";
                                Style: (FontSize: 17, TextColor: #e6edf5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                            }
                        }

                        Group {
                            LayoutMode: Top;
                            Padding: (Full: 14);

                            Group {
                                LayoutMode: Top;
                                Anchor: (Width: 240);

                                Group {
                                    Anchor: (Width: 100, Height: 100);
                                    LayoutMode: Middle;
                                    Background: #050b16(0.65);

                                    ItemIcon #AugmentCard3Icon {
                                        Anchor: (Width: 90, Height: 90);
                                        Visible: false;
                                    }
                                }

                                Group { Anchor: (Height: 10); }

                                Label #AugmentCard3Description {
                                    Text: "Loading augment...";
                                    Style: (FontSize: 16, TextColor: #e6edf5, RenderBold: true, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                                }

                                Group { Anchor: (Height: 8); }

                                Label #AugmentCard3Buffs {
                                    Text: "Buffs: -";
                                    Style: (FontSize: 14, TextColor: #cdd9ec, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }

                                Label #AugmentCard3Debuffs {
                                    Text: "Debuffs: -";
                                    Style: (FontSize: 14, TextColor: #ffb3b3, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }

                                Label #AugmentCard3SelfDamage {
                                    Text: "";
                                    Style: (FontSize: 14, TextColor: #ffb86b, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }

                                Label #AugmentCard3Neutral {
                                    Text: "";
                                    Style: (FontSize: 14, TextColor: #e6edf5, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }

                                Label #AugmentCard3Notes {
                                    Text: "";
                                    Style: (FontSize: 13, TextColor: #c9d2de, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }

                                Group { Anchor: (Height: 6); }

                                Label #AugmentCard3Duration {
                                    Text: "Duration: -";
                                    Style: (FontSize: 14, TextColor: #b7c6d9, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }

                                Label #AugmentCard3Cooldown {
                                    Text: "Cooldown: -";
                                    Style: (FontSize: 14, TextColor: #b7c6d9, Wrap: true, HorizontalAlignment: Center);
                                    Visible: false;
                                }
                                Group { Anchor: (Height: 14); }
                            }
                        }
                        }

                        Button #AugmentCard3HitButton {
                            Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
                            Style: (
                                Default: (Background: #000000(0)),
                                Hovered: (Background: #ffffff(0.16)),
                                Pressed: (Background: #ffffff(0.24))
                            );
                        }
                    }
                }
            }

            Group { Anchor: (Height: 14); }

            // Reroll row (centered, slim)
            Group {
                LayoutMode: Middle;
                Anchor: (Width: 980);

                Group {
                    LayoutMode: Left;
                    Anchor: (Width: 980);

                    Group {
                        Anchor: (Width: 300);
                        LayoutMode: Middle;

                        $C.@TextButton #AugmentCard1Reroll {
                            Text: "Reroll";
                            Anchor: (Width: 140, Height: 30);
                            Padding: (Horizontal: 12, Vertical: 4);
                            Style: @ChooseButtonStyle;
                            Visible: false;
                        }
                    }

                    Group { Anchor: (Width: 40); }

                    Group {
                        Anchor: (Width: 300);
                        LayoutMode: Middle;

                        $C.@TextButton #AugmentCard2Reroll {
                            Text: "Reroll";
                            Anchor: (Width: 140, Height: 30);
                            Padding: (Horizontal: 12, Vertical: 4);
                            Style: @ChooseButtonStyle;
                            Visible: false;
                        }
                    }

                    Group { Anchor: (Width: 40); }

                    Group {
                        Anchor: (Width: 300);
                        LayoutMode: Middle;

                        $C.@TextButton #AugmentCard3Reroll {
                            Text: "Reroll";
                            Anchor: (Width: 140, Height: 30);
                            Padding: (Horizontal: 12, Vertical: 4);
                            Style: @ChooseButtonStyle;
                            Visible: false;
                        }
                    }
                }
            }

            Group { Anchor: (Height: 32); }

            Group {
                LayoutMode: Middle;
                Anchor: (Width: 980);

                $C.@TextButton #AugmentsRefreshButton {
                    Text: "Refresh";
                    Anchor: (Width: 160, Height: 34);
                    Padding: (Horizontal: 14, Vertical: 6);
                    Style: @ChooseButtonStyle;
                    Visible: false;
                }
            }
        }
    }
}

$C.@BackButton {}