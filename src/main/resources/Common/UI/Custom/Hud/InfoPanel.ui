// Import: $IP = "InfoPanel.ui"; then $IP.@InfoPanel #InfoPanel {}
@InfoPanel = Group {
  LayoutMode: Top;
  Anchor: (Bottom: 12, Left: 135, Width: 220, Height: 135);
  Background: (TexturePath: "ObjectivePanelContainer.png", Border: 15);
  Padding: (Horizontal: 12, Top: 8, Bottom: 10);

  Label #Level {
    Anchor: (Height: 20, Bottom: 4);
    Text: "Level";
    Style: (TextColor: #f0c040, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
  }

  Group {
    Anchor: (Height: 1, Bottom: 5);
    Background: #7a5a10;
  }

  Group #InfoMobLevel {
    LayoutMode: Left;
    Anchor: (Height: 16, Top: 5);

    Label #InfoMobLevelPrefix {
      Style: (FontSize: 10, TextColor: #7a6a3a, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
      Text: "Local Mobs: ";
    }

    Label #InfoMobLevelValue {
      Anchor: (Left: 2);
      Style: (FontSize: 11, TextColor: #e8e8b0, RenderBold: true, VerticalAlignment: Center);
      Text: "--";
    }
  }

  Group #InfoRace {
    LayoutMode: Left;
    Anchor: (Height: 16, Top: 3);

    ItemIcon #InfoRaceIcon {
      Anchor: (Width: 13, Height: 13);
      Visible: false;
    }

    Label #InfoRacePrefix {
      Anchor: (Left: 2);
      Style: (FontSize: 10, TextColor: #7a6a3a, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
      Text: "Race: ";
    }

    Label #InfoRaceValue {
      Anchor: (Left: 2);
      Style: (FontSize: 11, TextColor: #7dd4c0, RenderBold: true, VerticalAlignment: Center);
      Text: "--";
    }
  }

  Group {
    Anchor: (Height: 1, Top: 5);
    Background: #4a3a10;
  }

  Group #PrimaryClassRow {
    LayoutMode: Left;
    Anchor: (Height: 18, Top: 5);

    ItemIcon #PrimaryIcon {
      Anchor: (Width: 13, Height: 13);
      Visible: false;
    }

    Label #PrimaryClass {
      Anchor: (Height: 18, Left: 3);
      Style: (FontSize: 12, TextColor: #f0c040, RenderBold: true, VerticalAlignment: Center);
      Text: "--";
    }
  }

  Group #SecondaryClassRow {
    LayoutMode: Left;
    Anchor: (Height: 16, Top: 2);

    ItemIcon #SecondaryIcon {
      Anchor: (Width: 13, Height: 13);
      Visible: false;
    }

    Label #SecondaryClass {
      Anchor: (Height: 16, Left: 3);
      Style: (FontSize: 11, TextColor: #a0a8c8, RenderBold: true, VerticalAlignment: Center);
      Text: "--";
    }
  }
};
